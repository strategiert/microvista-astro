/* 
** Contact Form 7 Styles 
*/
.wpcf7-form input[type="text"], 
.wpcf7-form input[type="email"], 
.wpcf7-form input[type="url"], 
.wpcf7-form input[type="password"], 
.wpcf7-form input[type="search"], 
.wpcf7-form input[type="number"], 
.wpcf7-form input[type="tel"], 
.wpcf7-form textarea {
    background-color:#eef2f5!important;
    color: black;
    width: 100%;
    padding: 12px 16px;
    border-radius: 0;
    border: 0;
    font-family:"PT Sans";
}

.datenschutz{font-family:"PT Sans";margin-top:-10px;}

.wpcf7-list-item{margin-left: 0px; margin-top: 10px;}

.kflabel {width:100%;}


.wpcf7-text:focus,
.wpcf7-textarea:focus {
    outline: 1px solid rgba(238, 242, 245, 0.9);
    outline-offset: 0;
}
.wpcf7-mail-sent-ok {
    border: 0;
    background: #5471de;
    color: #fff;
    padding: 18px;
}
.wpcf7-acceptance-missing,
.wpcf7-validation-errors {
    border: 0;
    background: #f9443b;
    color: #fff;
    padding: 18px;
}
.wpcf7-not-valid-tip {
    color: #f9443b;
}
/* 
** Button Styles 
*/
.wpcf7-form .button {
    background-color: #ee7711;
    border: 0;
    color: #fff;
    border-radius: 1px;
    font-weight: 700;
    text-align: center;
    width: auto;
    margin-top:20px;
    margin-bottom: 20px;
    padding: 10px 42px;
    letter-spacing: 2px;
    font-size: 16px;
    font-family:"PT Sans";
}
.wpcf7-form .button:hover {
    cursor: pointer;}

@media screen and (max-width: 736px){.wpcf7-submit{    margin:0 auto;
    display:block;}}
    
.wpcf7-select{color:black;}


.current-lang > a{
  color: #8ebfd6 !important;
}

		</style>
		</head>
