			#menu_cta{background-color:#ee7711; color: white;padding-bottom:10px; padding-top:10px; padding-left:20px; padding-right:20px;}

a {
    color: #8EBFD6; /*Normal Link Color*/
}

a:active, a:hover {
    color: #32285B; /*Hover and Active satet color*/
}
.grecaptcha-badge{
	visibility: hidden;
