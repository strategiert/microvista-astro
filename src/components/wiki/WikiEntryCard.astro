---
interface Props {
  term: string;
  definition: string;
  category: string;
  slug: string;
  delay?: number;
}

const { term, definition, category, slug, delay = 0 } = Astro.props;
---

<a href={`/wiki/${slug}`} class="glass-card wiki-entry-card animate-fade-in-up" style={`animation-delay: ${delay}ms`}>
  <div class="wiki-entry-header">
    <h3 class="wiki-entry-title">{term}</h3>
  </div>
  
  <p class="wiki-entry-definition">{definition.slice(0, 120)}...</p>
  
  <div class="wiki-entry-footer">
    <span class="wiki-entry-category">{category}</span>
    <div class="wiki-entry-arrow">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </div>
  </div>
</a>
