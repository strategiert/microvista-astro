---
/**
 * HeroSection — Microvista Homepage Hero
 * Tech-forward Design mit starker Typografie
 */
import { localePath, type Locale } from '../../i18n/translations';

interface Props {
  locale: Locale;
  content: {
    heroBadge: string;
    heroTitle: string;
    heroTitleAccent: string;
    heroSub: string;
    cta1: string;
    cta2: string;
  };
}

const { locale, content: t } = Astro.props;
const lp = (path: string) => localePath(path, locale);
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/ct/CT-Techniker-am-industriellen-CT-Dustin-Klein-scaled-e1761285791426.jpg"
      alt="CT-Techniker am industriellen CT"
      class="hero-img"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid-pattern"></div>
  </div>
  
  <div class="container hero-content">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      {t.heroBadge}
    </div>
    
    <h1 class="hero-title">
      {t.heroTitle}
      <span class="hero-title-accent">{t.heroTitleAccent}</span>
    </h1>
    
    <p class="hero-sub">{t.heroSub}</p>
    
    <div class="hero-ctas">
      <a href={lp('/kontakt')} class="btn btn-primary">
        <svg class="btn-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2v8m0 0l-3-3m3 3l3-3m-8 7v6a2 2 0 002 2h8a2 2 0 002-2v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {t.cta1}
      </a>
      <a href={lp('/kontakt')} class="btn btn-outline">
        {t.cta2}
        <svg class="btn-icon-right" width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3.34 17.333a.833.833 0 01-1.187-1.034l2.5-8.333a.833.833 0 01.154-.27l8.75-8.75a.833.833 0 011.179 0l4.583 4.583a.833.833 0 010 1.179l-8.75 8.75a.833.833 0 01-.27.154l-8.333 2.5.374-.78z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-value">24h</span>
        <span class="stat-label">Express</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">ISO</span>
        <span class="stat-label">9001 & 17025</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">µm</span>
        <span class="stat-label">Auflösung</span>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--mv-violet);
}

.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 25%;
  display: block;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(50, 40, 91, 0.92) 0%,
    rgba(50, 40, 91, 0.75) 40%,
    rgba(50, 40, 91, 0.45) 100%
  );
}

.hero-grid-pattern {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(142, 191, 214, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(142, 191, 214, 0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  padding-top: calc(var(--space-24) + 100px);
  padding-bottom: var(--space-16);
  max-width: 840px;
}

/* Badge */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  background: rgba(142, 191, 214, 0.12);
  border: 1px solid rgba(142, 191, 214, 0.3);
  color: var(--mv-blue);
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-8);
}

.badge-dot {
  width: 6px;
  height: 6px;
  background: var(--mv-orange);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

/* Title */
.hero-title {
  font-family: var(--font-heading);
  font-size: clamp(var(--text-4xl), 8vw, var(--text-6xl));
  font-weight: 700;
  line-height: 1.05;
  color: var(--mv-white);
  margin-bottom: var(--space-6);
  text-shadow: 0 2px 40px rgba(0, 0, 0, 0.2);
}

.hero-title-accent {
  display: block;
  color: var(--mv-blue);
  position: relative;
}

.hero-title-accent::after {
  content: '';
  position: absolute;
  bottom: 0.1em;
  left: 0;
  width: 100%;
  height: 0.12em;
  background: linear-gradient(90deg, var(--mv-blue) 0%, transparent 100%);
  opacity: 0.3;
}

/* Subtitle */
.hero-sub {
  font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.7;
  max-width: 600px;
  margin-bottom: var(--space-10);
}

/* CTAs */
.hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-bottom: var(--space-16);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-4) var(--space-6);
  border-radius: var(--radius-md);
  font-family: var(--font-heading);
  font-size: var(--text-base);
  font-weight: 600;
  text-decoration: none;
  transition: all var(--transition-base);
  cursor: pointer;
  white-space: nowrap;
}

.btn-icon {
  flex-shrink: 0;
}

.btn-icon-right {
  flex-shrink: 0;
  transition: transform var(--transition-base);
}

.btn-primary {
  background: var(--mv-orange);
  color: var(--mv-white);
  border: 2px solid var(--mv-orange);
  box-shadow: 0 4px 14px rgba(238, 119, 17, 0.35);
}

.btn-primary:hover {
  background: var(--mv-orange-hover);
  border-color: var(--mv-orange-hover);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(238, 119, 17, 0.45);
}

.btn-outline {
  background: transparent;
  color: var(--mv-white);
  border: 2px solid rgba(255, 255, 255, 0.5);
}

.btn-outline:hover {
  background: var(--mv-white);
  color: var(--mv-violet);
  border-color: var(--mv-white);
}

.btn-outline:hover .btn-icon-right {
  transform: translateX(3px);
}

/* Stats */
.hero-stats {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  padding-top: var(--space-8);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.stat-value {
  font-family: var(--font-heading);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--mv-white);
}

.stat-label {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background: rgba(255, 255, 255, 0.15);
}

/* Responsive */
@media (max-width: 640px) {
  .hero-stats {
    gap: var(--space-4);
  }
  
  .stat-divider {
    height: 24px;
  }
  
  .hero-title-accent::after {
    display: none;
  }
}
</style>
