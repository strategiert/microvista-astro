---
/**
 * BranchenCard - Große Branchen-Karte für Index
 */
import { localePath, type Locale } from '../../i18n/translations';

interface Props {
  slug: string;
  name: string;
  description: string;
  icon: string;
  locale: Locale;
  ctaText: string;
  featured?: boolean;
}

const { slug, name, description, icon, locale, ctaText, featured = false } = Astro.props;
const lp = (path: string) => localePath(path, locale);

// Industry Icons
const icons: Record<string, string> = {
  'automotive': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg>`,
  'elektronik': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>`,
  'medizintechnik': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  'luftfahrt': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 12h20"/><path d="M13 2v20"/><path d="M21 12a9 9 0 0 1-9 9"/><path d="M3 12a9 9 0 0 0 9-9"/></svg>`,
  'kunststoff': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M9 5H5"/></svg>`,
  'energie': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  'additive-fertigung': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>`,
  'batteriesysteme': `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="16" height="10" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/></svg>`,
};

const iconSvg = icons[icon] || icons['automotive'];

// Industry colors
const colors: Record<string, { bg: string; accent: string }> = {
  'automotive': { bg: 'rgba(50, 40, 91, 0.08)', accent: '#32285b' },
  'elektronik': { bg: 'rgba(0, 160, 210, 0.08)', accent: '#00a0d2' },
  'medizintechnik': { bg: 'rgba(16, 185, 129, 0.08)', accent: '#10b981' },
  'luftfahrt': { bg: 'rgba(139, 92, 246, 0.08)', accent: '#8b5cf6' },
  'kunststoff': { bg: 'rgba(245, 158, 11, 0.08)', accent: '#f59e0b' },
  'energie': { bg: 'rgba(238, 119, 17, 0.08)', accent: '#ee7711' },
  'additive-fertigung': { bg: 'rgba(6, 182, 212, 0.08)', accent: '#06b6d4' },
  'batteriesysteme': { bg: 'rgba(50, 40, 91, 0.06)', accent: '#32285b' },
};

const color = colors[icon] || colors['automotive'];
---

<article class:list={['branchen-card', { 'featured': featured }]} style={`--accent-color: ${color.accent}; --bg-color: ${color.bg};`}>
  <a href={lp(`/branchen/${slug}`)} class="card-link">
    <div class="card-visual">
      <div class="icon-wrapper" set:html={iconSvg} />
      <div class="card-glow"></div>
    </div>
    <div class="card-content">
      <h3 class="card-title">{name}</h3>
      <p class="card-description">{description}</p>
      <span class="card-cta">
        {ctaText}
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </a>
</article>

<style>
  .branchen-card {
    position: relative;
    background: var(--mv-white);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 2px solid var(--mv-gray-100);
    transition: all var(--transition-slow);
  }

  .branchen-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -15px rgba(50, 40, 91, 0.15);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .card-visual {
    position: relative;
    height: 160px;
    background: linear-gradient(135deg, var(--bg-color) 0%, var(--mv-white) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .icon-wrapper {
    position: relative;
    z-index: 1;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--mv-white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    color: var(--accent-color);
    transition: all var(--transition-slow);
  }

  .branchen-card:hover .icon-wrapper {
    transform: scale(1.1);
    box-shadow: 0 0 0 4px var(--bg-color), var(--shadow-lg);
  }

  .card-glow {
    position: absolute;
    width: 200px;
    height: 200px;
    background: var(--accent-color);
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.1;
    transition: opacity var(--transition-slow);
  }

  .branchen-card:hover .card-glow {
    opacity: 0.2;
  }

  .card-content {
    flex: 1;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--mv-gray-900);
    margin-bottom: var(--space-2);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--mv-gray-600);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    flex: 1;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent-color);
    transition: gap var(--transition-fast);
  }

  .branchen-card:hover .card-cta {
    gap: var(--space-3);
  }

  /* Featured variant */
  .featured {
    grid-column: span 2;
  }

  .featured .card-link {
    flex-direction: row;
  }

  .featured .card-visual {
    width: 40%;
    height: auto;
    min-height: 280px;
  }

  .featured .card-content {
    width: 60%;
    padding: var(--space-8);
    justify-content: center;
  }

  .featured .card-title {
    font-size: var(--text-2xl);
  }

  .featured .card-description {
    font-size: var(--text-base);
  }

  @media (max-width: 768px) {
    .featured {
      grid-column: span 1;
    }

    .featured .card-link {
      flex-direction: column;
    }

    .featured .card-visual {
      width: 100%;
      height: 160px;
      min-height: auto;
    }

    .featured .card-content {
      width: 100%;
      padding: var(--space-6);
    }

    .featured .card-title {
      font-size: var(--text-xl);
    }

    .featured .card-description {
      font-size: var(--text-sm);
    }
  }
</style>
