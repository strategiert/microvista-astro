---
/**
 * GatewaySection — Labor & Serie Kacheln
 * Die wichtigste Conversion-Sektion der Homepage
 */
import { localePath, type Locale } from '../../i18n/translations';

interface Props {
  locale: Locale;
  content: {
    worldsTitle: string;
    laborTitle: string;
    laborSub: string;
    laborBenefits: string[];
    laborCta: string;
    serieTitle: string;
    serieSub: string;
    serieBenefits: string[];
    serieCta: string;
  };
}

const { locale, content: t } = Astro.props;
const lp = (path: string) => localePath(path, locale);
---

<section class="worlds-section">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Unsere Welten</span>
      <h2 class="section-title">{t.worldsTitle}</h2>
    </div>
    
    <div class="worlds-grid">
      <!-- Labor Card -->
      <a href={lp('/labor')} class="world-card world-labor">
        <div class="card-glow labor-glow"></div>
        <div class="world-img-wrap">
          <img
            src="/images/ct/Auswertung-CT-Scan-vom-CT-Techniker-Dustin-Klein-e1761286147918.jpg"
            alt="CT-Labor"
            loading="lazy"
          />
          <div class="world-img-overlay"></div>
          <div class="world-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
            </svg>
          </div>
        </div>
        <div class="world-content">
          <span class="world-badge world-badge-labor">Labor</span>
          <h3>{t.laborTitle}</h3>
          <p>{t.laborSub}</p>
          <ul class="world-benefits">
            {t.laborBenefits.map(b => (
              <li>
                <svg class="benefit-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <circle cx="9" cy="9" r="8" fill="rgba(142,191,214,0.15)"/>
                  <path d="M5.5 9l2.5 2.5 4.5-5" stroke="#8ebfd6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          <span class="world-cta">
            {t.laborCta}
            <svg class="cta-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>

      <!-- Serie Card -->
      <a href={lp('/serie')} class="world-card world-serie">
        <div class="card-glow serie-glow"></div>
        <div class="world-img-wrap">
          <img
            src="/images/ct/Microvista-Industrieller-CT-Container-Truck-ScanExpress-4K-scaled.jpg"
            alt="ScanExpress Serienprüfung"
            loading="lazy"
          />
          <div class="world-img-overlay"></div>
          <div class="world-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
        </div>
        <div class="world-content">
          <span class="world-badge world-badge-serie">Serie</span>
          <h3>{t.serieTitle}</h3>
          <p>{t.serieSub}</p>
          <ul class="world-benefits">
            {t.serieBenefits.map(b => (
              <li>
                <svg class="benefit-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <circle cx="9" cy="9" r="8" fill="rgba(238,119,17,0.15)"/>
                  <path d="M5.5 9l2.5 2.5 4.5-5" stroke="#ee7711" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          <span class="world-cta">
            {t.serieCta}
            <svg class="cta-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
.worlds-section {
  background: linear-gradient(180deg, var(--mv-gray-50) 0%, var(--mv-white) 100%);
  padding: var(--space-24) 0;
}

.section-header {
  text-align: center;
  margin-bottom: var(--space-12);
}

.section-eyebrow {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--mv-blue);
  margin-bottom: var(--space-3);
}

.section-title {
  font-family: var(--font-heading);
  font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
  font-weight: 700;
  color: var(--mv-violet);
}

.worlds-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-8);
}

@media (min-width: 768px) {
  .worlds-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
}

.world-card {
  position: relative;
  display: block;
  text-decoration: none;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  background: var(--mv-white);
  border: 1px solid var(--mv-gray-200);
  transition: all var(--transition-slow);
  box-shadow: var(--shadow-md);
}

.card-glow {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity var(--transition-slow);
  pointer-events: none;
}

.labor-glow {
  background: radial-gradient(circle at 50% 0%, rgba(142, 191, 214, 0.15) 0%, transparent 60%);
}

.serie-glow {
  background: radial-gradient(circle at 50% 0%, rgba(238, 119, 17, 0.12) 0%, transparent 60%);
}

.world-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}

.world-card:hover .card-glow {
  opacity: 1;
}

.world-img-wrap {
  position: relative;
  height: 240px;
  overflow: hidden;
}

.world-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.world-card:hover .world-img-wrap img {
  transform: scale(1.05);
}

.world-img-overlay {
  position: absolute;
  inset: 0;
}

.world-labor .world-img-overlay {
  background: linear-gradient(to top, rgba(50, 40, 91, 0.85) 0%, rgba(50, 40, 91, 0.3) 50%, transparent 100%);
}

.world-serie .world-img-overlay {
  background: linear-gradient(to top, rgba(238, 119, 17, 0.75) 0%, rgba(238, 119, 17, 0.25) 50%, transparent 100%);
}

.world-icon {
  position: absolute;
  top: var(--space-6);
  right: var(--space-6);
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-xl);
  color: var(--mv-violet);
  box-shadow: var(--shadow-lg);
  transition: all var(--transition-base);
}

.world-card:hover .world-icon {
  transform: scale(1.1) rotate(-5deg);
}

.world-serie .world-icon {
  color: var(--mv-orange);
}

.world-content {
  padding: var(--space-8);
}

.world-badge {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-4);
}

.world-badge-labor {
  background: rgba(50, 40, 91, 0.08);
  color: var(--mv-violet);
}

.world-badge-serie {
  background: rgba(238, 119, 17, 0.08);
  color: var(--mv-orange);
}

.world-content h3 {
  font-family: var(--font-heading);
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--mv-gray-900);
  margin-bottom: var(--space-3);
}

.world-content p {
  color: var(--mv-gray-600);
  line-height: 1.65;
  margin-bottom: var(--space-5);
}

.world-benefits {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.world-benefits li {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: var(--text-sm);
  color: var(--mv-gray-700);
}

.benefit-icon {
  flex-shrink: 0;
}

.world-cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-heading);
  font-size: var(--text-base);
  font-weight: 600;
  transition: all var(--transition-base);
}

.world-labor .world-cta { 
  color: var(--mv-violet); 
}

.world-serie .world-cta { 
  color: var(--mv-orange); 
}

.cta-arrow {
  transition: transform var(--transition-base);
}

.world-card:hover .cta-arrow {
  transform: translateX(4px);
}
</style>
