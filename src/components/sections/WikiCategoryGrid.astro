---
/**
 * WikiCategoryGrid - Bento Grid für Wiki Kategorien
 * Moderne Kachel-Navigation zu Kategorien
 */
import { localePath, type Locale } from '../../i18n/translations';

interface Category {
  id: string;
  label: string;
  count: number;
}

interface Props {
  categories: Category[];
  locale: Locale;
  title?: string;
}

const { categories, locale, title = 'Kategorien' } = Astro.props;
const lp = (path: string) => localePath(path, locale);

// Category Icons & Colors
const categoryMeta: Record<string, { icon: string; color: string; bg: string; description: string }> = {
  'grundlagen': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    color: '#32285b',
    bg: 'rgba(50, 40, 91, 0.08)',
    description: 'Grundlegende CT-Konzepte'
  },
  'verfahren': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    color: '#00a0d2',
    bg: 'rgba(0, 160, 210, 0.08)',
    description: 'Methoden & Techniken'
  },
  'qm': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
    color: '#ee7711',
    bg: 'rgba(238, 119, 17, 0.08)',
    description: 'Qualitätsmanagement'
  },
  'materialien': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    color: '#10b981',
    bg: 'rgba(16, 185, 129, 0.08)',
    description: 'Materialkunde'
  },
  'normen': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
    color: '#8b5cf6',
    bg: 'rgba(139, 92, 246, 0.08)',
    description: 'Normen & Standards'
  },
  'software': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    color: '#06b6d4',
    bg: 'rgba(6, 182, 212, 0.08)',
    description: 'Software & Tools'
  },
  'hardware': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
    color: '#f59e0b',
    bg: 'rgba(245, 158, 11, 0.08)',
    description: 'CT-Hardware'
  },
  'allgemein': {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
    color: '#64748b',
    bg: 'rgba(100, 116, 139, 0.08)',
    description: 'Allgemeine Begriffe'
  },
};
---

<section class="category-section">
  <div class="container">
    <h2 class="section-title">{title}</h2>
    
    <div class="category-grid">
      {categories.map(cat => {
        const meta = categoryMeta[cat.id] || categoryMeta['allgemein'];
        return (
          <a href={lp(`/wiki/kategorie/${cat.id}`)} class="category-card" style={`--cat-color: ${meta.color}; --cat-bg: ${meta.bg};`}>
            <div class="card-icon" set:html={meta.icon} />
            <div class="card-content">
              <h3>{cat.label}</h3>
              <p>{meta.description}</p>
              <span class="card-count">{cat.count} Einträge</span>
            </div>
            <svg class="card-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .category-section {
    padding: var(--space-12) 0 var(--space-16);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--mv-violet);
    margin-bottom: var(--space-6);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .category-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .category-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--mv-white);
    border: 2px solid var(--mv-gray-100);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .category-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--cat-color);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .category-card:hover {
    border-color: var(--cat-color);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .category-card:hover::before {
    opacity: 1;
  }

  .card-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cat-bg);
    border-radius: var(--radius-lg);
    color: var(--cat-color);
  }

  .card-content {
    flex: 1;
  }

  .card-content h3 {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--mv-gray-900);
    margin-bottom: var(--space-1);
  }

  .card-content p {
    font-size: var(--text-sm);
    color: var(--mv-gray-500);
    margin-bottom: var(--space-2);
    line-height: 1.5;
  }

  .card-count {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--cat-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-arrow {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    color: var(--mv-gray-300);
    opacity: 0;
    transform: translateX(-8px);
    transition: all var(--transition-fast);
  }

  .category-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--cat-color);
  }

  @media (max-width: 640px) {
    .category-card {
      padding: var(--space-4);
    }

    .card-icon {
      width: 40px;
      height: 40px;
    }

    .card-arrow {
      display: none;
    }
  }
</style>
