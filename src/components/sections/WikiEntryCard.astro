---
/**
 * WikiEntryCard - Einzelner Wiki-Eintrag in der Liste
 * Kompakte, informative Kachel
 */
import { localePath, type Locale } from '../../i18n/translations';

interface Props {
  term: string;
  definition: string;
  category: string;
  categoryLabel: string;
  slug: string;
  locale: Locale;
  synonyms?: string[];
}

const { term, definition, category, categoryLabel, slug, locale, synonyms = [] } = Astro.props;
const lp = (path: string) => localePath(path, locale);

// Category colors
const categoryColors: Record<string, string> = {
  'grundlagen': '#32285b',
  'verfahren': '#00a0d2',
  'qm': '#ee7711',
  'materialien': '#10b981',
  'normen': '#8b5cf6',
  'software': '#06b6d4',
  'hardware': '#f59e0b',
  'allgemein': '#64748b',
};

const accentColor = categoryColors[category] || '#32285b';
---

<a href={lp(`/wiki/${slug}`)} class="wiki-card" style={`--accent-color: ${accentColor};`}>
  <div class="card-accent"></div>
  <div class="card-content">
    <div class="card-header">
      <h3 class="term">{term}</h3>
      <span class="category-badge" style={`background: ${accentColor}15; color: ${accentColor};`}>
        {categoryLabel}
      </span>
    </div>
    <p class="definition">{definition}</p>
    {synonyms.length > 0 && (
      <div class="synonyms">
        <span class="synonyms-label">Synonyme:</span>
        {synonyms.join(', ')}
      </div>
    )}
  </div>
  <div class="card-arrow">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>

<style>
  .wiki-card {
    display: flex;
    align-items: stretch;
    background: var(--mv-white);
    border: 1px solid var(--mv-gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
    overflow: hidden;
    position: relative;
  }

  .card-accent {
    width: 3px;
    background: var(--accent-color);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .wiki-card:hover {
    border-color: var(--accent-color);
    box-shadow: var(--shadow-md);
    transform: translateX(4px);
  }

  .wiki-card:hover .card-accent {
    opacity: 1;
  }

  .card-content {
    flex: 1;
    padding: var(--space-4) var(--space-5);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .term {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--mv-violet);
    line-height: 1.3;
    transition: color var(--transition-fast);
  }

  .wiki-card:hover .term {
    color: var(--accent-color);
  }

  .category-badge {
    flex-shrink: 0;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .definition {
    font-size: var(--text-sm);
    color: var(--mv-gray-600);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .synonyms {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    color: var(--mv-gray-500);
  }

  .synonyms-label {
    font-weight: 600;
    color: var(--mv-gray-400);
  }

  .card-arrow {
    display: flex;
    align-items: center;
    padding: 0 var(--space-4);
    color: var(--mv-gray-300);
    opacity: 0;
    transition: all var(--transition-fast);
  }

  .wiki-card:hover .card-arrow {
    opacity: 1;
    color: var(--accent-color);
  }

  @media (max-width: 640px) {
    .card-header {
      flex-direction: column;
      gap: var(--space-2);
    }

    .category-badge {
      align-self: flex-start;
    }

    .card-arrow {
      display: none;
    }

    .wiki-card:hover {
      transform: translateX(2px);
    }
  }
</style>
