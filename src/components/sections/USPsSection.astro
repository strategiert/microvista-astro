---
/**
 * USPsSection — Alleinstellungsmerkmale mit klaren Icons
 */

interface Props {
  content: {
    uspTitle: string;
    usps: { icon: string; title: string; desc: string }[];
  };
}

const { content: t } = Astro.props;

const uspIcons: Record<string, any> = {
  '⚡': 'lightning',
  '📏': 'ruler',
  '🏆': 'award',
  '🤖': 'robot',
};

const uspData = t.usps.map(u => ({
  ...u,
  iconName: uspIcons[u.icon] || 'default'
}));
---

<section class="usp-section">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Ihre Vorteile</span>
      <h2 class="section-title">{t.uspTitle}</h2>
    </div>
    
    <div class="usp-grid">
      {uspData.map((usp, i) => (
        <div class="usp-card">
          <div class="usp-card-inner">
            <div class={`usp-icon-wrap icon-${usp.iconName}`}>
              {usp.iconName === 'lightning' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              )}
              {usp.iconName === 'ruler' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 6H3a2 2 0 00-2 2v8a2 2 0 002 2h18a2 2 0 002-2V8a2 2 0 00-2-2z"/>
                  <line x1="6" y1="10" x2="6" y2="14"/>
                  <line x1="10" y1="10" x2="10" y2="14"/>
                  <line x1="14" y1="10" x2="14" y2="14"/>
                  <line x1="18" y1="10" x2="18" y2="14"/>
                </svg>
              )}
              {usp.iconName === 'award' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="8" r="7"/>
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                </svg>
              )}
              {usp.iconName === 'robot' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="10" rx="2"/>
                  <circle cx="12" cy="5" r="2"/>
                  <path d="M12 7v4"/>
                  <line x1="8" y1="16" x2="8" y2="16"/>
                  <line x1="16" y1="16" x2="16" y2="16"/>
                </svg>
              )}
            </div>
            <div class="usp-number">0{i + 1}</div>
            <h3>{usp.title}</h3>
            <p>{usp.desc}</p>
          </div>
        </div>
      ))}
    </div>
    
    <div class="usp-trust">
      <div class="trust-items">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>ISO 9001 zertifiziert</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>ISO 17025 akkreditiert</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>DAkkS anerkannt</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.usp-section {
  background: linear-gradient(135deg, var(--mv-violet) 0%, #1a1640 50%, #0f0c29 100%);
  padding: var(--space-24) 0;
  position: relative;
  overflow: hidden;
}

.usp-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(142, 191, 214, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(238, 119, 17, 0.06) 0%, transparent 50%);
  pointer-events: none;
}

.container {
  position: relative;
  z-index: 1;
}

.section-header {
  text-align: center;
  margin-bottom: var(--space-12);
}

.section-eyebrow {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--mv-blue);
  margin-bottom: var(--space-3);
}

.section-title {
  font-family: var(--font-heading);
  font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
  font-weight: 700;
  color: var(--mv-white);
}

/* USP Grid */
.usp-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-5);
  margin-bottom: var(--space-12);
}

@media (min-width: 640px) {
  .usp-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .usp-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.usp-card {
  position: relative;
}

.usp-card-inner {
  padding: var(--space-6);
  border-radius: var(--radius-xl);
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  transition: all var(--transition-base);
  height: 100%;
}

.usp-card:hover .usp-card-inner {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.15);
  transform: translateY(-4px);
}

.usp-icon-wrap {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-4);
}

.icon-lightning {
  background: linear-gradient(135deg, rgba(238, 119, 17, 0.2) 0%, rgba(238, 119, 17, 0.05) 100%);
  color: var(--mv-orange);
}

.icon-ruler {
  background: linear-gradient(135deg, rgba(0, 160, 210, 0.2) 0%, rgba(0, 160, 210, 0.05) 100%);
  color: var(--mv-cyan);
}

.icon-award {
  background: linear-gradient(135deg, rgba(142, 191, 214, 0.2) 0%, rgba(142, 191, 214, 0.05) 100%);
  color: var(--mv-blue);
}

.icon-robot {
  background: linear-gradient(135deg, rgba(50, 40, 91, 0.4) 0%, rgba(50, 40, 91, 0.1) 100%);
  color: #a89bd1;
}

.usp-number {
  font-family: var(--font-heading);
  font-size: var(--text-xs);
  font-weight: 700;
  color: rgba(255, 255, 255, 0.2);
  margin-bottom: var(--space-3);
}

.usp-card h3 {
  font-family: var(--font-heading);
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--mv-white);
  margin-bottom: var(--space-2);
}

.usp-card p {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.6;
}

/* Trust Section */
.usp-trust {
  padding-top: var(--space-10);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.trust-items {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
}

.trust-item {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.7);
}

.trust-item svg {
  color: var(--mv-blue);
}

.trust-divider {
  width: 4px;
  height: 4px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

@media (max-width: 640px) {
  .trust-divider {
    display: none;
  }
  
  .trust-items {
    flex-direction: column;
    gap: var(--space-3);
  }
}
</style>
