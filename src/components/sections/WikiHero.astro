---
/**
 * WikiHero - Hero-Bereich für Wiki Index
 * Sauberes, fokussiertes Design mit prominenter Suche
 */
import { localePath, type Locale } from '../../i18n/translations';

interface Props {
  title: string;
  subtitle: string;
  searchPlaceholder: string;
  locale: Locale;
  stats?: { label: string; value: string }[];
}

const { title, subtitle, searchPlaceholder, locale, stats = [] } = Astro.props;
const lp = (path: string) => localePath(path, locale);
---

<section class="wiki-hero">
  <div class="wiki-hero-bg">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="grid-pattern"></div>
  </div>
  
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
        Wissenssammlung
      </div>
      
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      
      <!-- Search Box -->
      <div class="search-container">
        <div class="search-box">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          <input 
            type="search" 
            id="wiki-search"
            placeholder={searchPlaceholder}
            aria-label={searchPlaceholder}
          />
          <kbd class="search-shortcut">⌘K</kbd>
        </div>
      </div>
      
      <!-- Stats -->
      {stats.length > 0 && (
        <div class="hero-stats">
          {stats.map(stat => (
            <div class="stat-item">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .wiki-hero {
    position: relative;
    padding: calc(var(--space-20) + 60px) 0 var(--space-16);
    background: linear-gradient(180deg, #f8f7ff 0%, var(--mv-white) 100%);
    overflow: hidden;
  }

  .wiki-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: rgba(142, 191, 214, 0.3);
    top: -100px;
    right: -100px;
  }

  .orb-2 {
    width: 300px;
    height: 300px;
    background: rgba(50, 40, 91, 0.1);
    bottom: 0;
    left: -100px;
  }

  .grid-pattern {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(50, 40, 91, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(50, 40, 91, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .container {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .hero-content {
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: rgba(50, 40, 91, 0.06);
    border: 1px solid rgba(50, 40, 91, 0.1);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--mv-violet);
    margin-bottom: var(--space-6);
  }

  .hero-badge svg {
    color: var(--mv-blue);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    font-weight: 700;
    color: var(--mv-violet);
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    color: var(--mv-gray-600);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Search Box */
  .search-container {
    max-width: 560px;
    margin: 0 auto var(--space-10);
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--mv-white);
    border: 2px solid var(--mv-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--space-1);
    transition: all var(--transition-base);
    box-shadow: var(--shadow-md);
  }

  .search-box:focus-within {
    border-color: var(--mv-violet);
    box-shadow: 0 0 0 4px rgba(50, 40, 91, 0.1), var(--shadow-lg);
  }

  .search-icon {
    position: absolute;
    left: var(--space-4);
    color: var(--mv-gray-400);
    pointer-events: none;
  }

  .search-box input {
    flex: 1;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-12);
    border: none;
    background: transparent;
    font-size: var(--text-lg);
    color: var(--mv-gray-900);
    outline: none;
  }

  .search-box input::placeholder {
    color: var(--mv-gray-400);
  }

  .search-shortcut {
    display: none;
    padding: var(--space-1) var(--space-2);
    background: var(--mv-gray-100);
    border: 1px solid var(--mv-gray-200);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--mv-gray-500);
    margin-right: var(--space-2);
  }

  @media (min-width: 640px) {
    .search-shortcut {
      display: block;
    }
  }

  /* Stats */
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--mv-violet);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--mv-gray-500);
  }

  @media (max-width: 640px) {
    .hero-stats {
      gap: var(--space-6);
    }
    
    .stat-value {
      font-size: var(--text-xl);
    }
  }
</style>

<script>
  // Keyboard shortcut for search
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      const searchInput = document.getElementById('wiki-search');
      searchInput?.focus();
    }
  });
</script>
