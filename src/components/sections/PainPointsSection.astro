---
/**
 * PainPointsSection — Problemfelder mit professionellen Kacheln
 */
import { localePath, type Locale } from '../../i18n/translations';

interface Props {
  locale: Locale;
  content: {
    painTitle: string;
    painTitleAccent: string;
    painItems: { icon: string; label: string }[];
    painCta: string;
    painCtaBtn: string;
  };
}

const { locale, content: t } = Astro.props;
const lp = (path: string) => localePath(path, locale);

const painCards = [
  { 
    icon: 'pause', 
    label: t.painItems[0]?.label || 'Stockende Entwicklung',
    desc: 'Verzögerungen im Time-to-Market durch unklare Qualitätsfragen'
  },
  { 
    icon: 'alert', 
    label: t.painItems[1]?.label || 'Kein beherrschter Prozess',
    desc: 'Prozessfähigkeit trotz dokumentierter Arbeitsanweisungen nicht gegeben'
  },
  { 
    icon: 'package', 
    label: t.painItems[2]?.label || 'Hohe Ausschussrate',
    desc: 'Teure Ausschusskosten in der laufenden Produktion'
  },
  { 
    icon: 'lock', 
    label: t.painItems[3]?.label || 'Gesperrte Chargen',
    desc: 'Lagerkosten und Lieferverzögerungen durch Qualitätsmängel'
  },
];
---

<section class="pain-section">
  <div class="container">
    <div class="pain-grid">
      <div class="pain-left">
        <span class="section-eyebrow">Ihre Herausforderungen</span>
        <h2 class="pain-title">
          {t.painTitle}
          <span class="pain-accent">{t.painTitleAccent}</span>
        </h2>
        
        <div class="pain-cards">
          {painCards.map((card, i) => (
            <div class="pain-card">
              <div class={`pain-card-icon icon-${card.icon}`}>
                {card.icon === 'pause' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="6" y="4" width="4" height="16" rx="1"/>
                    <rect x="14" y="4" width="4" height="16" rx="1"/>
                  </svg>
                )}
                {card.icon === 'alert' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                  </svg>
                )}
                {card.icon === 'package' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                  </svg>
                )}
                {card.icon === 'lock' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0110 0v4"/>
                  </svg>
                )}
              </div>
              <div class="pain-card-content">
                <h4>{card.label}</h4>
                <p>{card.desc}</p>
              </div>
              <div class="pain-card-number">0{i + 1}</div>
            </div>
          ))}
        </div>
      </div>
      
      <div class="pain-right">
        <div class="pain-cta-card">
          <div class="cta-accent-line"></div>
          <svg class="cta-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2a10 10 0 1010 10A10 10 0 0012 2zm0 16v-4m0-4v.01"/>
          </svg>
          <p class="pain-cta-text">{t.painCta}</p>
          <a href={lp('/kontakt')} class="btn btn-primary">
            {t.painCtaBtn}
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        
        <div class="pain-image-wrap">
          <img
            src="/images/ct/Bauteil-im-CT-platziert-scaled.jpg"
            alt="Bauteil im CT platziert"
            loading="lazy"
          />
          <div class="image-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/>
              <circle cx="12" cy="13" r="4"/>
            </svg>
            CT-Prüfung in Aktion
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.pain-section {
  padding: var(--space-24) 0;
  background: var(--mv-white);
}

.pain-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-12);
  align-items: start;
}

@media (min-width: 1024px) {
  .pain-grid {
    grid-template-columns: 1.2fr 1fr;
  }
}

/* Left Column */
.pain-left {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.section-eyebrow {
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--mv-blue);
}

.pain-title {
  font-family: var(--font-heading);
  font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
  font-weight: 700;
  color: var(--mv-violet);
  line-height: 1.2;
  margin-bottom: var(--space-6);
}

.pain-accent {
  color: var(--mv-orange);
}

/* Pain Cards Grid */
.pain-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
}

@media (min-width: 640px) {
  .pain-cards {
    grid-template-columns: 1fr 1fr;
  }
}

.pain-card {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  padding: var(--space-5);
  background: var(--mv-gray-50);
  border: 1px solid var(--mv-gray-100);
  border-radius: var(--radius-xl);
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}

.pain-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: var(--mv-violet);
  opacity: 0;
  transition: opacity var(--transition-base);
}

.pain-card:hover {
  background: var(--mv-white);
  border-color: var(--mv-gray-200);
  box-shadow: var(--shadow-md);
  transform: translateX(4px);
}

.pain-card:hover::before {
  opacity: 1;
}

.pain-card-icon {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  color: var(--mv-violet);
}

.icon-pause { background: rgba(50, 40, 91, 0.08); }
.icon-alert { background: rgba(238, 119, 17, 0.1); color: var(--mv-orange); }
.icon-package { background: rgba(0, 160, 210, 0.08); color: var(--mv-cyan); }
.icon-lock { background: rgba(142, 191, 214, 0.15); color: var(--mv-blue); }

.pain-card-content {
  flex: 1;
}

.pain-card-content h4 {
  font-family: var(--font-heading);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--mv-gray-900);
  margin-bottom: var(--space-1);
}

.pain-card-content p {
  font-size: var(--text-sm);
  color: var(--mv-gray-500);
  line-height: 1.5;
}

.pain-card-number {
  font-family: var(--font-heading);
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--mv-gray-300);
}

/* Right Column */
.pain-right {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
  position: sticky;
  top: var(--space-8);
}

.pain-cta-card {
  position: relative;
  background: linear-gradient(135deg, var(--mv-violet) 0%, #1a1640 100%);
  color: var(--mv-white);
  padding: var(--space-8);
  border-radius: var(--radius-2xl);
  overflow: hidden;
}

.cta-accent-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--mv-orange) 0%, var(--mv-blue) 100%);
}

.cta-icon {
  margin-bottom: var(--space-5);
  color: var(--mv-blue);
  background: rgba(142, 191, 214, 0.1);
  padding: var(--space-3);
  border-radius: var(--radius-lg);
}

.pain-cta-text {
  font-size: var(--text-lg);
  line-height: 1.6;
  margin-bottom: var(--space-6);
  color: rgba(255, 255, 255, 0.9);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-5);
  border-radius: var(--radius-md);
  font-family: var(--font-heading);
  font-size: var(--text-base);
  font-weight: 600;
  text-decoration: none;
  transition: all var(--transition-base);
  cursor: pointer;
}

.btn-primary {
  background: var(--mv-orange);
  color: var(--mv-white);
  border: 2px solid var(--mv-orange);
}

.btn-primary:hover {
  background: var(--mv-orange-hover);
  border-color: var(--mv-orange-hover);
  transform: translateY(-1px);
}

/* Image */
.pain-image-wrap {
  position: relative;
  border-radius: var(--radius-2xl);
  overflow: hidden;
}

.pain-image-wrap img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
}

.image-badge {
  position: absolute;
  bottom: var(--space-4);
  left: var(--space-4);
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8px);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--mv-violet);
  box-shadow: var(--shadow-md);
}
</style>
