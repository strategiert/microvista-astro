<script>
  // Panel-Toggle
  const triggers = document.querySelectorAll<HTMLButtonElement>('.nav-trigger, #command-trigger');
  const panels = document.querySelectorAll<HTMLDivElement>('.mega-panel');
  const closeAll = () => {
    panels.forEach(p => { p.classList.remove('open'); p.setAttribute('aria-hidden', 'true'); });
    document.querySelectorAll<HTMLButtonElement>('.nav-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));
  };

  triggers.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const key = btn.getAttribute('data-panel');
      if (!key) return;
      const target = document.getElementById(`panel-${key}`);
      const isOpen = target?.classList.contains('open');
      closeAll();
      if (target && !isOpen) {
        target.classList.add('open');
        target.setAttribute('aria-hidden', 'false');
        document.querySelectorAll<HTMLButtonElement>(`.nav-trigger[data-panel="${key}"]`).forEach(b => b.setAttribute('aria-expanded', 'true'));
      }
    });
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.header-shell')) closeAll();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });

  // ─── Search Modal ───────────────────────────
  type SearchEntry = { url: string; title: string; desc: string; kind: string; tags?: string[] };
  let searchIndex: SearchEntry[] | null = null;
  let activeIdx = -1;

  const searchModal = document.getElementById('search-modal');
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchResults = document.getElementById('search-results');
  const commandBtn = document.getElementById('command-trigger');

  // Locale-aware basePath für lp() im JS
  const localeMatch = window.location.pathname.match(/^\/(en|fr|es|it)(\/|$)/);
  const langPrefix = localeMatch ? '/' + localeMatch[1] : '';

  async function loadIndex() {
    if (searchIndex) return searchIndex;
    try {
      const res = await fetch('/search-index.json');
      const data = await res.json();
      searchIndex = data.entries || [];
      return searchIndex;
    } catch (e) {
      console.warn('Search index load failed:', e);
      searchIndex = [];
      return searchIndex;
    }
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function score(entry: SearchEntry, q: string): number {
    const text = (entry.title + ' ' + entry.desc + ' ' + (entry.tags || []).join(' ')).toLowerCase();
    const needle = q.toLowerCase();
    if (!text.includes(needle)) return 0;
    let s = 0;
    if (entry.title.toLowerCase().includes(needle)) s += 10;
    if (entry.title.toLowerCase().startsWith(needle)) s += 20;
    if ((entry.tags || []).some(t => t.toLowerCase().includes(needle))) s += 5;
    if (entry.desc.toLowerCase().includes(needle)) s += 2;
    if (entry.kind === 'service') s += 3;
    if (entry.kind === 'branche') s += 2;
    return s;
  }

  function renderHits(q: string) {
    if (!searchResults || !searchIndex) return;
    if (!q.trim()) {
      searchResults.innerHTML = '<div class="search-hint">Tippen Sie ein Stichwort.</div>';
      activeIdx = -1;
      return;
    }
    const hits = searchIndex
      .map((e) => ({ e, s: score(e, q) }))
      .filter(({ s }) => s > 0)
      .sort((a, b) => b.s - a.s)
      .slice(0, 12);

    if (hits.length === 0) {
      searchResults.innerHTML = '<div class="search-empty">Kein Treffer. Versuchen Sie einen anderen Begriff.</div>';
      activeIdx = -1;
      return;
    }

    searchResults.innerHTML = hits.map(({ e }, i) => `
      <a class="search-hit${i === 0 ? ' active' : ''}" href="${langPrefix}${e.url}" data-idx="${i}">
        <div class="search-hit-row">
          <span class="search-hit-kind" data-kind="${e.kind}">${e.kind}</span>
          <span class="search-hit-title">${escapeHtml(e.title)}</span>
        </div>
        ${e.desc ? `<div class="search-hit-desc">${escapeHtml(e.desc)}</div>` : ''}
      </a>
    `).join('');
    activeIdx = 0;
  }

  async function openSearch() {
    if (!searchModal) return;
    closeAll();
    searchModal.classList.add('open');
    searchModal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    await loadIndex();
    setTimeout(() => searchInput?.focus(), 50);
  }

  function closeSearch() {
    if (!searchModal) return;
    searchModal.classList.remove('open');
    searchModal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (searchInput) searchInput.value = '';
    if (searchResults) searchResults.innerHTML = '<div class="search-hint">Tippen Sie ein Stichwort.</div>';
  }

  commandBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    openSearch();
  });

  searchInput?.addEventListener('input', (e) => {
    renderHits((e.target as HTMLInputElement).value);
  });

  searchInput?.addEventListener('keydown', (e) => {
    if (!searchResults) return;
    const hits = searchResults.querySelectorAll<HTMLAnchorElement>('.search-hit');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (hits.length === 0) return;
      hits[activeIdx]?.classList.remove('active');
      activeIdx = (activeIdx + 1) % hits.length;
      hits[activeIdx]?.classList.add('active');
      hits[activeIdx]?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (hits.length === 0) return;
      hits[activeIdx]?.classList.remove('active');
      activeIdx = (activeIdx - 1 + hits.length) % hits.length;
      hits[activeIdx]?.classList.add('active');
      hits[activeIdx]?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter') {
      const target = hits[activeIdx];
      if (target) {
        e.preventDefault();
        window.location.href = target.href;
      }
    }
  });

  document.querySelectorAll('[data-search-close]').forEach((el) => {
    el.addEventListener('click', closeSearch);
  });

  // Ctrl+K → Search Modal
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape' && searchModal?.classList.contains('open')) {
      closeSearch();
    }
  });

  // Mobile Drawer
  const mobileToggle = document.querySelector<HTMLButtonElement>('.mobile-menu-toggle');
  const drawer = document.getElementById('mobile-drawer');
  mobileToggle?.addEventListener('click', () => {
    const open = drawer?.classList.toggle('open');
    mobileToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    drawer?.setAttribute('aria-hidden', open ? 'false' : 'true');
    document.body.style.overflow = open ? 'hidden' : '';
  });

  // Language Dropdown
  const langBtn = document.querySelector<HTMLButtonElement>('.lang-current');
  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const expanded = langBtn.getAttribute('aria-expanded') === 'true';
    langBtn.setAttribute('aria-expanded', (!expanded).toString());
  });
</script>
