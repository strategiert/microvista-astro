---
/**
 * Globaler Header — Signal Hub Navigation (Konzept G)
 * Search-First Header + Problem-orientiertes Mega-Panel
 * 5 Sprachen DE/EN/FR/ES/IT, Mobile responsive, World-Bar Sub-Nav
 */
import {
  translations,
  localeNames,
  type Locale,
  localePath,
  enabledLocales,
  languageSwitchPath
} from '../../i18n/translations';

interface Props {
  theme?: 'light' | 'dark' | 'transparent';
  world?: 'labor' | 'serie';
}

const { theme = 'light', world } = Astro.props;
const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);
const nav = translations.nav;

// ──────────────── Trigger-Labels ────────────────
const triggers = {
  leistungen: { de: 'Leistungen', en: 'Services', fr: 'Services', es: 'Servicios', it: 'Servizi' },
  branchen:   { de: 'Branchen',   en: 'Industries', fr: 'Secteurs', es: 'Sectores', it: 'Settori' },
  wissen:     { de: 'Wissen',     en: 'Knowledge', fr: 'Savoir', es: 'Conocimiento', it: 'Conoscenza' },
};

// ──────────────── Command-Trigger ────────────────
const cmdLabel = {
  de: 'Problem, Verfahren oder Branche suchen',
  en: 'Search problem, method or industry',
  fr: 'Rechercher problème, procédé ou secteur',
  es: 'Buscar problema, proceso o sector',
  it: 'Cerca problema, processo o settore',
};
const cmdSub = {
  de: 'Schnell finden — von Hairpin bis Porosität.',
  en: 'Find fast — from hairpin to porosity.',
  fr: 'Trouvez vite — du hairpin à la porosité.',
  es: 'Encuentre rápido — de hairpin a porosidad.',
  it: 'Trova rapido — da hairpin a porosità.',
};

// ──────────────── Panel: Leistungen ────────────────
const leistungenPanel = {
  kicker: { de: 'Problem-first', en: 'Problem-first', fr: 'Problem-first', es: 'Problem-first', it: 'Problem-first' },
  headline: {
    de: 'Start bei Ihrer Prüfaufgabe — nicht bei der Menüstruktur.',
    en: 'Start with your inspection task — not the menu structure.',
    fr: 'Commencez par votre tâche d\'inspection — pas la structure du menu.',
    es: 'Empiece por su tarea de inspección — no por la estructura del menú.',
    it: 'Inizia dal tuo compito di ispezione — non dalla struttura del menu.',
  },
  tiles: [
    {
      id: 'Signal 01',
      tone: 'labor',
      badge: { de: 'Labor', en: 'Lab', fr: 'Labo', es: 'Lab', it: 'Lab' },
      title: { de: 'Neues Bauteil freigeben?', en: 'Release a new part?', fr: 'Valider une nouvelle pièce ?', es: '¿Validar una pieza nueva?', it: 'Rilasciare un nuovo pezzo?' },
      desc: {
        de: 'Vom ersten Scan bis zum Erstmusterprüfbericht.',
        en: 'From first scan to first article inspection report.',
        fr: 'Du premier scan au rapport de premier article.',
        es: 'Del primer escaneo al informe de primera muestra.',
        it: 'Dal primo scan al rapporto primo campione.',
      },
      tags: ['EMPB', 'CAD Soll-Ist', 'Reverse Engineering'],
      href: '/labor/erstmusterpruefung',
    },
    {
      id: 'Signal 02',
      tone: 'serie',
      badge: { de: 'Serie', en: 'Series', fr: 'Série', es: 'Serie', it: 'Serie' },
      title: { de: 'Serienqualität absichern?', en: 'Secure series quality?', fr: 'Sécuriser la qualité série ?', es: '¿Asegurar la calidad en serie?', it: 'Garantire la qualità in serie?' },
      desc: {
        de: 'Inline-CT, 100%-Prüfung, KI-Auswertung — Stückzahlen sicher prüfen.',
        en: 'Inline CT, 100% inspection, AI analysis — inspect high volumes.',
        fr: 'CT en ligne, contrôle 100%, analyse IA — pour gros volumes.',
        es: 'CT en línea, inspección 100%, análisis IA — para grandes volúmenes.',
        it: 'CT in linea, ispezione 100%, analisi AI — per grandi volumi.',
      },
      tags: ['Inline-CT', '100% Prüfung', 'KI'],
      href: '/serie/inline-ct',
    },
    {
      id: 'Signal 03',
      tone: 'express',
      badge: { de: 'Express', en: 'Express', fr: 'Express', es: 'Express', it: 'Express' },
      title: { de: 'Reklamation oder Chargensperre?', en: 'Complaint or batch lock?', fr: 'Réclamation ou lot bloqué ?', es: '¿Reclamación o lote bloqueado?', it: 'Reclamo o lotto bloccato?' },
      desc: {
        de: 'Ursachenanalyse, Tempo, klarer Kontaktpfad.',
        en: 'Root cause analysis, fast turnaround, clear contact path.',
        fr: 'Analyse des causes, rapidité, contact direct.',
        es: 'Análisis de causa, rapidez, contacto directo.',
        it: 'Analisi delle cause, rapidità, contatto diretto.',
      },
      tags: ['Schadensanalyse', 'Defektanalyse', 'Express CT'],
      href: '/labor/schadensanalyse',
    },
    {
      id: 'Signal 04',
      tone: 'wissen',
      badge: { de: 'Software', en: 'Software', fr: 'Logiciel', es: 'Software', it: 'Software' },
      title: { de: 'Auswertung automatisieren?', en: 'Automate evaluation?', fr: 'Automatiser l\'analyse ?', es: '¿Automatizar la evaluación?', it: 'Automatizzare l\'analisi?' },
      desc: {
        de: 'InspectVista — 5× schneller, 10× höhere Auflösung, Cloud oder On-Prem.',
        en: 'InspectVista — 5× faster, 10× higher resolution, cloud or on-prem.',
        fr: 'InspectVista — 5× plus rapide, 10× plus résolu, cloud ou on-prem.',
        es: 'InspectVista — 5× más rápido, 10× más resolución, cloud u on-prem.',
        it: 'InspectVista — 5× più veloce, 10× più risoluzione, cloud o on-prem.',
      },
      tags: ['InspectVista', 'Cloud', 'KI-Auswertung'],
      href: '/software',
    },
  ],
  sideTitle: { de: 'Direkt einsteigen', en: 'Direct entry', fr: 'Entrée directe', es: 'Entrada directa', it: 'Entrata diretta' },
  sideLinks: [
    { label: { de: 'Labor & Erstmuster', en: 'Lab & First Article', fr: 'Labo & Premier article', es: 'Lab & Primera muestra', it: 'Lab & Primo campione' }, href: '/labor' },
    { label: { de: 'Serienprüfung',     en: 'Series Inspection', fr: 'Inspection série', es: 'Inspección en serie', it: 'Ispezione in serie' }, href: '/serie' },
    { label: { de: 'InspectVista Software', en: 'InspectVista Software', fr: 'Logiciel InspectVista', es: 'Software InspectVista', it: 'Software InspectVista' }, href: '/software' },
    { label: { de: 'Express-Inspektion', en: 'Express Inspection', fr: 'Inspection express', es: 'Inspección exprés', it: 'Ispezione express' }, href: '/express-ct-inspektion' },
  ],
};

// ──────────────── Panel: Branchen ────────────────
const branchenPanel = {
  kicker: { de: 'Industry layer', en: 'Industry layer', fr: 'Industry layer', es: 'Industry layer', it: 'Industry layer' },
  headline: {
    de: 'Branchen sichtbar — verbunden mit Problemen und Wissen.',
    en: 'Industries visible — connected with problems and knowledge.',
    fr: 'Secteurs visibles — connectés aux problèmes et au savoir.',
    es: 'Sectores visibles — conectados con problemas y conocimiento.',
    it: 'Settori visibili — collegati a problemi e conoscenza.',
  },
  tiles: [
    { id: 'A', tone: 'serie', badge: { de: 'Serie', en: 'Series', fr: 'Série', es: 'Serie', it: 'Serie' }, title: { de: 'Automotive', en: 'Automotive', fr: 'Automobile', es: 'Automoción', it: 'Automotive' }, desc: { de: 'Hairpin-Statoren, Leichtmetallguss, Serienqualität.', en: 'Hairpin stators, light-metal casting, series quality.', fr: 'Hairpins, fonderie aluminium, qualité série.', es: 'Hairpin, fundición ligera, calidad serie.', it: 'Hairpin, fonderia leggera, qualità serie.' }, tags: ['Hairpin', 'Leichtmetallguss'], href: '/branchen/automotive' },
    { id: 'B', tone: 'serie', badge: { de: 'Serie', en: 'Series', fr: 'Série', es: 'Serie', it: 'Serie' }, title: { de: 'E-Mobilität', en: 'E-Mobility', fr: 'E-mobilité', es: 'E-movilidad', it: 'E-mobility' }, desc: { de: 'Batteriemodule, Schweißungen, E-Motor-Komponenten.', en: 'Battery modules, welds, e-motor components.', fr: 'Modules batterie, soudures, composants moteur.', es: 'Módulos batería, soldaduras, componentes motor.', it: 'Moduli batteria, saldature, componenti motore.' }, tags: ['Batterie', 'Schweißung'], href: '/branchen/e-mobilitaet' },
    { id: 'C', tone: 'labor', badge: { de: 'Labor', en: 'Lab', fr: 'Labo', es: 'Lab', it: 'Lab' }, title: { de: 'Medizintechnik', en: 'Medical Devices', fr: 'Dispositifs médicaux', es: 'Dispositivos médicos', it: 'Dispositivi medici' }, desc: { de: 'Implantate, Pharma-Verpackung, Dokumentation.', en: 'Implants, pharma packaging, documentation.', fr: 'Implants, emballage pharma, documentation.', es: 'Implantes, embalaje farma, documentación.', it: 'Impianti, packaging farma, documentazione.' }, tags: ['MDR', 'ISO 13485'], href: '/branchen/medizintechnik' },
    { id: 'D', tone: 'wissen', badge: { de: 'Hybrid', en: 'Hybrid', fr: 'Hybride', es: 'Híbrido', it: 'Ibrido' }, title: { de: 'Additive Fertigung', en: 'Additive Manufacturing', fr: 'Fabrication additive', es: 'Fabricación aditiva', it: 'Manifattura additiva' }, desc: { de: 'Porosität, Innenstruktur, Parameter-Optimierung.', en: 'Porosity, internal structure, parameter optimization.', fr: 'Porosité, structure interne, optimisation des paramètres.', es: 'Porosidad, estructura interna, optimización.', it: 'Porosità, struttura interna, ottimizzazione.' }, tags: ['Porosität', '3D-Druck'], href: '/branchen/additive-fertigung' },
  ],
  sideTitle: { de: 'Mehr Branchen', en: 'More Industries', fr: 'Plus de secteurs', es: 'Más sectores', it: 'Altri settori' },
  sideLinks: [
    { label: { de: 'Alle 14 Branchen', en: 'All 14 industries', fr: 'Tous les 14 secteurs', es: 'Los 14 sectores', it: 'Tutti i 14 settori' }, href: '/branchen' },
    { label: { de: 'Luftfahrt', en: 'Aerospace', fr: 'Aéronautique', es: 'Aeroespacial', it: 'Aerospazio' }, href: '/branchen/luftfahrt' },
    { label: { de: 'Werkstoffprüfung', en: 'NDT/Materials', fr: 'CND/Matériaux', es: 'END/Materiales', it: 'CND/Materiali' }, href: '/branchen/werkstoffpruefung' },
    { label: { de: 'Forschung & Entwicklung', en: 'R&D', fr: 'R&D', es: 'I+D', it: 'R&S' }, href: '/branchen/forschung-entwicklung' },
  ],
};

// ──────────────── Panel: Wissen ────────────────
const wissenPanel = {
  kicker: { de: 'Knowledge layer', en: 'Knowledge layer', fr: 'Knowledge layer', es: 'Knowledge layer', it: 'Knowledge layer' },
  headline: {
    de: 'Wissen ist Teil der Navigation, nicht Anhang.',
    en: 'Knowledge is part of navigation, not an appendix.',
    fr: 'Le savoir fait partie de la navigation, pas un appendice.',
    es: 'El conocimiento forma parte de la navegación.',
    it: 'La conoscenza fa parte della navigazione.',
  },
  tiles: [
    {
      id: 'Wiki',
      tone: 'wissen',
      badge: { de: 'Wiki', en: 'Wiki', fr: 'Wiki', es: 'Wiki', it: 'Wiki' },
      title: { de: 'CT-Wiki', en: 'CT Wiki', fr: 'Wiki CT', es: 'Wiki CT', it: 'Wiki CT' },
      desc: {
        de: 'Begriffe schnell erklärt — Porosität, APQP, CAD Soll-Ist und mehr.',
        en: 'Terms explained fast — porosity, APQP, CAD comparison and more.',
        fr: 'Termes expliqués rapidement — porosité, APQP, CAO et plus.',
        es: 'Términos explicados rápido — porosidad, APQP, CAD y más.',
        it: 'Termini spiegati veloce — porosità, APQP, CAD e altro.',
      },
      tags: ['Definitionen', 'A-Z'],
      href: '/wiki',
    },
    {
      id: 'Magazin',
      tone: 'wissen',
      badge: { de: 'Magazin', en: 'Magazine', fr: 'Magazine', es: 'Revista', it: 'Magazine' },
      title: { de: 'Magazin & Case Studies', en: 'Magazine & Case Studies', fr: 'Magazine & études de cas', es: 'Revista & casos prácticos', it: 'Magazine & case study' },
      desc: {
        de: 'Praxisartikel, Marktanalysen, Hairpin-Stator-Scans, Trends 2026.',
        en: 'Practical articles, market analyses, hairpin scans, trends 2026.',
        fr: 'Articles pratiques, analyses, hairpin, tendances 2026.',
        es: 'Artículos prácticos, análisis, hairpin, tendencias 2026.',
        it: 'Articoli pratici, analisi, hairpin, trend 2026.',
      },
      tags: ['Case Study', 'Trends'],
      href: '/magazin',
    },
  ],
  sideTitle: { de: 'Mehr Ressourcen', en: 'More Resources', fr: 'Plus de ressources', es: 'Más recursos', it: 'Altre risorse' },
  sideLinks: [
    { label: { de: 'Forschung & Entwicklung', en: 'R&D', fr: 'R&D', es: 'I+D', it: 'R&S' }, href: '/forschung-entwicklung' },
    { label: { de: 'Zertifizierungen', en: 'Certifications', fr: 'Certifications', es: 'Certificaciones', it: 'Certificazioni' }, href: '/zertifizierungen' },
    { label: { de: 'FAQ', en: 'FAQ', fr: 'FAQ', es: 'FAQ', it: 'FAQ' }, href: '/faq' },
    { label: { de: 'Fragebogen', en: 'Questionnaire', fr: 'Questionnaire', es: 'Cuestionario', it: 'Questionario' }, href: '/fragebogen' },
  ],
};

const allPanels = [
  { key: 'leistungen', data: leistungenPanel },
  { key: 'branchen',   data: branchenPanel },
  { key: 'wissen',     data: wissenPanel },
];

// ──────────────── World Bar (Sub-Nav für /labor und /serie) ────────────────
const worldContext = {
  labor: {
    label: { de: 'Labor & Erstmuster', en: 'Lab & First Article', fr: 'Laboratoire', es: 'Laboratorio', it: 'Laboratorio' },
    links: [
      { de: 'Erstmusterprüfung', en: 'First Article Inspection', fr: 'Premier article', es: 'Primera muestra', it: 'Primo campione', href: '/labor/erstmusterpruefung' },
      { de: 'Schadensanalyse', en: 'Failure Analysis', fr: 'Analyse de défaillance', es: 'Análisis de fallas', it: 'Analisi dei guasti', href: '/labor/schadensanalyse' },
      { de: 'Reverse Engineering', en: 'Reverse Engineering', fr: 'Rétro-ingénierie', es: 'Ingeniería inversa', it: 'Reverse engineering', href: '/labor/reverse-engineering' },
    ],
    switch: { de: 'Zur Serienprüfung →', en: 'To Series Inspection →', fr: 'Vers l\'inspection série →', es: 'A inspección en serie →', it: 'All\'ispezione in serie →' },
    switchHref: '/serie',
  },
  serie: {
    label: { de: 'Serienprüfung', en: 'Series Inspection', fr: 'Inspection en série', es: 'Inspección en serie', it: 'Ispezione in serie' },
    links: [
      { de: 'Inline-CT', en: 'Inline CT', fr: 'CT en ligne', es: 'CT en línea', it: 'CT in linea', href: '/serie/inline-ct' },
      { de: '100% Prüfung', en: '100% Inspection', fr: 'Inspection 100%', es: 'Inspección 100%', it: 'Ispezione 100%', href: '/serie/100-prozent-pruefung' },
      { de: 'KI-Automatisierung', en: 'AI Automation', fr: 'Automatisation IA', es: 'Automatización IA', it: 'Automazione IA', href: '/serie/ki-automatisierung' },
    ],
    switch: { de: 'Zum Labor →', en: 'To the Lab →', fr: 'Vers le laboratoire →', es: 'Al laboratorio →', it: 'Al laboratorio →' },
    switchHref: '/labor',
  },
};
const worldCtx = world ? worldContext[world] : null;

// Aktueller Pfad für Sprachwechsel
const currentPath = Astro.url.pathname;
const getLangUrl = (targetLocale: Locale) => languageSwitchPath(currentPath, targetLocale);
---

<header class:list={['site-header', `theme-${theme}`]}>
  <div class="container">
    <div class="header-shell">
      <div class="header-row">
        <a href={lp('/')} class="brand" aria-label="Microvista">
          <img class="brand-logo brand-logo-light" src="/images/logos/2013-08-microvista_Logo_RGB-7.png" alt="Microvista" width="705" height="399" loading="eager" />
          <img class="brand-logo brand-logo-dark" src="/images/logos/2024_08-MV-Logo_weiss.png" alt="" aria-hidden="true" width="705" height="399" loading="eager" />
        </a>

        <nav class="nav" aria-label="Hauptnavigation">
          {allPanels.map(p => (
            <button class="nav-trigger" type="button" data-panel={p.key} aria-expanded="false">
              {p.data.kicker ? triggers[p.key as keyof typeof triggers][locale] : p.key}
            </button>
          ))}
        </nav>

        <button class="command-trigger" id="command-trigger" type="button">
          <span class="command-icon" aria-hidden="true">/</span>
          <span class="command-copy">
            <strong>{cmdLabel[locale]}</strong>
            <span>{cmdSub[locale]}</span>
          </span>
          <span class="command-kbd" aria-hidden="true">Ctrl K</span>
        </button>

        <div class="header-actions">
          <div class="lang-switch-wrapper">
            <button class="lang-current" aria-expanded="false" aria-haspopup="true">
              {locale.toUpperCase()}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <ul class="lang-dropdown">
              {enabledLocales.map(l => (
                <li>
                  <a href={getLangUrl(l)} class:list={[{ active: l === locale }]}>
                    <span class="lang-code">{l.toUpperCase()}</span>
                    <span class="lang-name">{localeNames[l]}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <a href={lp('/kontakt')} class="cta-pill">{nav.kontakt[locale]}</a>

          <button class="mobile-menu-toggle" type="button" aria-label="Menü öffnen" aria-expanded="false">
            <span class="hamburger"></span>
          </button>
        </div>
      </div>

      {allPanels.map(p => (
        <div class="mega-panel" id={`panel-${p.key}`} role="region" aria-hidden="true">
          <div class="panel-head">
            <div>
              <div class="panel-kicker">{p.data.kicker[locale]}</div>
              <h2>{p.data.headline[locale]}</h2>
            </div>
          </div>

          <div class="panel-grid">
            <div class="problem-grid">
              {p.data.tiles.map((tile: any) => (
                <a class="problem-tile" href={lp(tile.href)}>
                  <div class="problem-top">
                    <span class="problem-id">{tile.id}</span>
                    <span class:list={['problem-badge', `tone-${tile.tone}`]}>{tile.badge[locale]}</span>
                  </div>
                  <h3>{tile.title[locale]}</h3>
                  <p>{tile.desc[locale]}</p>
                  <div class="tag-row">
                    {tile.tags.map((t: string) => <span class="tag">{t}</span>)}
                  </div>
                </a>
              ))}
            </div>

            <div class="panel-side">
              <div class="side-card">
                <h3>{p.data.sideTitle[locale]}</h3>
                <ul class="side-links">
                  {p.data.sideLinks.map((sl: any) => (
                    <li><a href={lp(sl.href)}>{sl.label[locale]}<span aria-hidden="true">→</span></a></li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Search Modal -->
  <div class="search-modal" id="search-modal" aria-hidden="true" role="dialog" aria-label="Suche">
    <div class="search-backdrop" data-search-close></div>
    <div class="search-shell">
      <div class="search-input-row">
        <span class="search-icon" aria-hidden="true">⌕</span>
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder={cmdLabel[locale]}
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="search-esc">ESC</kbd>
      </div>
      <div class="search-results" id="search-results">
        <div class="search-hint">
          {locale === 'de' ? 'Tippen Sie ein Stichwort — z.B. Hairpin, Porosität, Express, Erstmuster.' :
           locale === 'en' ? 'Type a keyword — e.g. hairpin, porosity, express, first article.' :
           locale === 'fr' ? 'Tapez un mot-clé — p.ex. hairpin, porosité, express, premier article.' :
           locale === 'es' ? 'Escriba una palabra clave — p.ej. hairpin, porosidad, express, primera muestra.' :
           'Digita una parola chiave — es. hairpin, porosità, express, primo campione.'}
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
    {allPanels.map(p => (
      <details class="m-panel">
        <summary>{triggers[p.key as keyof typeof triggers][locale]}</summary>
        <div class="m-panel-body">
          {p.data.tiles.map((tile: any) => (
            <a class="m-tile" href={lp(tile.href)}>
              <strong>{tile.title[locale]}</strong>
              <span>{tile.desc[locale]}</span>
            </a>
          ))}
          <div class="m-side">
            {p.data.sideLinks.map((sl: any) => (
              <a href={lp(sl.href)}>{sl.label[locale]}</a>
            ))}
          </div>
        </div>
      </details>
    ))}
    <a href={lp('/kontakt')} class="m-cta">{nav.kontakt[locale]}</a>
  </div>
</header>

{worldCtx && (
  <nav class:list={['world-bar', `world-bar--${world}`]} aria-label="Bereich-Navigation">
    <div class="container">
      <span class="world-bar__label">
        {worldCtx.label[locale as keyof typeof worldCtx.label] || worldCtx.label.en}
      </span>
      <span class="world-bar__sep" aria-hidden="true">›</span>
      <ul class="world-bar__links">
        {worldCtx.links.map(link => (
          <li>
            <a href={lp(link.href)}>
              {link[locale as keyof typeof link] as string || link.en}
            </a>
          </li>
        ))}
      </ul>
      <a href={lp(worldCtx.switchHref)} class="world-bar__switch">
        {worldCtx.switch[locale as keyof typeof worldCtx.switch] || worldCtx.switch.en}
      </a>
    </div>
  </nav>
)}

<style>
  /* ─── Site Header Wrapper ───────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-3) 0;
    background: transparent;
  }

  .site-header.theme-light {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(50, 40, 91, 0.06);
  }

  .site-header.theme-transparent {
    background: transparent;
    border-bottom: none;
  }

  .site-header.theme-dark {
    background: var(--mv-violet);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* ─── Header Shell (Signal Hub) ─────────────── */
  .header-shell {
    position: relative;
    padding: 12px 16px;
    border-radius: 22px;
    border: 1px solid rgba(50, 40, 91, 0.08);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px);
    box-shadow: 0 18px 48px rgba(50, 40, 91, 0.12);
  }

  .theme-transparent .header-shell {
