---
import SerieLayout from '../../layouts/SerieLayout.astro';
import { localePath, type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

const content = {
  de: {
    badge: 'Zerstörungsfreie Serienprüfung',
    tagline: 'GET YOUR INSPECTION DONE – Anywhere. Anytime. Fast.',
    headline: 'Zerstörungsfreie',
    headlineAccent: 'Serienprüfung',
    headlineSub: 'Hohe Stückzahl. Geringe Prüfkosten.',
    subline: 'Falls Sie eine zerstörungsfreie Serienprüfung mit industrieller Computertomographie durchführen wollen, hat Microvista die passende Lösung – wirtschaftlich, zuverlässig, skalierbar.',
    cta1: 'Express-Inspektion buchen',
    cta2: 'Gratis-Beratung sichern',

    stats: [
      { value: '100%', label: 'Prüfabdeckung' },
      { value: '<3s', label: 'pro Bauteil' },
      { value: '99.9%', label: 'Erkennungsrate' },
      { value: '450kV', label: 'Röhrenleistung' },
    ],

    whyTitle: 'Hohe Stückzahl = geringe Prüfkosten pro Bauteil',
    whyText: 'Die zerstörungsfreie Serienprüfung mit industrieller CT ist die wirtschaftlichste Form der Qualitätssicherung für komplexe Bauteile in hohen Stückzahlen. Die Prüfkosten pro Bauteil sinken mit steigender Stückzahl – und Microvista liefert die gesamte Infrastruktur: CT-Labor, mobiles CT oder automatisierte Cloud-Auswertung.',
    whyBenefits: [
      'Erreichung eines fähigen / beherrschten Produktionsprozesses',
      'Reduzierung der Kosten für die Weiterverarbeitung von Bauteilen mit verdeckten Mängeln',
      'Verhinderung der Sperrung Ihrer Charge durch den Microvista Qualitätsnachweis',
    ],

    aufgabenTitle: 'Typische Prüfaufgaben in der Serienprüfung',
    aufgabenSubline: 'Ein einziger CT-Scan liefert alle folgenden Informationen gleichzeitig – kein separates Prüfverfahren nötig.',
    aufgaben: [
      { icon: '◎', title: 'Poren, Lunker & Einschlüsse', text: 'Volumetrische Fehlstellen in Guss- und Sinterbauteilen sicher detektieren' },
      { icon: '✂', title: 'Grat & Kernreste', text: 'Späne und Kernreste in Hohlräumen aufspüren – auch verdeckt' },
      { icon: '⌇', title: 'Rissprüfung', text: 'Haarrisse und Kaltlaufstellen dreidimensional sichtbar machen' },
      { icon: '◉', title: 'Porositätenanalyse', text: 'Verteilung und Volumenanteil von Poren präzise quantifizieren' },
      { icon: '↔', title: 'Wanddickenmessung', text: 'Schichtdicken und Wandstärken hochpräzise über das gesamte Bauteilvolumen' },
      { icon: '⊞', title: 'CAD Soll/Ist-Vergleich', text: 'Maßabweichungen vom CAD-Modell farblich visualisieren' },
      { icon: '⚙', title: 'Montage- & Fügefehler', text: 'Schweißnähte, Presspassungen und Klebeverbindungen berührungslos prüfen' },
      { icon: '⚡', title: 'Hairpin-Statoren', text: 'Lückenlose Qualitätsprüfung von E-Motor-Wicklungen und Statorpaketen' },
    ],

    verfahrenTitle: 'Zerstörungsfreie Prüfmethoden im Vergleich',
    verfahrenSubline: 'Warum industrielle CT die überlegene Methode für komplexe Serienteile ist',
    verfahren: [
      {
        method: 'Röntgendiffraktion (RT)',
        badge: 'Eingeschränkt',
        badgeOk: false,
        cons: ['Nur 2D-Bilder – keine Volumendaten', 'Teure Geräte & lange Untersuchungszeiten', 'Limitierte Defekterkennung bei komplexen Geometrien'],
      },
      {
        method: 'Ultraschallprüfung (UT)',
        badge: 'Eingeschränkt',
        badgeOk: false,
        cons: ['Unzuverlässig bei dünnen oder hohlen Bauteilen', 'Schlechte Kopplung bei rauen Oberflächen', 'Kein vollständiger Volumenscan möglich'],
      },
      {
        method: 'Magnetpulver- & Eindringprüfung (MT/PT)',
        badge: 'Begrenzt',
        badgeOk: false,
        cons: ['Nur Oberflächenfehler detektierbar', 'Eingeschränkt auf bestimmte Materialien', 'Kein Einsatz bei Hohlräumen & inneren Strukturen'],
      },
      {
        method: 'Sichtprüfung (VT)',
        badge: 'Begrenzt',
        badgeOk: false,
        cons: ['Nur äußerlich sichtbare Fehler', 'Stark abhängig vom Prüfer', 'Keine innenliegenden Defekte detektierbar'],
      },
      {
        method: 'Industrielle CT (Microvista)',
        badge: 'Empfohlen',
        badgeOk: true,
        cons: ['3D-Volumenbilder für jeden Scan', 'Risse, Poren, Maße & Fügefehler in EINEM Durchlauf', '100% zerstörungsfrei – Bauteil bleibt unversehrt'],
      },
    ],

    optionenTitle: 'Wie kann eine Serienprüfung realisiert werden?',
    optionenSubline: 'Drei Wege zur wirtschaftlichsten Qualitätssicherung für Ihre Produktion',
    optionen: [
      {
        nr: '01',
        title: 'CT-Labor von Microvista',
        text: 'Bauteile einsenden – die Experten von Microvista scannen & werten aus. Keine Investitionskosten, kein Personalaufwand, keine Schulungen. Die ideale Option für Einzelteile, Chargenfreigaben oder wiederkehrende Serienprüfungen.',
        note: 'Express-Scan < 24h möglich (nach Absprache & abhängig von Teileanzahl)',
        img: '/images/ct/Bauteil-im-CT-platziert-scaled.jpg',
        imgAlt: 'Bauteil wird im Microvista CT-Labor platziert',
        href: '/labor',
        btnLabel: 'CT-Labor entdecken',
      },
      {
        nr: '02',
        title: 'Mobiles CT mieten – ScanExpress',
        text: 'Prüfung direkt vor Ort in Ihrer Produktion – ohne Versand der Bauteile. Das mobile CT ScanExpress verschafft Ihnen volle Flexibilität und spart hohe Investmentkosten & Wartezeiten.',
        note: 'Ideal für temporären Bedarf oder Serienfertigung vor Ort',
        img: '/images/ct/ScanExpress-Compact-Frontaufnahme-scaled.png',
        imgAlt: 'ScanExpress – das mobile industrielle CT von Microvista',
        href: '/live-demo-scanexpress',
        btnLabel: 'ScanExpress kennenlernen',
      },
      {
        nr: '03',
        title: 'Microvista Cloud',
        text: 'Sie besitzen bereits ein eigenes CT? Laden Sie Ihre CT-Scan-Daten in die Microvista Cloud und lassen Sie diese automatisch auswerten. Spart erheblichen Zeitaufwand – manuelle Auswertung entfällt vollständig.',
        note: 'Für Betriebe mit eigenem CT-System und hohem Prüfvolumen',
        img: '/images/ct/Beispiel-Bedienoberflaeche-der-CT-Software-am-Laptop.png',
        imgAlt: 'Microvista Cloud Software zur automatisierten CT-Auswertung',
        href: '/kontakt',
        btnLabel: 'Cloud-Lösung anfragen',
      },
    ],

    specsTitle: 'Unsere Messkapazitäten',
    specsNote: 'Microvista setzt auf eine 450kV Röhre mit besonders hoher Photonenenergie – zerstörungsfreie Prüfung von dickwandigem Eisenguss bis ca. 70 mm Wandstärke möglich.',
    specs: [
      { value: '798 mm', label: 'Max. Bauteil-Ø' },
      { value: '1.802 mm', label: 'Max. Bauteil-Länge' },
      { value: '200 kg', label: 'Max. Gewicht' },
      { value: '0,02–1 mm', label: 'Auflösung' },
      { value: '450 kV', label: 'Röhrenleistung' },
      { value: '< 24h', label: 'Express-Option' },
      { value: '10 AT', label: 'Standard-Lieferzeit' },
    ],

    servicesTitle: 'Unsere Lösungen für die Serienprüfung',
    servicesSubline: 'Maßgeschneiderte Prüfsysteme für jede Produktionsanforderung',
    services: [
      {
        title: 'Inline-CT',
        description: 'CT-Prüfung direkt in Ihrer Produktionslinie – vollautomatisch, taktzeittauglich, 100% Prüfabdeckung ohne Stillstand.',
      },
      {
        title: '100% Prüfung',
        description: 'Lückenlose Qualitätskontrolle für jeden einzelnen Artikel. Kein Bauteil verlässt die Fertigung ohne Qualitätsnachweis.',
      },
      {
        title: 'KI-Automatisierung',
        description: 'Intelligente Defekterkennung ohne manuelle Eingriffe. Schneller, reproduzierbarer und günstiger als manuelle Auswertung.',
      },
    ],
    learnMore: 'Mehr erfahren',

    crossTitle: 'Noch in der Entwicklungsphase?',
    crossText: 'Für Prototypen, Erstmuster und Schadensanalysen bieten wir schnelle CT-Laboranalysen mit höchster Präzision.',
    crossBtn: 'CT-Labor entdecken',

    ctaTitle: 'Bereit für 100% Qualität?',
    ctaSubline: 'Lassen Sie uns gemeinsam Ihre Serienprüfung planen. Unverbindliche Beratung & individuelle ROI-Berechnung.',
    ctaButton: 'Jetzt Beratung anfragen',
  },

  en: {
    badge: 'Non-Destructive Series Inspection',
    tagline: 'GET YOUR INSPECTION DONE – Anywhere. Anytime. Fast.',
    headline: 'Non-Destructive',
    headlineAccent: 'Series Inspection',
    headlineSub: 'High Volume. Low Cost Per Part.',
    subline: 'Industrial CT series inspection from Microvista – economical, reliable, scalable. Lab, mobile, or cloud-based – we have the right solution for your production.',
    cta1: 'Book Express Inspection',
    cta2: 'Get Free Consultation',

    stats: [
      { value: '100%', label: 'Coverage' },
      { value: '<3s', label: 'per part' },
      { value: '99.9%', label: 'Detection rate' },
      { value: '450kV', label: 'Tube power' },
    ],

    whyTitle: 'High volume = low cost per part',
    whyText: 'CT-based non-destructive series inspection is the most economical form of quality assurance for complex parts in high volumes. Cost per part decreases as volume increases – and Microvista provides the complete infrastructure: CT lab, mobile CT, or automated cloud evaluation.',
    whyBenefits: [
      'Achieve a capable / controlled production process',
      'Reduce costs of further processing parts with hidden defects',
      'Prevent batch blocking with Microvista quality certification',
    ],

    aufgabenTitle: 'Typical inspection tasks in series production',
    aufgabenSubline: 'A single CT scan delivers all the following information simultaneously – no separate inspection method needed.',
    aufgaben: [
      { icon: '◎', title: 'Pores, Voids & Inclusions', text: 'Reliably detect volumetric defects in cast and sintered parts' },
      { icon: '✂', title: 'Burrs & Core Residues', text: 'Detect chips and core remnants in cavities – even hidden ones' },
      { icon: '⌇', title: 'Crack Inspection', text: 'Make hairline cracks and cold shuts visible in 3D' },
      { icon: '◉', title: 'Porosity Analysis', text: 'Precisely quantify pore distribution and volume fraction' },
      { icon: '↔', title: 'Wall Thickness Measurement', text: 'High-precision wall thickness measurement across the entire volume' },
      { icon: '⊞', title: 'CAD Comparison', text: 'Color-visualize deviations from the CAD model' },
      { icon: '⚙', title: 'Assembly & Joint Defects', text: 'Non-contact inspection of welds, press fits and adhesive bonds' },
      { icon: '⚡', title: 'Hairpin Stators', text: 'Complete quality inspection of e-motor windings and stator packs' },
    ],

    verfahrenTitle: 'Non-destructive testing methods compared',
    verfahrenSubline: 'Why industrial CT is the superior method for complex series parts',
    verfahren: [
      {
        method: 'X-Ray Diffraction (RT)',
        badge: 'Limited',
        badgeOk: false,
        cons: ['2D images only – no volume data', 'Expensive equipment & long inspection times', 'Limited defect detection for complex geometries'],
      },
      {
        method: 'Ultrasonic Testing (UT)',
        badge: 'Limited',
        badgeOk: false,
        cons: ['Unreliable for thin or hollow parts', 'Poor coupling on rough surfaces', 'No full volume scan possible'],
      },
      {
        method: 'Magnetic Particle & Penetrant Testing (MT/PT)',
        badge: 'Restricted',
        badgeOk: false,
        cons: ['Only surface defects detectable', 'Limited to specific materials', 'No cavities or internal structures'],
      },
      {
        method: 'Visual Testing (VT)',
        badge: 'Restricted',
        badgeOk: false,
        cons: ['Only externally visible defects', 'Highly inspector-dependent', 'No internal defects detectable'],
      },
      {
        method: 'Industrial CT (Microvista)',
        badge: 'Recommended',
        badgeOk: true,
        cons: ['3D volume images for every scan', 'Cracks, pores, dimensions & joint defects in ONE pass', '100% non-destructive – part remains intact'],
      },
    ],

    optionenTitle: 'How can series inspection be realized?',
    optionenSubline: 'Three paths to the most economical quality assurance for your production',
    optionen: [
      {
        nr: '01',
        title: 'CT Lab by Microvista',
        text: 'Ship parts to us – Microvista experts scan & evaluate. No investment costs, no personnel expense, no training. The ideal option for individual parts, batch approvals, or recurring series inspections.',
        note: 'Express scan < 24h possible (by appointment & depending on part count)',
        img: '/images/ct/Bauteil-im-CT-platziert-scaled.jpg',
        imgAlt: 'Part being placed in the Microvista CT lab',
        href: '/labor',
        btnLabel: 'Discover CT Lab',
      },
      {
        nr: '02',
        title: 'Mobile CT Rental – ScanExpress',
        text: 'On-site inspection at your facility – no need to ship parts. The mobile ScanExpress CT gives you full flexibility and saves high investment and waiting costs.',
        note: 'Ideal for temporary needs or on-site series production',
        img: '/images/ct/ScanExpress-Compact-Frontaufnahme-scaled.png',
        imgAlt: 'ScanExpress – the mobile industrial CT by Microvista',
        href: '/live-demo-scanexpress',
        btnLabel: 'Learn about ScanExpress',
      },
      {
        nr: '03',
        title: 'Microvista Cloud',
        text: 'Already own a CT? Upload your scan data to the Microvista Cloud for automated evaluation. Saves significant time – manual evaluation is completely eliminated.',
        note: 'For facilities with their own CT system and high inspection volumes',
        img: '/images/ct/Beispiel-Bedienoberflaeche-der-CT-Software-am-Laptop.png',
        imgAlt: 'Microvista Cloud software for automated CT evaluation',
        href: '/kontakt',
        btnLabel: 'Request Cloud Solution',
      },
    ],

    specsTitle: 'Our Measurement Capabilities',
    specsNote: 'Microvista uses a 450kV tube with exceptionally high photon energy – enabling non-destructive inspection of thick-walled iron castings up to approx. 70 mm wall thickness.',
    specs: [
      { value: '798 mm', label: 'Max. Part Ø' },
      { value: '1,802 mm', label: 'Max. Part Length' },
      { value: '200 kg', label: 'Max. Weight' },
      { value: '0.02–1 mm', label: 'Resolution' },
      { value: '450 kV', label: 'Tube Power' },
      { value: '< 24h', label: 'Express Option' },
      { value: '10 WD', label: 'Standard Lead Time' },
    ],

    servicesTitle: 'Our Series Inspection Solutions',
    servicesSubline: 'Customized inspection systems for every production requirement',
    services: [
      {
        title: 'Inline CT',
        description: 'CT inspection directly in your production line – fully automated, cycle-time capable, 100% coverage without downtime.',
      },
      {
        title: '100% Inspection',
        description: 'Complete quality control for every single article. No part leaves production without quality certification.',
      },
      {
        title: 'AI Automation',
        description: 'Intelligent defect detection without manual intervention. Faster, more reproducible, and cheaper than manual evaluation.',
      },
    ],
    learnMore: 'Learn more',

    crossTitle: 'Still in development?',
    crossText: 'For prototypes, first articles, and failure analysis, we offer fast CT lab analyses with maximum precision.',
    crossBtn: 'Discover CT Lab',

    ctaTitle: 'Ready for 100% quality?',
    ctaSubline: 'Let us plan your series inspection together. Non-binding consultation and individual ROI calculation.',
    ctaButton: 'Request Consultation Now',
  },
};

const t = content[locale as keyof typeof content] || content.en || content.de;

const ui = {
  de: { seoTitle: 'Zerstörungsfreie Serienprüfung mit industrieller CT', seoDesc: 'Microvista bietet zerstörungsfreie Serienprüfung mit industrieller CT – im Labor, mobil oder via Cloud. 100% Prüfabdeckung, < 24h Express, ISO 9001 & 17025 zertifiziert.' },
  en: { seoTitle: 'Non-Destructive Series Inspection with Industrial CT', seoDesc: 'Microvista offers non-destructive series inspection with industrial CT – lab, mobile or cloud. 100% coverage, < 24h express, ISO 9001 & 17025 certified.' },
  fr: { seoTitle: 'Contrôle en série non destructif par CT industriel', seoDesc: 'Microvista propose un contrôle en série non destructif par tomographie computérisée industrielle.' },
  es: { seoTitle: 'Inspección en serie no destructiva con CT industrial', seoDesc: 'Microvista ofrece inspección en serie no destructiva con tomografía computarizada industrial.' },
  it: { seoTitle: 'Ispezione in serie non distruttiva con CT industriale', seoDesc: 'Microvista offre ispezione in serie non distruttiva con tomografia computerizzata industriale.' },
}[locale] || { seoTitle: 'Zerstörungsfreie Serienprüfung mit industrieller CT', seoDesc: '' };

const serviceHrefs = [
  lp('/serie/inline-ct'),
  lp('/serie/100-prozent-pruefung'),
  lp('/serie/ki-automatisierung'),
];
---

<SerieLayout
  title={ui.seoTitle}
  description={ui.seoDesc}
>

  <!-- ─── 1. HERO ──────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="container hero-container">
        <div class="hero-content">
          <span class="badge">{t.badge}</span>
          <p class="tagline">{t.tagline}</p>
          <h1>
            {t.headline}
            <span class="accent">{t.headlineAccent}</span>
            <span class="sub">{t.headlineSub}</span>
          </h1>
          <p class="subline">{t.subline}</p>
          <div class="hero-cta">
            <a href={lp('/express-ct-inspektion')} class="btn btn-orange btn-lg">{t.cta1}</a>
            <a href={lp('/kontakt')} class="btn btn-ghost btn-lg">{t.cta2}</a>
          </div>
        </div>
      </div>
      <div class="hero-image-col">
        <img
          src="/images/ct/Microvista-Industrieller-CT-Container-Truck-ScanExpress-4K-scaled.jpg"
          alt="Microvista ScanExpress – mobiles industrielles CT im Container-Truck"
          loading="eager"
          class="hero-img"
        />
        <div class="hero-img-overlay"></div>
      </div>
    </div>
  </section>

  <!-- ─── 2. STATS BAR ─────────────────────────────── -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        {t.stats.map((s: any) => (
          <div class="stat-item">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 3. WARUM CT FÜR SERIENPRÜFUNG? ───────────── -->
  <section class="why-section section">
    <div class="container">
      <div class="why-grid">
        <div class="why-text">
          <h2>{t.whyTitle}</h2>
          <p>{t.whyText}</p>
          <ul class="benefits-list">
            {t.whyBenefits.map((b: string) => (
              <li class="benefit-item">
                <span class="benefit-check">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
                </span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="why-image">
          <img
            src="/images/ct/Analyse-industrieller-CT-Scan-scaled.png"
            alt="Analyse eines industriellen CT-Scans – Microvista Software"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. PRÜFAUFGABEN ───────────────────────────── -->
  <section class="aufgaben-section section">
    <div class="container">
      <div class="section-header text-center">
        <h2>{t.aufgabenTitle}</h2>
        <p class="text-muted">{t.aufgabenSubline}</p>
      </div>
      <div class="aufgaben-grid">
        {t.aufgaben.map((a: any) => (
          <div class="aufgabe-card">
            <span class="aufgabe-icon">{a.icon}</span>
            <h3>{a.title}</h3>
            <p>{a.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 5. VERFAHREN VERGLEICH ───────────────────── -->
  <section class="verfahren-section section">
    <div class="container">
      <div class="section-header text-center">
        <h2>{t.verfahrenTitle}</h2>
        <p class="text-muted">{t.verfahrenSubline}</p>
      </div>
      <div class="verfahren-grid">
        {t.verfahren.map((v: any) => (
          <div class={`verfahren-card ${v.badgeOk ? 'verfahren-card--winner' : ''}`}>
            <div class="verfahren-header">
              <h3>{v.method}</h3>
              <span class={`verfahren-badge ${v.badgeOk ? 'badge--ok' : 'badge--nok'}`}>{v.badge}</span>
            </div>
            <ul class="verfahren-list">
              {v.cons.map((c: string) => (
                <li>
                  <span class={`list-icon ${v.badgeOk ? 'icon--ok' : 'icon--nok'}`}>
                    {v.badgeOk
                      ? <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
                      : <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    }
                  </span>
                  <span>{c}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 6. REALISIERUNGSOPTIONEN ─────────────────── -->
  <section class="optionen-section section">
    <div class="container">
      <div class="section-header text-center">
        <h2>{t.optionenTitle}</h2>
        <p class="text-muted">{t.optionenSubline}</p>
      </div>
      <div class="optionen-grid">
        {t.optionen.map((o: any) => (
          <div class="option-card">
            <div class="option-image-wrap">
              <img src={o.img} alt={o.imgAlt} loading="lazy" />
              <span class="option-nr">{o.nr}</span>
            </div>
            <div class="option-body">
              <h3>{o.title}</h3>
              <p>{o.text}</p>
              <div class="option-note">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span>{o.note}</span>
              </div>
              <a href={lp(o.href)} class="option-link">
                {o.btnLabel}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 7. SPEZIFIKATIONEN ───────────────────────── -->
  <section class="specs-section">
    <div class="container">
      <div class="specs-header text-center">
        <h2>{t.specsTitle}</h2>
      </div>
      <div class="specs-grid">
        {t.specs.map((s: any) => (
          <div class="spec-item">
            <span class="spec-value">{s.value}</span>
            <span class="spec-label">{s.label}</span>
          </div>
        ))}
      </div>
      <p class="specs-note">{t.specsNote}</p>
    </div>
  </section>

  <!-- ─── 8. LÖSUNGEN (Services Grid) ─────────────── -->
  <section class="services-section section">
    <div class="container">
