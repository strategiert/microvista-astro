            <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- USPs -->
  <USPsSection content={{
    uspTitle: t.uspTitle,
    usps: t.usps,
  }} />

  <!-- MAGAZIN VORSCHAU -->
  {localePosts.length > 0 && (
    <section class="magazin-section">
      <div class="container">
        <div class="section-header-row">
          <div>
            <span class="section-eyebrow">Magazin</span>
            <h2 class="section-title">{t.magazinTitle}</h2>
          </div>
