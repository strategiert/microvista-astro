                <div class="magazin-card-body">
                  <span class="magazin-cat">{post.data.category}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description?.substring(0, 120)}…</p>
                  <span class="magazin-read-more">{t.readMore} →</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="container">
      <div class="final-cta-inner">
        <span class="cta-eyebrow">Kontakt</span>
        <h2>{t.ctaTitle}</h2>
