---

<BaseLayout
  title="Industrielle Computertomographie Dienstleister für Exzellenz"
  description="Defektanalyse, Dimensionsmessung, Montage- & Fügekontrolle durch industrielle Computertomographie: Anywhere. Anytime. Fast."
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/images/ct/CT-Techniker-am-industriellen-CT-Dustin-Klein-scaled-e1761285791426.jpg"
    fetchpriority="high"
  />
  <Header slot="header" theme="transparent" />

  <!-- HERO -->
  <HeroSection locale={locale} content={{
    heroBadge: t.heroBadge,
    heroTitle: t.heroTitle,
    heroTitleAccent: t.heroTitleAccent,
    heroSub: t.heroSub,
    cta1: t.cta1,
    cta2: t.cta2,
  }} />

  <!-- BEKANNT AUS -->
  <section class="press-section">
    <div class="container">
      <p class="press-label">{t.pressTitle}</p>
      <div class="press-logos">
        {pressLogos.map(logo => (
          <img src={logo.src} alt={logo.name} class="press-logo" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- PAIN POINTS -->
  <PainPointsSection locale={locale} content={{
    painTitle: t.painTitle,
    painTitleAccent: t.painTitleAccent,
    painItems: t.painItems,
    painCta: t.painCta,
    painCtaBtn: t.painCtaBtn,
  }} />

  <!-- LABOR / SERIE GATEWAY -->
  <GatewaySection locale={locale} content={{
    worldsTitle: t.worldsTitle,
    laborTitle: t.laborTitle,
    laborSub: t.laborSub,
    laborBenefits: t.laborBenefits,
    laborCta: t.laborCta,
    serieTitle: t.serieTitle,
    serieSub: t.serieSub,
    serieBenefits: t.serieBenefits,
    serieCta: t.serieCta,
  }} />

  <!-- PRÜFAUFGABEN -->
  <section class="aufgaben-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Leistungen</span>
        <h2 class="section-title">{t.aufgabenTitle}</h2>
      </div>
      <div class="aufgaben-grid">
        {t.aufgaben.map((a, i) => (
          <div class="aufgabe-card">
            <div class="aufgabe-icon" set:html={aufgabenIcons[a.icon]} />
            <h3>{a.title}</h3>
            <p>{a.desc}</p>
            <div class="card-number">0{i + 1}</div>
          </div>
        ))}
      </div>
      <div class="aufgaben-footer">
        <a href={lp('/industrielle-computertomographie/prufaufgaben')} class="btn btn-outline-dark">
