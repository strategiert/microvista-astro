            </svg>
          </a>
        </div>
        <div class="magazin-grid">
          {localePosts.map((post, i) => {
            const slug = post.id.replace(/^(de|en)\//, '').replace(/\.mdx?$/, '');
            return (
              <a href={lp(`/magazin/${slug}`)} class:list={['magazin-card', i === 0 ? 'magazin-card-featured' : '']}>
