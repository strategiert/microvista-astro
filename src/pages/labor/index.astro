---
import LaborLayout from '../../layouts/LaborLayout.astro';
import { localePath, type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

const content = {
  de: {
    badge: 'CT-Labor · Externe Qualitätskontrolle',
    headline: 'CT-Labor zur externen',
    headlineAccent: 'Qualitätskontrolle',
    tagline: 'GET YOUR INSPECTION DONE – Anywhere. Anytime. Fast.',
    subline: 'Einfach Bauteile zuschicken: Die Experten von Microvista scannen & werten aus. Keine Investitionskosten, kein Schulungsaufwand – volle Qualitätssicherheit.',
    cta1: 'Express-Inspektion buchen',
    cta2: 'Gratis-Beratung sichern',
    whenTitle: 'Wann auf das CT-Labor von Microvista setzen?',
    whenText: 'Die externe Qualitätskontrolle mit CT ist die ideale Option, falls Sie Einzelteile prüfen oder einmalig eine Charge freigeben wollen. Die automatisierte Prüfung einer Serie ist ebenfalls möglich. Jedoch fällt der Zeitaufwand für den Versand der Bauteile hierbei stärker ins Gewicht. Aus diesem Grund bietet Microvista die Möglichkeit, ein mobiles CT zu mieten. Dieses verschafft Ihnen volle Flexibilität, spart hohe Investmentkosten & Wartezeiten bei der Anschaffung eines eigenen CT. Falls Sie bereits ein CT besitzen & Ihren Auswerteprozess mit Automatisierung enorm verschnellern wollen, ist dies über die Microvista Cloud möglich.',
    benefits: [
      { icon: '✓', text: 'Kein teures CT muss angeschafft werden' },
      { icon: '✓', text: 'Personalkapazitäten können anders eingesetzt werden' },
      { icon: '✓', text: 'Keine regelmäßigen Schulungen für Mitarbeitende notwendig' },
    ],
    ablaufTitle: 'Ablauf einer Prüfung mit industrieller CT',
    ablaufSubline: 'Von der Bemusterung bis zur Serienprüfung – schnell, zuverlässig, zerstörungsfrei.',
    ablauf: [
      {
        tag: 'Serienprüfung',
        icon: '⚙',
        title: 'Automatisierte Serienprüfung',
        text: 'Haben Sie komplizierte und/oder sicherheitsrelevante Bauteile in hochwertigen Endprodukten? Würden Schäden bei Qualitätsmängeln weit über die Herstellungskosten hinausgehen? Sichern Sie sich mit einer schnellen, aufwandsarmen & zerstörungsfreien Prüfung ab. Im CT-Labor von Microvista kann ein Inspektionsprozess mittels fertiger Prozess- & Automatisierungsbausteine schnell & zu geringen Kosten realisiert werden.',
        note: 'Scan innerhalb von 24h möglich – nur mit Absprache & abhängig von der Teileanzahl',
        href: '/serie',
        btnLabel: 'Zur Serienprüfung',
      },
      {
        tag: 'Bemusterung',
        icon: '🔬',
        title: 'Erstmuster & Prototypen',
        text: 'Benötigen Sie einen Erstmusterprüfbericht oder brauchen Sie Unterstützung bei der Prototypenentwicklung? Zuverlässige Aussagen zum Produktzustand vor dem Start der Produktion oder im Entwicklungsprozess müssen schnell verfügbar sein, um rechtzeitig zu reagieren und die richtigen Schlüsse ziehen zu können. Microvista unterstützt Sie mit Expertise bei der Planung und Durchführung von CT-Scans sowie der anschließenden Analyse.',
        note: 'Durchlaufzeit nach Absprache – in der Regel < 3 Tage für Standardaufgaben',
        href: '/labor/erstmusterpruefung',
        btnLabel: 'Zur Erstmusterprüfung',
      },
    ],
    servicesTitle: 'Unsere Laborleistungen',
    servicesSubline: 'Spezialisierte CT-Analysen für jede Anforderung',
    services: [
      {
        title: 'Erstmusterprüfung',
        description: 'Validierung Ihrer Prototypen und Erstmuster mit höchster Präzision. Erstmusterprüfbericht (EMPB) inklusive.',
      },
      {
        title: 'Schadensanalyse',
        description: 'Detaillierte Untersuchung von Bauteilversagen und Defekten. Ursachenermittlung ohne Zerstörung des Bauteils.',
      },
      {
        title: 'Reverse Engineering',
        description: 'Digitalisierung und Analyse bestehender Bauteile. CAD-Modelle aus realen Bauteilen generieren.',
      }
    ],
    statsTitle: 'Warum Microvista?',
    stats: [
      { value: '24h', label: 'Express-Scan möglich' },
      { value: 'ISO', label: '9001 & 17025 zertifiziert' },
      { value: 'Sub-µm', label: 'Auflösung' },
      { value: '100%', label: 'Zerstörungsfrei' },
    ],
    ctaTitle: 'Bereit für präzise CT-Analysen?',
    ctaSubline: 'Bauteile einsenden, scannen lassen, Ergebnis erhalten. Wir melden uns innerhalb von 24 Stunden.',
    ctaButton: 'Jetzt Anfrage stellen',
    crossTitle: 'Serienreif?',
    crossText: 'Nach erfolgreicher Erstmusterfreigabe unterstützen wir Sie auch bei der automatisierten Serienprüfung – mobil oder stationär.',
    crossBtn: 'Serienprüfung entdecken',
    learnMore: 'Mehr erfahren',
  },
  en: {
    badge: 'CT Lab · External Quality Control',
    headline: 'CT Lab for external',
    headlineAccent: 'quality control',
    tagline: 'GET YOUR INSPECTION DONE – Anywhere. Anytime. Fast.',
    subline: 'Simply send your components: Microvista experts scan & evaluate. No investment costs, no training required – full quality assurance.',
    cta1: 'Book Express Inspection',
    cta2: 'Get Free Consultation',
    whenTitle: 'When to use the Microvista CT Lab?',
    whenText: 'External CT quality control is the ideal option if you want to inspect individual parts or approve a batch one-time. Automated inspection of a series is also possible, but shipping time becomes more significant. That is why Microvista offers mobile CT rental for full flexibility without high investment costs. If you already own a CT and want to massively accelerate your evaluation process with automation, this is possible via the Microvista Cloud.',
    benefits: [
      { icon: '✓', text: 'No expensive CT equipment needs to be purchased' },
      { icon: '✓', text: 'Personnel capacity can be deployed elsewhere' },
      { icon: '✓', text: 'No regular training for staff required' },
    ],
    ablaufTitle: 'Inspection process with industrial CT',
    ablaufSubline: 'From first article to series inspection – fast, reliable, non-destructive.',
    ablauf: [
      {
        tag: 'Series Inspection',
        icon: '⚙',
        title: 'Automated Series Inspection',
        text: 'Do you have complex and/or safety-relevant components in high-quality end products? Would damage from quality defects far exceed manufacturing costs? Protect yourself with fast, low-effort & non-destructive inspection. At Microvista\'s CT lab, an inspection process can be realized quickly and at low cost using ready-made process & automation modules.',
        note: 'Scan within 24h possible – by appointment & depending on part count',
        href: '/serie',
        btnLabel: 'To Series Inspection',
      },
      {
        tag: 'First Article',
        icon: '🔬',
        title: 'First Article & Prototypes',
        text: 'Do you need a first article inspection report or support with prototype development? Reliable statements about product condition before production starts must be quickly available to react in time and draw the right conclusions. Microvista supports you with expertise in planning and conducting CT scans and the subsequent analysis.',
        note: 'Lead time by agreement – typically < 3 days for standard tasks',
        href: '/labor/erstmusterpruefung',
        btnLabel: 'To First Article Inspection',
      },
    ],
    servicesTitle: 'Our Lab Services',
    servicesSubline: 'Specialized CT analyses for every requirement',
    services: [
      {
        title: 'First Article Inspection',
        description: 'Validation of your prototypes and first articles with highest precision. FAIR report included.',
      },
      {
        title: 'Failure Analysis',
        description: 'Detailed investigation of component failures and defects. Root cause analysis without destroying the part.',
      },
      {
        title: 'Reverse Engineering',
        description: 'Digitization and analysis of existing components. Generate CAD models from real parts.',
      }
    ],
    statsTitle: 'Why Microvista?',
    stats: [
      { value: '24h', label: 'Express scan possible' },
      { value: 'ISO', label: '9001 & 17025 certified' },
      { value: 'Sub-µm', label: 'Resolution' },
      { value: '100%', label: 'Non-destructive' },
    ],
    ctaTitle: 'Ready for precise CT analyses?',
    ctaSubline: 'Send parts, get scanned, receive results. We respond within 24 hours.',
    ctaButton: 'Request Quote Now',
    crossTitle: 'Ready for production?',
    crossText: 'After successful first article approval, we also support you with automated serial inspection – mobile or stationary.',
    crossBtn: 'Discover Series Inspection',
    learnMore: 'Learn more',
  }
};

const t = content[locale as keyof typeof content] || content.en || content.de;

const serviceHrefs = [
  lp('/labor/erstmusterpruefung'),
  lp('/labor/schadensanalyse'),
  lp('/labor/reverse-engineering'),
];
---

<LaborLayout
  title="CT-Labor für externe Qualitätskontrolle"
  description={t.subline}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-inner">
      <div class="container">
        <div class="hero-content">
          <span class="badge">{t.badge}</span>
          <p class="tagline">{t.tagline}</p>
          <h1>
            {t.headline}
            <span class="accent">{t.headlineAccent}</span>
          </h1>
          <p class="subline">{t.subline}</p>
          <div class="hero-cta">
            <a href={lp('/express-ct-inspektion')} class="btn btn-primary btn-lg">{t.cta1}</a>
            <a href={lp('/kontakt')} class="btn btn-ghost btn-lg">{t.cta2}</a>
          </div>
        </div>
      </div>
      <div class="hero-image-wrap">
        <img
          src="/images/ct/Bauteil-im-CT-platziert-scaled.jpg"
          alt="Bauteil wird im industriellen CT von Microvista platziert"
          class="hero-img"
          loading="eager"
        />
        <div class="hero-image-overlay"></div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        {t.stats.map((s: any) => (
          <div class="stat-item">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- When Section -->
  <section class="when-section section">
    <div class="container">
      <div class="when-grid">
        <div class="when-text">
          <h2>{t.whenTitle}</h2>
          <p>{t.whenText}</p>
          <ul class="benefits-list">
            {t.benefits.map((b: any) => (
              <li class="benefit-item">
                <span class="benefit-icon">{b.icon}</span>
                <span>{b.text}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="when-image">
          <img
            src="/images/ct/CT-Techniker-am-industriellen-CT-Dustin-Klein-scaled-e1761285791426.jpg"
            alt="CT-Techniker Dustin Klein am industriellen CT von Microvista"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Ablauf Section -->
  <section class="ablauf-section section">
    <div class="container">
      <div class="section-header text-center">
        <h2>{t.ablaufTitle}</h2>
        <p class="text-muted">{t.ablaufSubline}</p>
      </div>
      <div class="ablauf-grid">
        {t.ablauf.map((item: any) => (
          <div class="ablauf-card">
            <div class="ablauf-card-header">
              <span class="ablauf-tag">{item.tag}</span>
              <span class="ablauf-icon" aria-hidden="true">{item.icon}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <div class="ablauf-note">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>{item.note}</span>
            </div>
            <a href={lp(item.href)} class="ablauf-link">
              {item.btnLabel}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services section">
    <div class="container">
      <div class="section-header text-center">
        <h2>{t.servicesTitle}</h2>
        <p class="text-muted">{t.servicesSubline}</p>
      </div>
      <div class="services-grid">
        {t.services.map((service: any, index: number) => (
          <a href={serviceHrefs[index]} class="service-card card">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <span class="card-link">
              {t.learnMore}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-Sell -->
  <section class="cross-sell">
    <div class="container">
      <div class="cross-sell-box">
        <div class="cross-sell-icon-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <div class="cross-sell-content">
          <strong>{t.crossTitle}</strong>
          <p>{t.crossText}</p>
        </div>
        <a href={lp('/serie')} class="btn btn-primary">{t.crossBtn}</a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-text">
          <h2>{t.ctaTitle}</h2>
          <p>{t.ctaSubline}</p>
        </div>
        <a href={lp('/kontakt')} class="btn btn-cta btn-lg">{t.ctaButton}</a>
      </div>
    </div>
  </section>
</LaborLayout>

<style>
  /* ─── Hero ─────────────────────────────────── */
  .hero {
    background: var(--primary);
    color: white;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-image-wrap {
      display: none;
    }
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .hero .container {
    display: flex;
    align-items: center;
    padding-top: var(--space-20);
    padding-bottom: var(--space-20);
  }

  .hero-content {
    max-width: 600px;
  }

  .badge {
    display: inline-block;
    padding: var(--space-1) var(--space-4);
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
    font-family: var(--font-heading);
  }

  .tagline {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    letter-spacing: 0.12em;
    color: var(--accent-light);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
    font-weight: 600;
  }

  .hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    color: white;
    line-height: 1.1;
    margin-bottom: var(--space-6);
    text-transform: uppercase;
  }

  .hero h1 .accent {
    display: block;
    color: var(--accent-light);
  }

  .subline {
    font-size: var(--text-lg);
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    margin-bottom: var(--space-8);
    max-width: 520px;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: all var(--transition-base);
    border: 2px solid transparent;
    cursor: pointer;
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-lg);
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--accent-light);
  }

  .btn-ghost {
    background: transparent;
    border-color: rgba(255,255,255,0.4);
    color: white;
  }

  .btn-ghost:hover {
    background: rgba(255,255,255,0.1);
    border-color: white;
  }

  .btn-secondary {
    background: transparent;
    border-color: var(--border);
    color: var(--primary);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-cta {
    background: var(--accent);
    color: white;
    white-space: nowrap;
  }

  .btn-cta:hover {
    background: var(--accent-light);
  }

  .hero-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--primary) 0%, transparent 30%);
  }

  /* ─── Stats Bar ─────────────────────────────── */
  .stats-bar {
    background: var(--primary-light);
    color: white;
    padding: var(--space-6) 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    text-align: center;
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--accent-light);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
  }

  /* ─── Section Utility ───────────────────────── */
  .section {
    padding: var(--space-20) 0;
  }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--primary);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }

  .text-center {
    text-align: center;
  }

  .text-muted {
    color: var(--text-muted);
    font-size: var(--text-lg);
  }

  /* ─── When Section ──────────────────────────── */
  .when-section {
    background: var(--surface);
  }

  .when-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  @media (max-width: 768px) {
    .when-grid {
      grid-template-columns: 1fr;
    }
    .when-image {
      display: none;
    }
  }

  .when-text h2 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--primary);
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  .when-text p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: white;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .benefit-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: var(--accent);
    color: white;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .benefit-item span:last-child {
    color: var(--text);
    font-weight: 500;
    line-height: 1.5;
  }

  .when-image img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xl);
  }

  /* ─── Ablauf Section ────────────────────────── */
  .ablauf-section {
    background: white;
  }

  .ablauf-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  @media (max-width: 768px) {
    .ablauf-grid {
      grid-template-columns: 1fr;
    }
  }

  .ablauf-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
    overflow: hidden;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .ablauf-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-2px);
  }

  .ablauf-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--accent);
  }

  .ablauf-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ablauf-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--primary);
    color: white;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-family: var(--font-heading);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .ablauf-icon {
    font-size: var(--text-2xl);
    line-height: 1;
  }

  .ablauf-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--primary);
    text-transform: uppercase;
    margin: 0;
  }

  .ablauf-card p {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .ablauf-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3);
