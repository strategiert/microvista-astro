---
import LaborLayout from '../../layouts/LaborLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { localePath, type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);
const content = await loadStaticPage('pruefaufgabe-reverse-engineering', locale);

let articleContent = content || '';
if (content) {
  const h2Index = content.indexOf('<h2');
  if (h2Index > -1) articleContent = content.substring(h2Index);
}

const t = {
  de: {
    seoTitle: 'CT Reverse Engineering | Vom 3D-Scan zum CAD-Modell | Microvista',
    description: 'CT-basiertes Reverse Engineering: Vollständige Digitalisierung inkl. Innengeometrien. Vom Scan zum CAD-Modell — zerstörungsfrei.',
    h1: 'Reverse Engineering',
    lead: 'Vom physischen Bauteil zum digitalen CAD-Modell — mit industrieller CT erfassen wir Außen- und Innengeometrien in einem Scan, zerstörungsfrei und hochpräzise.',
    cta: 'Reverse Engineering anfragen',
    back: 'Zurück zum CT-Labor',
    badges: ['Innengeometrien erfassbar', 'Keine Demontage nötig', 'STEP/IGES/STL Export'],
  },
  en: {
    seoTitle: 'CT Reverse Engineering | From 3D Scan to CAD Model | Microvista',
    description: 'CT-based reverse engineering: Complete digitization including internal geometries. From scan to CAD model — non-destructive.',
    h1: 'Reverse Engineering',
    lead: 'From physical component to digital CAD model — with industrial CT we capture exterior and interior geometries in one scan, non-destructive and highly precise.',
    cta: 'Request Reverse Engineering',
    back: 'Back to CT Lab',
    badges: ['Internal geometries captured', 'No disassembly needed', 'STEP/IGES/STL export'],
  },
  fr: {
    seoTitle: 'Rétro-ingénierie CT | Du scan 3D au modèle CAO | Microvista',
    description: 'Rétro-ingénierie basée sur la CT: numérisation complète y compris géométries internes.',
    h1: 'Rétro-ingénierie',
    lead: 'Du composant physique au modèle CAO numérique — avec la CT industrielle, nous capturons géométries extérieures et intérieures en un seul scan.',
    cta: 'Demander une rétro-ingénierie',
    back: 'Retour au labo CT',
    badges: ['Géométries internes', 'Pas de démontage', 'Export STEP/IGES/STL'],
  },
  es: {
    seoTitle: 'Ingeniería inversa CT | Del escaneo 3D al modelo CAD | Microvista',
    description: 'Ingeniería inversa basada en CT: digitalización completa incluyendo geometrías internas.',
    h1: 'Ingeniería inversa',
    lead: 'Del componente físico al modelo CAD digital — con CT industrial capturamos geometrías exteriores e interiores en un solo escaneo.',
    cta: 'Solicitar ingeniería inversa',
    back: 'Volver al laboratorio CT',
    badges: ['Geometrías internas', 'Sin desmontaje', 'Exportación STEP/IGES/STL'],
  },
  it: {
    seoTitle: 'Reverse Engineering CT | Dalla scansione 3D al modello CAD | Microvista',
    description: 'Reverse engineering basato su CT: digitalizzazione completa incluse geometrie interne.',
    h1: 'Reverse Engineering',
    lead: 'Dal componente fisico al modello CAD digitale — con la CT industriale catturiamo geometrie esterne e interne in una sola scansione.',
    cta: 'Richiedere reverse engineering',
    back: 'Torna al laboratorio CT',
    badges: ['Geometrie interne', 'Nessun smontaggio', 'Esportazione STEP/IGES/STL'],
  },
}[locale] || {
  seoTitle: 'CT Reverse Engineering | Microvista',
  description: 'CT-based reverse engineering for complete component digitization.',
  h1: 'Reverse Engineering',
  lead: 'From physical component to digital CAD model with industrial CT.',
  cta: 'Request Reverse Engineering',
  back: 'Back to CT Lab',
  badges: ['Internal geometries', 'No disassembly', 'STEP/IGES/STL export'],
};
---

<LaborLayout title={t.seoTitle} description={t.description}>
  <section class="lab-hero">
    <div class="container">
      <nav class="lab-breadcrumb" aria-label="breadcrumb">
        <a href={lp('/labor')}>{t.back}</a>
        <span aria-hidden="true"> / </span>
        <span>{t.h1}</span>
      </nav>
      <h1>{t.h1}</h1>
      <p class="lab-lead">{t.lead}</p>
      <div class="lab-hero-actions">
        <a href={lp('/kontakt')} class="btn btn-primary">{t.cta}</a>
      </div>
      <div class="lab-badges">
        {t.badges.map((b: string) => <span class="lab-badge">{b}</span>)}
      </div>
    </div>
  </section>

  <section class="lab-article">
    <div class="container">
      <div class="lab-body" set:html={articleContent} />
    </div>
  </section>

  <section class="lab-cta-section">
    <div class="container">
      <div class="lab-cta-box">
        <h2>{t.cta}</h2>
        <p>{locale === 'de' ? 'Unsere CT-Experten beraten Sie kostenlos & unverbindlich.' : 'Our CT experts are happy to advise you — free & non-binding.'}</p>
        <a href={lp('/kontakt')} class="btn btn-primary btn-lg">{t.cta}</a>
      </div>
    </div>
  </section>
</LaborLayout>

<style>
  .lab-hero {
    background: white;
    color: var(--text);
    padding: var(--space-20) 0 var(--space-16);
    border-bottom: 1px solid var(--border);
  }

  .lab-breadcrumb {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-6);
    display: flex;
    gap: var(--space-2);
    align-items: center;
    flex-wrap: wrap;
  }

  .lab-breadcrumb a {
    color: var(--accent);
    text-decoration: none;
  }

  .lab-breadcrumb a:hover { color: var(--primary); }

  .lab-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    color: var(--primary);
    margin-bottom: var(--space-5);
    max-width: 820px;
    line-height: 1.1;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .lab-hero h1 { font-size: var(--text-4xl); }
  }

  .lab-lead {
    font-size: var(--text-xl);
    color: var(--text-muted);
    max-width: 680px;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .lab-hero-actions {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .lab-badges {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .lab-badge {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 4px var(--space-3);
    border: 1px solid rgba(142, 191, 214, 0.4);
    border-radius: var(--radius-full);
    color: var(--text-muted);
    background: rgba(142, 191, 214, 0.1);
  }

  .lab-article {
    padding: var(--space-16) 0 var(--space-20);
    background: #ffffff;
  }

  .lab-body {
    max-width: 860px;
    margin: 0 auto;
  }

  .lab-body :global(h2) {
    font-size: var(--text-3xl);
    font-family: var(--font-heading);
    color: var(--primary);
    margin-top: var(--space-16);
    margin-bottom: var(--space-5);
    padding-left: var(--space-4);
    border-left: 4px solid var(--accent);
    line-height: 1.25;
    text-transform: uppercase;
  }

  .lab-body :global(h2:first-child) { margin-top: 0; }

  .lab-body :global(h3) {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    color: var(--primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .lab-body :global(h4) {
    font-size: var(--text-xl);
    font-family: var(--font-heading);
    color: var(--primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .lab-body :global(p) {
    font-size: var(--text-base);
    line-height: 1.85;
    margin-bottom: var(--space-5);
    color: #374151;
  }

  .lab-body :global(ul),
  .lab-body :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .lab-body :global(li) {
    line-height: 1.75;
    margin-bottom: var(--space-2);
    color: #374151;
  }

  .lab-body :global(ul > li::marker) { color: var(--accent); }

  .lab-body :global(strong) {
    font-weight: 700;
    color: var(--primary);
  }

  .lab-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    margin: var(--space-8) 0;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  }

  .lab-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(238, 119, 17, 0.35);
    text-underline-offset: 3px;
  }

  .lab-body :global(a:hover) {
    color: #c85e00;
    text-decoration-color: #c85e00;
  }

  .lab-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-8) 0;
    font-size: var(--text-sm);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  }

  .lab-body :global(th) {
    background: var(--primary);
    color: white;
    padding: var(--space-3) var(--space-4);
    text-align: left;
    font-weight: 600;
  }

  .lab-body :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid #e5e7eb;
    color: #374151;
  }

  .lab-body :global(tr:nth-child(even) td) { background: #f9fafb; }

  .lab-cta-section {
    padding: var(--space-20) 0;
    background: var(--surface);
  }

  .lab-cta-box {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    background: white;
    padding: var(--space-12) var(--space-10);
    border-radius: var(--radius-2xl);
    box-shadow: 0 8px 40px rgba(50, 40, 91, 0.12);
  }

  .lab-cta-box h2 {
    color: var(--primary);
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
    border: none;
    padding: 0;
  }

  .lab-cta-box p {
    color: #6b7280;
    font-size: var(--text-lg);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .btn-lg {
    padding: var(--space-4) var(--space-10);
    font-size: var(--text-lg);
  }
</style>
