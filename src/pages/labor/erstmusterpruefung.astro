---
import LaborLayout from '../../layouts/LaborLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { localePath, type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);
const content = await loadStaticPage('pruefaufgabe-erstmusterpruefbericht', locale);

// Extract article (strip WP hero — starts at first H2)
let articleContent = content || '';
let pageTitle = 'Erstmusterprüfung';
if (content) {
  const h2Index = content.indexOf('<h2');
  if (h2Index > -1) articleContent = content.substring(h2Index);
}

const t = {
  de: {
    seoTitle: 'Erstmusterprüfung im CT-Labor | EMPB nach VDA & PPAP | Microvista',
    description: 'Erstmusterprüfbericht (EMPB) mit industrieller CT: Zerstörungsfreie Prüfung nach VDA Band 2 & PPAP. Express-Service, ISO 9001 zertifiziert.',
    h1: 'Erstmusterprüfung',
    lead: 'Erstmusterprüfberichte (EMPB) mit industrieller CT — zerstörungsfrei, normkonform, schnell. Von der Erstbemusterung bis zur Serienfreigabe nach VDA Band 2 und PPAP.',
    cta: 'Erstmusterprüfung anfragen',
    back: 'Zurück zum CT-Labor',
    badges: ['Express < 3 Tage', 'ISO 9001 zertifiziert', 'VDA & PPAP konform'],
  },
  en: {
    seoTitle: 'First Article Inspection in CT Lab | FAIR per VDA & PPAP | Microvista',
    description: 'First Article Inspection Report (FAIR) with industrial CT: Non-destructive testing per VDA Volume 2 & PPAP. Express service, ISO 9001 certified.',
    h1: 'First Article Inspection',
    lead: 'First Article Inspection Reports (FAIR) with industrial CT — non-destructive, standards-compliant, fast. From prototyping to series release per VDA Volume 2 and PPAP.',
    cta: 'Request First Article Inspection',
    back: 'Back to CT Lab',
    badges: ['Express < 3 days', 'ISO 9001 certified', 'VDA & PPAP compliant'],
  },
  fr: {
    seoTitle: 'Inspection premier article au labo CT | Microvista',
    description: 'Rapport d\'inspection premier article avec CT industriel selon VDA & PPAP. Service express, certifié ISO 9001.',
    h1: 'Inspection premier article',
    lead: 'Rapports d\'inspection premier article avec CT industriel — non destructif, conforme aux normes, rapide.',
    cta: 'Demander une inspection',
    back: 'Retour au labo CT',
    badges: ['Express < 3 jours', 'Certifié ISO 9001', 'Conforme VDA & PPAP'],
  },
  es: {
    seoTitle: 'Inspección de primera muestra en laboratorio CT | Microvista',
    description: 'Informe de inspección de primera muestra con CT industrial según VDA y PPAP. Servicio express, certificado ISO 9001.',
    h1: 'Inspección de primera muestra',
    lead: 'Informes de inspección de primera muestra con CT industrial — no destructivo, conforme a normas, rápido.',
    cta: 'Solicitar inspección',
    back: 'Volver al laboratorio CT',
    badges: ['Express < 3 días', 'Certificado ISO 9001', 'Conforme VDA y PPAP'],
  },
  it: {
    seoTitle: 'Ispezione primo articolo nel laboratorio CT | Microvista',
    description: 'Rapporto di ispezione primo articolo con CT industriale secondo VDA e PPAP. Servizio express, certificato ISO 9001.',
    h1: 'Ispezione primo articolo',
    lead: 'Rapporti di ispezione primo articolo con CT industriale — non distruttivo, conforme alle norme, veloce.',
    cta: 'Richiedere ispezione',
    back: 'Torna al laboratorio CT',
    badges: ['Express < 3 giorni', 'Certificato ISO 9001', 'Conforme VDA e PPAP'],
  },
}[locale] || {
  seoTitle: 'First Article Inspection | Microvista',
  description: 'First Article Inspection Report with industrial CT.',
  h1: 'First Article Inspection',
  lead: 'First Article Inspection Reports with industrial CT — non-destructive, standards-compliant, fast.',
  cta: 'Request Inspection',
  back: 'Back to CT Lab',
  badges: ['Express < 3 days', 'ISO 9001 certified', 'VDA & PPAP compliant'],
};
---

<LaborLayout title={t.seoTitle} description={t.description}>
  <!-- Hero -->
  <section class="lab-hero">
    <div class="container">
      <nav class="lab-breadcrumb" aria-label="breadcrumb">
        <a href={lp('/labor')}>{t.back}</a>
        <span aria-hidden="true"> / </span>
        <span>{t.h1}</span>
      </nav>
      <h1>{t.h1}</h1>
      <p class="lab-lead">{t.lead}</p>
      <div class="lab-hero-actions">
        <a href={lp('/kontakt')} class="btn btn-primary">{t.cta}</a>
      </div>
      <div class="lab-badges">
        {t.badges.map((b: string) => <span class="lab-badge">{b}</span>)}
      </div>
    </div>
  </section>

  <!-- Article -->
  <section class="lab-article">
    <div class="container">
      <div class="lab-body" set:html={articleContent} />
    </div>
  </section>

  <!-- CTA -->
  <section class="lab-cta-section">
    <div class="container">
      <div class="lab-cta-box">
        <h2>{t.cta}</h2>
        <p>{locale === 'de' ? 'Unsere CT-Experten beraten Sie kostenlos & unverbindlich.' : 'Our CT experts are happy to advise you — free & non-binding.'}</p>
        <a href={lp('/kontakt')} class="btn btn-primary btn-lg">{t.cta}</a>
      </div>
    </div>
  </section>
</LaborLayout>

<style>
  /* ===== HERO ===== */
  .lab-hero {
    background: white;
    color: var(--text);
    padding: var(--space-20) 0 var(--space-16);
    border-bottom: 1px solid var(--border);
  }

  .lab-breadcrumb {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-6);
    display: flex;
    gap: var(--space-2);
    align-items: center;
    flex-wrap: wrap;
  }

  .lab-breadcrumb a {
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .lab-breadcrumb a:hover {
    color: var(--primary);
  }

  .lab-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    color: var(--primary);
    margin-bottom: var(--space-5);
    max-width: 820px;
    line-height: 1.1;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .lab-hero h1 { font-size: var(--text-4xl); }
  }

  .lab-lead {
    font-size: var(--text-xl);
    color: var(--text-muted);
    max-width: 680px;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .lab-hero-actions {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .lab-badges {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .lab-badge {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 4px var(--space-3);
    border: 1px solid rgba(142, 191, 214, 0.4);
    border-radius: var(--radius-full);
    color: var(--text-muted);
    background: rgba(142, 191, 214, 0.1);
  }

  /* ===== ARTICLE ===== */
  .lab-article {
    padding: var(--space-16) 0 var(--space-20);
    background: #ffffff;
  }

  .lab-body {
    max-width: 860px;
    margin: 0 auto;
  }

  .lab-body :global(h2) {
    font-size: var(--text-3xl);
    font-family: var(--font-heading);
    color: var(--primary);
    margin-top: var(--space-16);
    margin-bottom: var(--space-5);
    padding-left: var(--space-4);
    border-left: 4px solid var(--accent);
    line-height: 1.25;
    text-transform: uppercase;
  }

  .lab-body :global(h2:first-child) {
    margin-top: 0;
  }

  .lab-body :global(h3) {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    color: var(--primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .lab-body :global(h4) {
    font-size: var(--text-xl);
    font-family: var(--font-heading);
    color: var(--primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .lab-body :global(p) {
    font-size: var(--text-base);
    line-height: 1.85;
    margin-bottom: var(--space-5);
    color: #374151;
  }

  .lab-body :global(ul),
  .lab-body :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .lab-body :global(li) {
    line-height: 1.75;
    margin-bottom: var(--space-2);
    color: #374151;
  }

  .lab-body :global(ul > li::marker) {
    color: var(--accent);
  }

  .lab-body :global(strong) {
    font-weight: 700;
    color: var(--primary);
  }

  .lab-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    margin: var(--space-8) 0;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  }

  .lab-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(238, 119, 17, 0.35);
    text-underline-offset: 3px;
    transition: all var(--transition-fast);
  }

  .lab-body :global(a:hover) {
    color: #c85e00;
    text-decoration-color: #c85e00;
  }

  .lab-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-8) 0;
    font-size: var(--text-sm);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  }

  .lab-body :global(th) {
    background: var(--primary);
    color: white;
    padding: var(--space-3) var(--space-4);
    text-align: left;
    font-weight: 600;
  }

  .lab-body :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid #e5e7eb;
    color: #374151;
  }

  .lab-body :global(tr:nth-child(even) td) {
    background: #f9fafb;
  }

  /* ===== CTA ===== */
  .lab-cta-section {
    padding: var(--space-20) 0;
    background: var(--surface);
  }

  .lab-cta-box {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    background: white;
    padding: var(--space-12) var(--space-10);
    border-radius: var(--radius-2xl);
    box-shadow: 0 8px 40px rgba(50, 40, 91, 0.12);
  }

  .lab-cta-box h2 {
    color: var(--primary);
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
    border: none;
    padding: 0;
  }

  .lab-cta-box p {
    color: #6b7280;
    font-size: var(--text-lg);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .btn-lg {
    padding: var(--space-4) var(--space-10);
    font-size: var(--text-lg);
  }
</style>
