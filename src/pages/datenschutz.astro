---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { loadStaticPage } from '../lib/load-static-page';
import { type Locale } from '../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('datenschutz', locale);

let articleContent = content || '';
if (content) {
  const h2Index = content.indexOf('<h2');
  if (h2Index > -1) articleContent = content.substring(h2Index);
}

const t = {
  de: { title: 'Datenschutzerklärung | Microvista', description: 'Datenschutzerklärung der Microvista GmbH gemäß DSGVO.', h1: 'Datenschutzerklärung' },
  en: { title: 'Privacy Policy | Microvista', description: 'Privacy policy of Microvista GmbH in accordance with GDPR.', h1: 'Privacy Policy' },
  fr: { title: 'Politique de confidentialité | Microvista', description: 'Politique de confidentialité.', h1: 'Politique de confidentialité' },
  es: { title: 'Política de privacidad | Microvista', description: 'Política de privacidad.', h1: 'Política de privacidad' },
  it: { title: 'Informativa sulla privacy | Microvista', description: 'Informativa sulla privacy.', h1: 'Informativa sulla privacy' },
}[locale] || { title: 'Privacy Policy | Microvista', description: 'Privacy policy.', h1: 'Privacy Policy' };
---

<BaseLayout title={t.title} description={t.description}>
  <Header slot="header" />

  <section class="legal-hero">
    <div class="container">
      <h1>{t.h1}</h1>
    </div>
  </section>

  <section class="legal-article">
    <div class="container">
      <div class="legal-body" set:html={articleContent} />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .legal-hero { background: #32285b; color: white; padding: var(--space-16) 0 var(--space-12); }
  .legal-hero h1 { font-family: var(--font-heading); font-size: var(--text-4xl); color: white; line-height: 1.1; text-transform: uppercase; }

  .legal-article { padding: var(--space-12) 0 var(--space-20); background: white; }
  .legal-body { max-width: 800px; margin: 0 auto; }
  .legal-body :global(h2) { font-size: var(--text-2xl); font-family: var(--font-heading); color: #32285b; margin-top: var(--space-12); margin-bottom: var(--space-4); padding-left: var(--space-4); border-left: 3px solid #ee7711; }
  .legal-body :global(h2:first-child) { margin-top: 0; }
  .legal-body :global(h3) { font-size: var(--text-xl); font-family: var(--font-heading); color: #32285b; margin-top: var(--space-8); margin-bottom: var(--space-3); }
  .legal-body :global(p) { font-size: var(--text-base); line-height: 1.85; margin-bottom: var(--space-4); color: #374151; }
  .legal-body :global(strong) { font-weight: 700; color: #32285b; }
  .legal-body :global(a) { color: #ee7711; text-decoration: underline; text-underline-offset: 3px; }
  .legal-body :global(a:hover) { color: #c85e00; }
  .legal-body :global(ul), .legal-body :global(ol) { padding-left: var(--space-6); margin-bottom: var(--space-4); }
  .legal-body :global(li) { line-height: 1.75; margin-bottom: var(--space-2); color: #374151; }
</style>
