---
import SerieLayout from '../layouts/SerieLayout.astro';
import { loadStaticPage } from '../lib/load-static-page';
import { localePath, type Locale } from '../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);
const content = await loadStaticPage('live-demo-scanexpress', locale);

let articleContent = content || '';
if (content) {
  const h2Index = content.indexOf('<h2');
  if (h2Index > -1) articleContent = content.substring(h2Index);
}

const t = {
  de: {
    seoTitle: 'ScanExpress — Mobiles industrielles CT zum Mieten | Microvista',
    description: 'Mobiles CT zum Mieten: ScanExpress bringt die CT-Prüfung direkt zu Ihnen. Full-Service oder begleitete Miete. Ergebnisse in 48h.',
    h1: 'ScanExpress',
    lead: 'Mobiles industrielles CT zum Mieten — Qualitätsprüfung direkt vor Ort, ohne Investitionskosten. Ergebnisse in 48 Stunden.',
    cta: 'ScanExpress anfragen',
    back: 'Zurück zur Serienprüfung',
    badges: ['48h Verfügbarkeit', 'Wochenweise mietbar', 'Plug & Play'],
  },
  en: {
    seoTitle: 'ScanExpress — Mobile Industrial CT for Rent | Microvista',
    description: 'Mobile CT for rent: ScanExpress brings CT inspection directly to you. Full-service or accompanied rental. Results in 48h.',
    h1: 'ScanExpress',
    lead: 'Mobile industrial CT for rent — quality inspection on-site, no investment costs. Results in 48 hours.',
    cta: 'Request ScanExpress',
    back: 'Back to Series Inspection',
    badges: ['48h availability', 'Weekly rental', 'Plug & Play'],
  },
}[locale] || {
  seoTitle: 'ScanExpress — Mobile Industrial CT | Microvista',
  description: 'Mobile industrial CT for rent.',
  h1: 'ScanExpress',
  lead: 'Mobile industrial CT for rent — quality inspection on-site.',
  cta: 'Request ScanExpress',
  back: 'Back to Series Inspection',
  badges: ['48h availability', 'Weekly rental', 'Plug & Play'],
};
---

<SerieLayout title={t.seoTitle} description={t.description}>
  <section class="se-hero">
    <div class="container">
      <nav class="se-breadcrumb" aria-label="breadcrumb">
        <a href={lp('/serie')}>{t.back}</a>
        <span aria-hidden="true"> / </span>
        <span>{t.h1}</span>
      </nav>
      <h1>{t.h1}</h1>
      <p class="se-lead">{t.lead}</p>
      <div class="se-hero-actions">
        <a href={lp('/kontakt')} class="btn btn-orange">{t.cta}</a>
      </div>
      <div class="se-badges">
        {t.badges.map((b: string) => <span class="se-badge">{b}</span>)}
      </div>
    </div>
  </section>

  <section class="se-article">
    <div class="container">
      <div class="se-body" set:html={articleContent} />
    </div>
  </section>

  <section class="se-cta-section">
    <div class="container">
      <div class="se-cta-box">
        <h2>{t.cta}</h2>
        <p>{locale === 'de' ? 'Unsere CT-Experten beraten Sie kostenlos & unverbindlich.' : 'Our CT experts are happy to advise you — free & non-binding.'}</p>
        <a href={lp('/kontakt')} class="btn btn-orange btn-lg">{t.cta}</a>
      </div>
    </div>
  </section>
</SerieLayout>

<style>
  .se-hero {
    background: linear-gradient(135deg, var(--background, #0f172a) 0%, var(--primary, #1e293b) 100%);
    color: white;
    padding: var(--space-20) 0 var(--space-16);
  }

  .se-breadcrumb {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: var(--space-6);
    display: flex;
    gap: var(--space-2);
    align-items: center;
    flex-wrap: wrap;
  }

  .se-breadcrumb a {
    color: var(--accent);
    text-decoration: none;
  }

  .se-breadcrumb a:hover { color: white; }

  .se-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    color: var(--accent);
    margin-bottom: var(--space-5);
    max-width: 820px;
    line-height: 1.1;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .se-hero h1 { font-size: var(--text-4xl); }
  }

  .se-lead {
    font-size: var(--text-xl);
    color: rgba(255, 255, 255, 0.72);
    max-width: 680px;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .se-hero-actions {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .se-badges {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .se-badge {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 4px var(--space-3);
    border: 1px solid rgba(249, 115, 22, 0.35);
    border-radius: var(--radius-full);
    color: rgba(255, 255, 255, 0.55);
    background: rgba(249, 115, 22, 0.1);
  }

  .se-article {
    padding: var(--space-16) 0 var(--space-20);
    background: var(--surface, #1e293b);
  }

  .se-body {
    max-width: 860px;
    margin: 0 auto;
  }

  .se-body :global(h2) {
    font-size: var(--text-3xl);
    font-family: var(--font-heading);
    color: var(--text, white);
    margin-top: var(--space-16);
    margin-bottom: var(--space-5);
    padding-left: var(--space-4);
    border-left: 4px solid var(--accent);
    line-height: 1.25;
    text-transform: uppercase;
  }

  .se-body :global(h2:first-child) { margin-top: 0; }

  .se-body :global(h3) {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    color: var(--text, white);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .se-body :global(h4) {
    font-size: var(--text-xl);
    font-family: var(--font-heading);
    color: var(--text, white);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .se-body :global(p) {
    font-size: var(--text-base);
    line-height: 1.85;
    margin-bottom: var(--space-5);
    color: var(--text-muted, rgba(255,255,255,0.7));
  }

  .se-body :global(ul),
  .se-body :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .se-body :global(li) {
    line-height: 1.75;
    margin-bottom: var(--space-2);
    color: var(--text-muted, rgba(255,255,255,0.7));
  }

  .se-body :global(ul > li::marker) { color: var(--accent); }

  .se-body :global(strong) {
    font-weight: 700;
    color: var(--text, white);
  }

  .se-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    margin: var(--space-8) 0;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .se-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(249, 115, 22, 0.35);
    text-underline-offset: 3px;
  }

  .se-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .se-body :global(blockquote) {
    border-left: 4px solid var(--accent);
    padding: var(--space-4) var(--space-6);
    background: rgba(249, 115, 22, 0.08);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    margin: var(--space-8) 0;
  }

  .se-body :global(blockquote p) {
    margin: 0;
    font-style: italic;
  }

  .se-cta-section {
    padding: var(--space-20) 0;
    background: var(--background, #0f172a);
  }

  .se-cta-box {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    background: var(--surface, #1e293b);
    padding: var(--space-12) var(--space-10);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(249, 115, 22, 0.2);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
  }

  .se-cta-box h2 {
    color: var(--text, white);
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
    border: none;
    padding: 0;
  }

  .se-cta-box p {
    color: var(--text-muted, rgba(255,255,255,0.6));
    font-size: var(--text-lg);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .btn-lg {
    padding: var(--space-4) var(--space-10);
    font-size: var(--text-lg);
  }
</style>
