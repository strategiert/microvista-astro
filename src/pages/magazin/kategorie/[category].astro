---
/**
 * Magazin Kategorie-Seite
 * Filtert Artikel nach Kategorie, SSR-Route (kein getStaticPaths nötig)
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import ArticleCard from '../../../components/sections/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { localePath, type Locale } from '../../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);
const preferredContentLocale = locale === 'de' ? 'de' : 'en';

const { category } = Astro.params;

const validCategories = ['technologie', 'branchen', 'case-studies', 'news', 'tipps'];
if (!category || !validCategories.includes(category)) {
  return Astro.redirect(lp('/magazin'));
}

// Alle Artikel laden und nach Kategorie filtern
const allPosts = await getCollection('magazin', ({ data }) => !data.draft);
const localizedPosts = allPosts.filter((post) => {
  if (preferredContentLocale === 'de') return !post.id.startsWith('en/');
  return post.id.startsWith('en/');
});
const posts = localizedPosts
  .filter(post => post.data.category === category)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

// Alle Kategorien für Filter-Nav
const allCategoryPosts = allPosts.filter((post) => {
  if (preferredContentLocale === 'de') return !post.id.startsWith('en/');
  return post.id.startsWith('en/');
});
const allCategories = [...new Set(allCategoryPosts.map(p => p.data.category))];

// SEO + UI Texte pro Kategorie und Sprache
const categoryContent = {
  technologie: {
    de: {
      title: 'Technologie & Innovation',
      description: 'CT-Technologie, KI-Auswertung und technische Innovationen in der industriellen Prüfung.',
      metaDescription: 'Fachartikel über CT-Technologie, KI-gestützte Auswertung und technische Innovationen in der industriellen Computertomographie.',
    },
    en: {
      title: 'Technology & Innovation',
      description: 'CT technology, AI-based analysis and technical innovations in industrial inspection.',
      metaDescription: 'Technical articles on CT technology, AI-based evaluation and innovations in industrial computed tomography.',
    },
  },
  branchen: {
    de: {
      title: 'Branchen & Anwendungen',
      description: 'Industrielle CT in Automotive, Medizintechnik, Luftfahrt und weiteren Branchen.',
      metaDescription: 'Branchenspezifische Anwendungen der industriellen Computertomographie in Automotive, Medizintechnik, Luftfahrt und mehr.',
    },
    en: {
      title: 'Industries & Applications',
      description: 'Industrial CT in automotive, medical technology, aerospace and other industries.',
      metaDescription: 'Industry-specific applications of industrial computed tomography in automotive, medical technology, aerospace and more.',
    },
  },
  'case-studies': {
    de: {
      title: 'Fallstudien & Referenzen',
      description: 'Praxisbeispiele: Wie Unternehmen industrielle CT-Prüfung erfolgreich einsetzen.',
      metaDescription: 'Fallstudien und Praxisbeispiele zum Einsatz industrieller Computertomographie in der Qualitätskontrolle.',
    },
    en: {
      title: 'Case Studies & References',
      description: 'Real-world examples: How companies successfully use industrial CT inspection.',
      metaDescription: 'Case studies and practical examples of industrial computed tomography use in quality control.',
    },
  },
  news: {
    de: {
      title: 'News & Aktuelles',
      description: 'Aktuelle Meldungen, Veranstaltungen und Neuigkeiten von Microvista.',
      metaDescription: 'Aktuelle News und Meldungen von Microvista — Industrielle Computertomographie und zerstörungsfreie Prüfung.',
    },
    en: {
      title: 'News & Updates',
      description: 'Latest news, events and updates from Microvista.',
      metaDescription: 'Latest news and updates from Microvista — industrial computed tomography and non-destructive testing.',
    },
  },
  tipps: {
    de: {
      title: 'Tipps & Tricks',
      description: 'Praxistipps, Anleitungen und Expertenwissen rund um industrielle Computertomographie.',
      metaDescription: 'Praktische Tipps und Expertenwissen für den optimalen Einsatz industrieller Computertomographie.',
    },
    en: {
      title: 'Tips & Tricks',
      description: 'Practical tips, guides and expert knowledge on industrial computed tomography.',
      metaDescription: 'Practical tips and expert knowledge for optimal use of industrial computed tomography.',
    },
  },
};

const contentLocale = locale === 'de' ? 'de' : 'en';
const catContent = categoryContent[category as keyof typeof categoryContent]?.[contentLocale as 'de' | 'en']
  ?? categoryContent[category as keyof typeof categoryContent]?.de;

const categoryLabels: Record<string, Record<string, string>> = {
  de: { technologie: 'Technologie', branchen: 'Branchen', 'case-studies': 'Case Studies', news: 'News', tipps: 'Tipps & Tricks' },
  en: { technologie: 'Technology', branchen: 'Industries', 'case-studies': 'Case Studies', news: 'News', tipps: 'Tips & Tricks' },
  fr: { technologie: 'Technologie', branchen: 'Secteurs', 'case-studies': 'Études de cas', news: 'Actualités', tipps: 'Trucs et astuces' },
  es: { technologie: 'Tecnología', branchen: 'Sectores', 'case-studies': 'Casos de estudio', news: 'Noticias', tipps: 'Consejos y trucos' },
  it: { technologie: 'Tecnologia', branchen: 'Settori', 'case-studies': 'Casi di studio', news: 'Notizie', tipps: 'Suggerimenti e trucchi' },
};
const labels = categoryLabels[locale] ?? categoryLabels.en;

const uiText: Record<string, Record<string, string>> = {
  de: { back: '← Alle Artikel', readMore: 'Weiterlesen', noArticles: 'Noch keine Artikel in dieser Kategorie.' },
  en: { back: '← All Articles', readMore: 'Read more', noArticles: 'No articles in this category yet.' },
  fr: { back: '← Tous les articles', readMore: 'Lire la suite', noArticles: 'Aucun article dans cette catégorie.' },
  es: { back: '← Todos los artículos', readMore: 'Leer más', noArticles: 'Aún no hay artículos en esta categoría.' },
  it: { back: '← Tutti gli articoli', readMore: 'Leggi di più', noArticles: 'Nessun articolo in questa categoria.' },
};
const ui = uiText[locale] ?? uiText.en;

const categoryColors: Record<string, string> = {
  technologie: '#32285b',
  branchen: '#00a0d2',
  'case-studies': '#ee7711',
  news: '#8ebfd6',
  tipps: '#4a3d7a',
};
---

<BaseLayout
  title={`${catContent?.title} | Microvista Magazin`}
  description={catContent?.metaDescription}
>
  <Header slot="header" />

  <main class="kategorie-page">
    <!-- Hero -->
    <section class="kategorie-hero" style={`--cat-accent: ${categoryColors[category] || 'var(--mv-violet)'}`}>
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href={lp('/magazin')}>{ui.back}</a>
        </nav>
        <span class="category-badge">{labels[category]}</span>
        <h1 class="hero-title">{catContent?.title}</h1>
        <p class="hero-subtitle">{catContent?.description}</p>
        <span class="article-count">{posts.length} {posts.length === 1 ? 'Artikel' : 'Artikel'}</span>
      </div>
      <div class="hero-pattern"></div>
    </section>

    <!-- Category Filter Nav -->
    <nav class="category-nav" aria-label="Kategorien">
      <div class="container">
        <div class="filter-scroll">
          <a href={lp('/magazin')} class="category-chip">
            {locale === 'de' ? 'Alle Artikel' : locale === 'en' ? 'All Articles' : 'Alle Artikel'}
          </a>
          {allCategories.map(cat => (
            <a
              href={lp(`/magazin/kategorie/${cat}`)}
              class:list={['category-chip', { active: cat === category }]}
              style={`--cat-color: ${categoryColors[cat] || '#32285b'}`}
            >
              {labels[cat] || cat}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Artikel -->
    <div class="container">
      {posts.length === 0 ? (
        <div class="empty-state">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <p>{ui.noArticles}</p>
        </div>
      ) : (
        <section class="posts-section">
          <div class="posts-grid">
            {posts.map(post => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                image={post.data.image}
                category={post.data.category}
                categoryLabel={labels[post.data.category] || post.data.category}
                publishDate={post.data.publishDate}
                slug={post.slug.replace(/^de\/|^en\//, '')}
                locale={locale}
                readMoreText={ui.readMore}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .kategorie-hero {
    position: relative;
    background: linear-gradient(135deg, var(--mv-violet) 0%, #1a1640 50%, #0f0c29 100%);
    padding: calc(var(--space-24) + 80px) 0 var(--space-16);
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(142, 191, 214, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(238, 119, 17, 0.08) 0%, transparent 40%);
    pointer-events: none;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
    position: relative;
    z-index: 1;
  }

  .breadcrumb {
    margin-bottom: var(--space-6);
  }

  .breadcrumb a {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color var(--transition-fast);
    letter-spacing: 0.05em;
  }

  .breadcrumb a:hover {
    color: var(--mv-blue);
  }

  .category-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--cat-accent, var(--mv-orange));
    color: var(--mv-white);
    margin-bottom: var(--space-4);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 700;
    color: var(--mv-white);
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: var(--space-6);
  }

  .article-count {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--mv-blue);
    letter-spacing: 0.1em;
  }

  /* Category Filter */
  .category-nav {
    background: var(--mv-white);
    border-bottom: 1px solid var(--mv-gray-100);
    padding: var(--space-4) 0;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .filter-scroll {
    display: flex;
    gap: var(--space-3);
    overflow-x: auto;
    padding-bottom: var(--space-2);
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filter-scroll::-webkit-scrollbar { display: none; }

  .category-chip {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition-fast);
    border: 2px solid var(--mv-gray-200);
    color: var(--mv-gray-600);
    background: var(--mv-white);
  }

  .category-chip:hover {
    border-color: var(--cat-color, var(--mv-violet));
    color: var(--cat-color, var(--mv-violet));
  }

  .category-chip.active {
    background: var(--cat-color, var(--mv-violet));
    border-color: var(--cat-color, var(--mv-violet));
    color: var(--mv-white);
  }

  /* Posts */
  .posts-section {
    padding: var(--space-12) 0 var(--space-20);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
  }

  /* Empty State */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-24) 0;
    color: var(--mv-gray-400);
    text-align: center;
  }

  .empty-state svg { opacity: 0.5; }
</style>
