---
/**
 * Branchen Index - Visuell aufgewertet
 * Moderne Übersicht aller Branchen mit Bento-Grid
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import BranchenHero from '../../components/sections/BranchenHero.astro';
import BranchenCard from '../../components/sections/BranchenCard.astro';
import { getCollection } from 'astro:content';
import { localePath, type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

// Branchen-Daten laden
const branchen = await getCollection('branchen');

const content = {
  de: {
    title: 'Branchen',
    subtitle: 'CT-Lösungen für Ihre Branche',
    description: 'Jede Branche hat spezifische Anforderungen an die Qualitätsprüfung. Entdecken Sie maßgeschneiderte CT-Lösungen für Ihren Anwendungsbereich.',
    cta: 'Mehr erfahren',
    ctaTitle: 'Ihre Branche nicht dabei?',
    ctaText: 'CT-Technologie ist vielseitig einsetzbar. Kontaktieren Sie uns für eine individuelle Beratung zu Ihren spezifischen Anforderungen.',
    ctaButton: 'Beratung anfragen',
    trustTitle: 'Vertraut von führenden Unternehmen',
    statsTitle: 'Microvista in Zahlen',
    industriesLabel: 'Branchen',
    experienceLabel: 'Jahre Erfahrung',
    countriesLabel: 'Länder'
  },
  en: {
    title: 'Industries',
    subtitle: 'CT solutions for your industry',
    description: 'Every industry has specific quality inspection requirements. Discover tailored CT solutions for your application area.',
    cta: 'Learn more',
    ctaTitle: 'Your industry not listed?',
    ctaText: 'CT technology is versatile. Contact us for individual consultation on your specific requirements.',
    ctaButton: 'Request consultation',
    trustTitle: 'Trusted by leading companies',
    statsTitle: 'Microvista in Numbers',
    industriesLabel: 'Industries',
    experienceLabel: 'Years Experience',
    countriesLabel: 'Countries'
  }
};

const t = content[locale as keyof typeof content] || content.de;

// Sort and organize industries
const sortedBranchen = branchen.sort((a, b) => a.data.name.localeCompare(b.data.name));

// Trust badges
const trustBadges = ['ISO 9001', 'ISO 17025', 'NADCAP', 'FDA Ready'];

// Stats
const stats = [
  { value: '14+', label: t.industriesLabel },
  { value: '15', label: t.experienceLabel },
  { value: '20+', label: t.countriesLabel }
];
---

<BaseLayout
  title={t.title}
  description={t.description}
>
  <Header slot="header" />

  <main class="branchen-page">
    <!-- Hero -->
    <BranchenHero
      title={t.title}
      subtitle={t.subtitle}
      description={t.description}
      locale={locale}
    />

    <!-- Stats Bar -->
    <section class="stats-bar">
      <div class="container">
        <div class="stats-row">
          {stats.map(stat => (
            <div class="stat-box">
              <span class="stat-number">{stat.value}</span>
              <span class="stat-text">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Branchen Grid -->
    <section class="branchen-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Unsere Branchenexpertise</h2>
          <p class="section-subtitle">Von Automotive bis zur Medizintechnik – wir kennen die spezifischen Anforderungen Ihrer Branche</p>
        </div>
        
        <div class="branchen-grid">
          {sortedBranchen.map((branche, index) => (
            <BranchenCard
              slug={branche.id}
              name={branche.data.name}
              description={branche.data.description}
              heroImage={branche.data.heroImage}
              icon={branche.id}
              locale={locale}
              ctaText={t.cta}
              featured={index === 0}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Visual Feature Section -->
    <section class="feature-section">
      <div class="container">
        <div class="feature-grid">
          <div class="feature-image">
            <img src="/images/branchen/automotive.jpg" alt="CT-Prüfung in Aktion" />
            <div class="image-badge">
              <span>⚡ Express-Service</span>
            </div>
          </div>
          <div class="feature-content">
            <h2>Flexibel. Schnell. Überall.</h2>
            <p>Egal ob im Labor oder direkt vor Ort – unser ScanExpress bringt die CT-Prüfung zu Ihnen. Ohne Transportrisiko, ohne Verzögerung.</p>
            <ul class="feature-list">
              <li>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="m4.5 10 3.5 3.5 7-7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Mobiles CT bis 798 mm Hüllkreis
              </li>
              <li>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="m4.5 10 3.5 3.5 7-7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                24-48h Express-Verfügbarkeit
              </li>
              <li>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="m4.5 10 3.5 3.5 7-7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Akkreditiert nach ISO 17025
              </li>
            </ul>
            <a href={lp('/serie/scanexpress')} class="feature-cta">
              ScanExpress entdecken
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Section -->
    <section class="trust-section">
      <div class="container">
        <p class="trust-title">{t.trustTitle}</p>
        <div class="trust-badges">
          {trustBadges.map(badge => (
            <span class="trust-badge">{badge}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <div class="cta-content">
            <h2>{t.ctaTitle}</h2>
            <p>{t.ctaText}</p>
            <a href={lp('/kontakt-beratung')} class="cta-button">
              {t.ctaButton}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
          <div class="cta-decoration">
            <div class="decoration-circle"></div>
            <div class="decoration-circle"></div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .branchen-page {
    background: var(--mv-white);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  /* Stats Bar */
  .stats-bar {
    background: linear-gradient(135deg, var(--mv-violet) 0%, #1a1640 100%);
    padding: var(--space-8) 0;
    margin-top: -1px;
  }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: var(--space-12);
    flex-wrap: wrap;
  }

  .stat-box {
    text-align: center;
    color: var(--mv-white);
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--mv-orange);
    line-height: 1;
  }

  .stat-text {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Branchen Section */
  .branchen-section {
    padding: var(--space-20) 0;
    background: linear-gradient(180deg, var(--mv-gray-50) 0%, var(--mv-white) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    font-weight: 700;
    color: var(--mv-violet);
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    font-size: var(--text-lg);
    color: var(--mv-gray-600);
    max-width: 600px;
    margin: 0 auto;
  }

  .branchen-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .branchen-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Feature Section */
  .feature-section {
    padding: var(--space-20) 0;
    background: var(--mv-white);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .feature-image {
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(50, 40, 91, 0.25);
  }

  .feature-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  .image-badge {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: var(--mv-orange);
    color: var(--mv-white);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .feature-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    font-weight: 700;
    color: var(--mv-violet);
    margin-bottom: var(--space-4);
  }

  .feature-content > p {
    font-size: var(--text-lg);
    color: var(--mv-gray-600);
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .feature-list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--mv-gray-700);
  }

  .feature-list svg {
    color: var(--mv-orange);
    flex-shrink: 0;
  }

  .feature-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--mv-violet);
    color: var(--mv-white);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .feature-cta:hover {
    background: var(--mv-violet-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(50, 40, 91, 0.3);
  }

  .feature-cta svg {
    transition: transform 0.3s ease;
  }

  .feature-cta:hover svg {
    transform: translateX(4px);
  }

  /* Trust Section */
  .trust-section {
    padding: var(--space-12) 0;
    border-top: 1px solid var(--mv-gray-100);
    text-align: center;
  }

  .trust-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--mv-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .trust-badge {
    padding: var(--space-2) var(--space-4);
    background: var(--mv-gray-100);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--mv-gray-600);
  }

  /* CTA Section */
  .cta-section {
    padding: var(--space-16) 0 var(--space-20);
  }

  .cta-box {
    position: relative;
    background: linear-gradient(135deg, var(--mv-violet) 0%, #1a1640 100%);
    border-radius: var(--radius-2xl);
    padding: var(--space-10) var(--space-8);
    overflow: hidden;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
  }

  .cta-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 4vw, var(--text-3xl));
    font-weight: 700;
    color: var(--mv-white);
    margin-bottom: var(--space-4);
  }

  .cta-content p {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--mv-orange);
    color: var(--mv-white);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background: var(--mv-orange-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(238, 119, 17, 0.4);
  }

  .cta-decoration {
    position: absolute;
    right: -50px;
    top: 50%;
    transform: translateY(-50%);
  }

  .decoration-circle {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.1);
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
  }

  .decoration-circle:nth-child(2) {
    width: 280px;
    height: 280px;
    right: -40px;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .stats-row {
      gap: var(--space-6);
    }

    .branchen-grid {
      grid-template-columns: 1fr;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .feature-image {
      order: -1;
    }

    .cta-box {
      padding: var(--space-8) var(--space-6);
    }

    .cta-decoration {
      display: none;
    }
  }
</style>
