---
/**
 * Branchen Detail - Vollständiges 9-Sektionen Template
 * Basierend auf Content-Konzept März 2026
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { localePath, type Locale } from '../../i18n/translations';

const { slug } = Astro.params;
const branchen = await getCollection('branchen');
const branche = branchen.find(b => b.id === slug);
const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

// 404 if not found
if (!branche) {
  return Astro.redirect('/404');
}

const data = branche.data;

// UI Translations
const ui = {
  de: {
    kicker: 'Branchenlösung',
    contactBtn: 'Beratung anfragen',
    labBtn: 'Labor-Services',
    expressBtn: 'Express buchen',
    back: 'Alle Branchen',
    challengesTitle: 'Diese Herausforderungen kennen wir',
    solutionsTitle: `Unsere CT-Lösungen für ${data.name}`,
    useCasesTitle: 'Anwendungsfälle',
    statsTitle: 'Key Facts',
    servicesTitle: 'Unsere Service-Optionen',
    ctaTitle: 'Bereit für die nächste Prüfaufgabe?',
    ctaSubtitle: 'Kontaktieren Sie uns für eine unverbindliche Beratung zu Ihren spezifischen Anforderungen.',
    trustBadges: ['ISO 9001', 'ISO 17025', 'NADCAP', 'FDA Ready'],
    services: {
      labor: { title: 'CT-Labor', desc: 'Hochauflösende Prüfung im akkreditierten Labor', when: 'Für Einzelprüfungen, Erstmuster und komplexe Analysen' },
      scanexpress: { title: 'ScanExpress', desc: 'Mobiles CT direkt bei Ihnen vor Ort', when: 'Für Großbauteile, Serienprüfung und Express-Service' },
      cloud: { title: 'Cloud-Auswertung', desc: 'Flexible Auswertung Ihrer CT-Daten', when: 'Für eigene Auswertung, Rohdaten-Export und Kollaboration' }
    }
  },
  en: {
    kicker: 'Industry Solution',
    contactBtn: 'Request Consultation',
    labBtn: 'Lab Services',
    expressBtn: 'Book Express',
    back: 'All Industries',
    challengesTitle: 'Challenges We Know',
    solutionsTitle: `Our CT Solutions for ${data.name}`,
    useCasesTitle: 'Use Cases',
    statsTitle: 'Key Facts',
    servicesTitle: 'Our Service Options',
    ctaTitle: 'Ready for your next inspection task?',
    ctaSubtitle: 'Contact us for a no-obligation consultation regarding your specific requirements.',
    trustBadges: ['ISO 9001', 'ISO 17025', 'NADCAP', 'FDA Ready'],
    services: {
      labor: { title: 'CT Lab', desc: 'High-resolution testing in accredited lab', when: 'For single tests, first articles and complex analyses' },
      scanexpress: { title: 'ScanExpress', desc: 'Mobile CT directly at your site', when: 'For large parts, serial inspection and express service' },
      cloud: { title: 'Cloud Analysis', desc: 'Flexible analysis of your CT data', when: 'For self-analysis, raw data export and collaboration' }
    }
  }
}[locale] || ui.de;

const t = ui;

// Industry colors
const industryColors: Record<string, string> = {
  'automotive': '#32285b',
  'luftfahrt': '#8b5cf6',
  'elektronik': '#00a0d2',
  'medizintechnik': '#10b981',
  'kunststofftechnik': '#f59e0b',
  'windenergie': '#06b6d4',
  'maschinenbau': '#6366f1',
  'forschung-entwicklung': '#ec4899',
  'additive-fertigung': '#06b6d4',
  'e-mobilitaet': '#10b981',
  'eisenguss': '#64748b',
  'leichtmetallguss': '#00a0d2',
  'werkstoffpruefung': '#f59e0b',
  'archaeologie': '#8b5cf6'
};

const accentColor = industryColors[slug as string] || '#32285b';
---

<BaseLayout
  title={data.seo?.title || `${data.name} | Microvista`}
  description={data.seo?.description || data.description}
>
  <Header slot="header" />

  <article class="branche-page">
    <!-- 1. HERO SECTION -->
    <section class="branche-hero" style={`--accent: ${accentColor};`}>
      <div class="hero-bg">
        <div class="gradient-orb"></div>
        <div class="grid-pattern"></div>
      </div>
      
      <div class="container">
        <nav class="hero-breadcrumb">
          <a href={lp('/branchen')} class="breadcrumb-link">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15.833 10H4.167m0 0L10 15.833M4.167 10L10 4.167" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {t.back}
          </a>
        </nav>
        
        <div class="hero-content">
          <div class="hero-kicker">
            <span class="kicker-label">{t.kicker}</span>
            <div class="trust-badges-small">
              {t.trustBadges.map(badge => <span class="badge">{badge}</span>)}
            </div>
          </div>
          <h1 class="hero-title">{data.name}</h1>
          <p class="hero-description">{data.description}</p>
          
          <div class="hero-actions">
            <a href={lp('/kontakt-beratung')} class="btn-primary">
              {t.contactBtn}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href={lp('/labor-ct-pruefung')} class="btn-secondary">
              {t.labBtn}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. PAIN POINTS SECTION -->
    {data.challenges && data.challenges.length > 0 && (
      <section class="pain-section">
        <div class="container">
          <h2 class="section-title">{t.challengesTitle}</h2>
          <div class="pain-grid">
            {data.challenges.map((challenge: any) => (
              <div class="pain-card">
                <div class="pain-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <p class="pain-text">{challenge.title}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 3. SOLUTIONS SECTION -->
    {data.solutions && data.solutions.length > 0 && (
      <section class="solutions-section" style={`--accent: ${accentColor};`}>
        <div class="container">
          <h2 class="section-title">{t.solutionsTitle}</h2>
          <div class="solutions-grid">
            {data.solutions.map((solution: any) => (
              <div class="solution-card">
                <div class="solution-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                </div>
                <h3>{solution.title}</h3>
                <p>{solution.description}</p>
              </div>
            ))}
          </div>
          <div class="section-cta">
            <a href={lp('/express-ct-inspektion')} class="btn-accent">
              {t.expressBtn}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- 4. USE CASES SECTION -->
    {data.useCases && data.useCases.length > 0 && (
      <section class="usecases-section">
        <div class="container">
          <h2 class="section-title">{t.useCasesTitle}</h2>
          <div class="usecases-grid">
            {data.useCases.map((useCase: string) => (
              <div class="usecase-card" style={`--accent: ${accentColor};`}>
                <div class="usecase-bullet"></div>
                <p>{useCase}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 5. STATS SECTION -->
    {data.stats && data.stats.length > 0 && (
      <section class="stats-section" style={`--accent: ${accentColor};`}>
        <div class="container">
          <h2 class="section-title light">{t.statsTitle}</h2>
          <div class="stats-grid">
            {data.stats.map((stat: any) => (
              <div class="stat-item">
                <span class="stat-value">{stat.value}</span>
                <span class="stat-label">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 6. TESTIMONIAL SECTION -->
    {data.quote && (
      <section class="testimonial-section">
        <div class="container">
          <div class="testimonial-card">
            <svg class="quote-icon" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <blockquote>{data.quote.text}</blockquote>
            <cite>— {data.quote.author}</cite>
          </div>
        </div>
      </section>
    )}

    <!-- 7. SERVICE OPTIONS SECTION -->
    <section class="services-section" style={`--accent: ${accentColor};`}>
      <div class="container">
        <h2 class="section-title">{t.servicesTitle}</h2>
        <div class="services-grid">
          <a href={lp('/labor-ct-pruefung')} class="service-card">
            <div class="service-icon labor-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M10 2v7.31"/><path d="M14 2v7.31"/><path d="M8.5 2h7"/><path d="M14 12.5a2.5 2.5 0 0 0-5 0v4a2.5 2.5 0 0 0 5 0z"/>
                <path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z"/>
              </svg>
            </div>
            <h3>{t.services.labor.title}</h3>
            <p class="service-desc">{t.services.labor.desc}</p>
            <p class="service-when">{t.services.labor.when}</p>
            <span class="service-link">Mehr erfahren →</span>
          </a>
          
          <a href={lp('/serie/scanexpress')} class="service-card featured">
            <div class="service-badge">Express verfügbar</div>
            <div class="service-icon scanexpress-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/>
              </svg>
            </div>
            <h3>{t.services.scanexpress.title}</h3>
            <p class="service-desc">{t.services.scanexpress.desc}</p>
            <p class="service-when">{t.services.scanexpress.when}</p>
            <span class="service-link">Mehr erfahren →</span>
          </a>
          
          <a href={lp('/cloud')} class="service-card">
            <div class="service-icon cloud-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17.5 19c0-1.7-1.3-3-3-3h-3.5"/><path d="M17.5 19c1.7 0 3-1.3 3-3s-1.3-3-3-3h-1"/>
                <path d="M6.5 13c-1.7 0-3 1.3-3 3s1.3 3 3 3h1"/><path d="M6.5 13h1c1.7 0 3-1.3 3-3s-1.3-3-3-3"/>
                <path d="M12 13v3"/><circle cx="12" cy="7" r="5"/>
              </svg>
            </div>
            <h3>{t.services.cloud.title}</h3>
            <p class="service-desc">{t.services.cloud.desc}</p>
            <p class="service-when">{t.services.cloud.when}</p>
            <span class="service-link">Mehr erfahren →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- 7. CTA SECTION -->
    <section class="cta-section" style={`--accent: ${accentColor};`}>
      <div class="container">
        <div class="cta-box">
          <h2>{t.ctaTitle}</h2>
          <p>{t.ctaSubtitle}</p>
          <div class="cta-actions">
            <a href={lp('/kontakt-beratung')} class="cta-btn primary">
              {t.contactBtn}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href={lp('/express-ct-inspektion')} class="cta-btn secondary">
              {t.expressBtn}
            </a>
          </div>
          <p class="usp-reminder">
            <span class="usp-highlight">GET YOUR INSPECTION DONE</span><br/>
            Anywhere. Anytime. Fast.
          </p>
        </div>
      </div>
    </section>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .branche-page {
    background: var(--mv-white);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  /* HERO */
  .branche-hero {
    position: relative;
    padding: calc(var(--space-16) + 80px) 0 var(--space-12);
    background: linear-gradient(135deg, var(--accent) 0%, #1a1640 100%);
    color: var(--mv-white);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .gradient-orb {
    position: absolute;
    width: 500px;
    height: 500px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    filter: blur(100px);
    top: -200px;
    right: -200px;
  }

  .grid-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0);
    background-size: 40px 40px;
  }

  .hero-breadcrumb {
    position: relative;
    margin-bottom: var(--space-8);
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .breadcrumb-link:hover {
    color: var(--mv-white);
  }

  .hero-content {
    position: relative;
    max-width: 700px;
  }

  .hero-kicker {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .kicker-label {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mv-blue);
  }

  .trust-badges-small {
    display: flex;
    gap: var(--space-2);
  }

  .badge {
    padding: var(--space-1) var(--space-2);
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 700;
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--mv-orange);
    color: var(--mv-white);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--mv-orange-hover);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: rgba(255, 255, 255, 0.1);
    color: var(--mv-white);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* PAIN POINTS */
  .pain-section {
    padding: var(--space-16) 0;
    background: var(--mv-gray-50);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 700;
    color: var(--mv-violet);
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .section-title.light {
    color: var(--mv-white);
  }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }

  .pain-card {
    background: var(--mv-white);
    border: 2px solid var(--mv-gray-100);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    transition: all var(--transition-base);
  }

  .pain-card:hover {
    border-color: #ef4444;
    transform: translateY(-4px);
  }

  .pain-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: rgba(239, 68, 68, 0.1);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ef4444;
  }

  .pain-text {
    font-size: var(--text-sm);
    color: var(--mv-gray-700);
    line-height: 1.5;
    margin: 0;
  }

  /* SOLUTIONS */
  .solutions-section {
    padding: var(--space-16) 0;
    background: linear-gradient(180deg, var(--mv-white) 0%, var(--mv-gray-50) 100%);
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .solution-card {
    background: var(--mv-white);
    border: 2px solid var(--mv-gray-100);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    transition: all var(--transition-base);
  }

  .solution-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .solution-icon {
    width: 48px;
    height: 48px;
    background: rgba(16, 185, 129, 0.1);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #10b981;
    margin-bottom: var(--space-4);
  }

  .solution-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--mv-gray-900);
    margin-bottom: var(--space-2);
  }

  .solution-card p {
    font-size: var(--text-sm);
    color: var(--mv-gray-600);
    line-height: 1.6;
    margin: 0;
  }

  .section-cta {
    text-align: center;
    margin-top: var(--space-10);
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-8);
    background: var(--mv-orange);
    color: var(--mv-white);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-accent:hover {
    background: var(--mv-orange-hover);
    transform: translateY(-2px);
  }

  /* TESTIMONIAL */
  .testimonial-section {
    padding: var(--space-16) 0;
    background: linear-gradient(135deg, var(--mv-violet) 0%, #1a1640 100%);
  }

  .testimonial-card {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    color: var(--mv-white);
  }

  .quote-icon {
    color: var(--mv-orange);
    opacity: 0.5;
    margin-bottom: var(--space-4);
  }

  .testimonial-card blockquote {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-lg), 3vw, var(--text-xl));
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: var(--space-6);
    color: var(--mv-white);
  }

  .testimonial-card cite {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    font-style: normal;
  }

  /* USE CASES */
  .usecases-section {
    padding: var(--space-16) 0;
    background: var(--mv-white);
  }

  .usecases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .usecase-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--mv-gray-50);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--accent);
  }

  .usecase-bullet {
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    margin-top: 8px;
    flex-shrink: 0;
  }

  .usecase-card p {
    font-size: var(--text-sm);
    color: var(--mv-gray-700);
    margin: 0;
    line-height: 1.5;
  }

