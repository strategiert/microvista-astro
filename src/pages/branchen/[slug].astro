---
/**
 * Branchen Detail - Redesign
 * Moderne Branchen-Detailseite
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { localePath, type Locale } from '../../i18n/translations';

const { slug } = Astro.params;
const branchen = await getCollection('branchen');
const branche = branchen.find(b => (b.data.slug || b.id) === slug) || null;
const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

const ui = {
  de: {
    industries: 'Branchen',
    heroPrefix: 'CT-Lösungen für',
    challenges: 'Ihre Herausforderungen',
    solutions: 'Unsere Lösungen',
    applications: 'Anwendungen',
    stats: 'Key Facts',
    contactBtn: 'Beratung anfragen',
    labBtn: 'Labor-Services',
    back: 'Alle Branchen'
  },
  en: {
    industries: 'Industries',
    heroPrefix: 'CT solutions for',
    challenges: 'Your Challenges',
    solutions: 'Our Solutions',
    applications: 'Applications',
    stats: 'Key Facts',
    contactBtn: 'Request Consultation',
    labBtn: 'Lab Services',
    back: 'All Industries'
  },
  fr: {
    industries: 'Secteurs',
    heroPrefix: 'Solutions CT pour',
    challenges: 'Vos défis',
    solutions: 'Nos solutions',
    applications: 'Applications',
    stats: 'Faits clés',
    contactBtn: 'Demander une consultation',
    labBtn: 'Services labo',
    back: 'Tous les secteurs'
  },
  es: {
    industries: 'Sectores',
    heroPrefix: 'Soluciones CT para',
    challenges: 'Sus desafíos',
    solutions: 'Nuestras soluciones',
    applications: 'Aplicaciones',
    stats: 'Datos clave',
    contactBtn: 'Solicitar consulta',
    labBtn: 'Servicios de laboratorio',
    back: 'Todos los sectores'
  },
  it: {
    industries: 'Settori',
    heroPrefix: 'Soluzioni CT per',
    challenges: 'Le tue sfide',
    solutions: 'Le nostre soluzioni',
    applications: 'Applicazioni',
    stats: 'Dati chiave',
    contactBtn: 'Richiedi consulenza',
    labBtn: 'Servizi di laboratorio',
    back: 'Tutti i settori'
  }
}[locale] || ui.en;

// Fallback-Daten
const fallbackData: Record<string, any> = {
  automotive: {
    name: 'Automotive', description: 'CT-Prüflösungen für die Automobilindustrie',
    challenges: [
      { title: 'Komplexe Geometrien', description: 'Gussteile und Verbundwerkstoffe mit inneren Strukturen' },
      { title: 'Null-Fehler-Toleranz', description: 'Höchste Qualitätsanforderungen für sicherheitskritische Bauteile' },
      { title: 'Hohe Stückzahlen', description: '100% Prüfung bei maximaler Taktzeit' }
    ],
    solutions: [
      { title: 'Inline-CT', description: 'Vollautomatische Prüfung direkt in der Produktionslinie' },
      { title: 'KI-Auswertung', description: 'Automatische Fehlererkennung ohne manuelle Eingriffe' },
      { title: 'Porositätsanalyse', description: 'Präzise Messung von Lunker und Poren in Gussteilen' }
    ],
    useCases: ['Gussteile', 'Schweißnähte', 'Batteriezellen', 'Elektronik', 'Kunststoffteile'],
    stats: [
      { value: '<3s', label: 'pro Bauteil' },
      { value: '99.9%', label: 'Erkennungsrate' },
      { value: '24/7', label: 'Produktion' }
    ],
    color: '#32285b'
  },
  luftfahrt: {
    name: 'Luftfahrt', description: 'Zertifizierte CT-Prüfung für Aerospace-Komponenten',
    challenges: [
      { title: 'Strenge Zertifizierung', description: 'NADCAP und EN/AS 9100 Anforderungen' },
      { title: 'Sicherheitskritische Bauteile', description: 'Null-Toleranz bei Defekten in Triebwerkskomponenten' },
      { title: 'Komplexe Materialien', description: 'CFK, Titan und Hochtemperaturlegierungen' }
    ],
    solutions: [
      { title: 'Zertifizierte Prüfung', description: 'NADCAP-akkreditierte CT-Analysen' },
      { title: 'Hochauflösung', description: 'Sub-Mikrometer Auflösung für kleinste Defekte' },
      { title: 'Dokumentation', description: 'Lückenlose Rückverfolgbarkeit und Reporting' }
    ],
    useCases: ['Turbinenschaufeln', 'Strukturbauteile', 'CFK-Komponenten', 'Triebwerksteile', 'Fahrwerke'],
    stats: [
      { value: 'NADCAP', label: 'zertifiziert' },
      { value: '<1µm', label: 'Auflösung' },
      { value: '100%', label: 'Rückverfolgung' }
    ],
    color: '#8b5cf6'
  },
  elektronik: {
    name: 'Elektronik', description: 'Präzise CT-Analyse für elektronische Baugruppen',
    challenges: [
      { title: 'Miniaturisierung', description: 'Immer kleinere Strukturen und dichtere Packaging' },
      { title: 'Versteckte Defekte', description: 'Lötfehler unter BGAs und in Vias' },
      { title: 'Hohe Taktung', description: 'Schnelle Prüfung in der SMT-Linie' }
    ],
    solutions: [
      { title: 'Nano-CT', description: 'Höchste Auflösung für Mikroelektronik' },
      { title: 'BGA-Inspektion', description: 'Automatische Lötstellenanalyse' },
      { title: 'Inline-Integration', description: 'Direkte Anbindung an SMT-Linien' }
    ],
    useCases: ['Leiterplatten', 'BGA/CSP', 'Bonddrähte', 'Halbleiter', 'Steckverbinder'],
    stats: [
      { value: '500nm', label: 'Auflösung' },
      { value: '<10s', label: 'pro Board' },
      { value: '99.5%', label: 'Erkennungsrate' }
    ],
    color: '#00a0d2'
  },
  medizintechnik: {
    name: 'Medizintechnik', description: 'Validierte CT-Prüfung für Medizinprodukte',
    challenges: [
      { title: 'Regulatorische Anforderungen', description: 'FDA 21 CFR Part 11, MDR, ISO 13485' },
      { title: 'Biokompatibilität', description: 'Keine Kontamination der Prüfteile' },
      { title: 'Validierung', description: 'Dokumentierte und validierte Prüfprozesse' }
    ],
    solutions: [
      { title: 'Validierte Prozesse', description: 'IQ/OQ/PQ-dokumentierte Prüfabläufe' },
      { title: 'Reinraum-fähig', description: 'Saubere Probenhandhabung' },
      { title: 'Compliance-Reporting', description: 'Regulatorisch konforme Dokumentation' }
    ],
    useCases: ['Implantate', 'Instrumente', 'Spritzen', 'Katheter', 'Dentaltechnik'],
    stats: [
      { value: 'ISO 13485', label: 'konform' },
      { value: '100%', label: 'Dokumentation' },
      { value: 'FDA', label: 'ready' }
    ],
    color: '#10b981'
  },
  kunststoff: {
    name: 'Kunststoffverarbeitung', description: 'CT-Analyse für Spritzguss und Kunststoffverarbeitung',
    challenges: [
      { title: 'Innere Strukturen', description: 'Lunker, Einfallstellen und Bindenähte' },
      { title: 'Faserorientierung', description: 'Analyse von GFK/CFK Füllung' },
      { title: 'Maßhaltigkeit', description: 'Verzug und Schwindung messen' }
    ],
    solutions: [
      { title: 'Defektanalyse', description: 'Automatische Erkennung typischer Spritzgussfehler' },
      { title: 'Faseranalyse', description: 'Orientierung und Verteilung von Fasern' },
      { title: 'Soll-Ist-Vergleich', description: 'CAD-Vergleich für Maßhaltigkeit' }
    ],
    useCases: ['Spritzguss', 'Blasformen', 'Extrusionsteile', 'Verbundwerkstoffe', 'Schäume'],
    stats: [
      { value: '3D', label: 'Analyse' },
      { value: 'µm', label: 'Genauigkeit' },
      { value: '100%', label: 'zerstörungsfrei' }
    ],
    color: '#f59e0b'
  },
  energie: {
    name: 'Energie & Batterien', description: 'CT-Prüfung für Batterien und Energiespeicher',
    challenges: [
      { title: 'Sicherheit', description: 'Defekte können zu thermischen Events führen' },
      { title: 'Elektrodenqualität', description: 'Beschichtung, Falten und Kontamination' },
      { title: 'Serienprüfung', description: '100% Prüfung jeder Zelle' }
    ],
    solutions: [
      { title: 'Inline-CT', description: 'Vollautomatische Zellenprüfung' },
      { title: 'Defekterkennung', description: 'Partikel, Falten, Delaminierung' },
      { title: 'Alterungsanalyse', description: 'CT vor und nach Zyklisierung' }
    ],
    useCases: ['Lithium-Ionen-Zellen', 'Festkörperbatterien', 'Brennstoffzellen', 'Kondensatoren', 'Windkraftkomponenten'],
    stats: [
      { value: '<5s', label: 'pro Zelle' },
      { value: '100%', label: 'Prüfung' },
      { value: '24/7', label: 'Betrieb' }
    ],
    color: '#ee7711'
  }
};

const data = fallbackData[slug as string] || {
  name: slug,
  description: 'Branchenspezifische CT-Lösungen',
  challenges: [], solutions: [], useCases: [], stats: [],
  color: '#32285b'
};

const accentColor = data.color || '#32285b';
---

<BaseLayout
  title={`${data.name} | ${ui.industries}`}
  description={data.description}
>
  <Header slot="header" />

  <article class="branche-page">
    <!-- Hero -->
    <section class="branche-hero" style={`--accent: ${accentColor};`}>
      <div class="hero-bg">
        <div class="gradient-orb"></div>
        <div class="grid-pattern"></div>
      </div>
      
      <div class="container">
        <nav class="hero-breadcrumb">
          <a href={lp('/branchen')} class="breadcrumb-link">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15.833 10H4.167m0 0L10 15.833M4.167 10L10 4.167" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {ui.back}
          </a>
        </nav>
        
        <div class="hero-content">
          <span class="hero-prefix">{ui.heroPrefix}</span>
          <h1 class="hero-title">{data.name}</h1>
          <p class="hero-description">{data.description}</p>
          
          <div class="hero-actions">
            <a href={lp('/kontakt')} class="btn-primary">
              {ui.contactBtn}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href={lp('/labor')} class="btn-secondary">
              {ui.labBtn}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    {data.stats && data.stats.length > 0 && (
      <section class="stats-section" style={`--accent: ${accentColor};`}>
        <div class="container">
          <div class="stats-grid">
            {data.stats.map((stat: any) => (
              <div class="stat-item">
                <span class="stat-value">{stat.value}</span>
                <span class="stat-label">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Challenges -->
    {data.challenges && data.challenges.length > 0 && (
      <section class="content-section">
        <div class="container">
          <h2 class="section-title">{ui.challenges}</h2>
          <div class="cards-grid">
            {data.challenges.map((challenge: any) => (
              <div class="content-card challenge-card">
                <div class="card-icon problem-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <h3>{challenge.title}</h3>
                <p>{challenge.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Solutions -->
    {data.solutions && data.solutions.length > 0 && (
      <section class="content-section bg-alt" style={`--accent: ${accentColor};`}>
        <div class="container">
          <h2 class="section-title">{ui.solutions}</h2>
          <div class="cards-grid">
            {data.solutions.map((solution: any) => (
              <div class="content-card solution-card">
                <div class="card-icon solution-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                </div>
                <h3>{solution.title}</h3>
                <p>{solution.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Use Cases -->
    {data.useCases && data.useCases.length > 0 && (
      <section class="content-section">
        <div class="container">
          <h2 class="section-title">{ui.applications}</h2>
          <div class="tags-cloud">
            {data.useCases.map((useCase: string) => (
              <span class="tag-item" style={`--accent: ${accentColor};`}>{useCase}</span>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bottom-cta" style={`--accent: ${accentColor};`}>
      <div class="container">
        <div class="cta-content">
          <h2>Bereit für die nächste Prüfaufgabe?</h2>
          <p>Kontaktieren Sie uns für eine unverbindliche Beratung zu Ihren spezifischen Anforderungen.</p>
          <div class="cta-actions">
            <a href={lp('/kontakt')} class="cta-btn primary">
              {ui.contactBtn}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href={lp('/branchen')} class="cta-btn secondary">
              {ui.back}
            </a>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .branche-page {
    background: var(--mv-white);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  /* Hero */
  .branche-hero {
    position: relative;
    padding: calc(var(--space-16) + 80px) 0 var(--space-12);
    background: linear-gradient(135deg, var(--accent) 0%, #1a1640 100%);
    color: var(--mv-white);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .gradient-orb {
    position: absolute;
    width: 500px;
    height: 500px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    filter: blur(100px);
    top: -200px;
    right: -200px;
  }

  .grid-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0);
    background-size: 40px 40px;
  }

  .hero-breadcrumb {
    position: relative;
    margin-bottom: var(--space-8);
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .breadcrumb-link:hover {
    color: var(--mv-white);
  }

  .hero-content {
    position: relative;
    max-width: 700px;
  }

  .hero-prefix {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mv-blue);
    margin-bottom: var(--space-2);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 700;
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--mv-orange);
    color: var(--mv-white);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--mv-orange-hover);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: rgba(255, 255, 255, 0.1);
    color: var(--mv-white);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Stats */
  .stats-section {
    background: var(--accent);
    padding: var(--space-8) 0;
    margin-top: -1px;
  }

  .stats-grid {
    display: flex;
    justify-content: center;
    gap: var(--space-12);
    flex-wrap: wrap;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--mv-white);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
  }

  /* Content Sections */
  .content-section {
    padding: var(--space-16) 0;
  }

  .bg-alt {
    background: linear-gradient(180deg, var(--mv-gray-50) 0%, var(--mv-white) 100%);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 700;
    color: var(--mv-violet);
    margin-bottom: var(--space-8);
    text-align: center;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .content-card {
    background: var(--mv-white);
    border: 2px solid var(--mv-gray-100);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    transition: all var(--transition-base);
  }

  .content-card:hover {
    border-color: var(--mv-gray-200);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .card-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
  }

  .problem-icon {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }

  .solution-icon {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
  }

  .content-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--mv-gray-900);
    margin-bottom: var(--space-2);
  }

  .content-card p {
    font-size: var(--text-sm);
    color: var(--mv-gray-600);
    line-height: 1.6;
    margin: 0;
  }

  /* Tags Cloud */
  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .tag-item {
    padding: var(--space-3) var(--space-5);
    background: var(--mv-white);
    border: 2px solid var(--mv-gray-100);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--mv-gray-700);
    transition: all var(--transition-base);
  }

  .tag-item:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  /* Bottom CTA */
  .bottom-cta {
    padding: var(--space-16) 0 var(--space-20);
    background: linear-gradient(135deg, var(--mv-violet) 0%, #1a1640 100%);
    color: var(--mv-white);
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .cta-content p {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-8);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .cta-btn.primary {
    background: var(--mv-orange);
    color: var(--mv-white);
  }

  .cta-btn.primary:hover {
    background: var(--mv-orange-hover);
    transform: translateY(-2px);
  }

  .cta-btn.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: var(--mv-white);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .cta-btn.secondary:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .branche-hero {
      padding: calc(var(--space-12) + 60px) 0 var(--space-8);
    }

    .stats-grid {
      gap: var(--space-6);
    }

    .stat-value {
      font-size: var(--text-2xl);
    }

    .content-section {
      padding: var(--space-10) 0;
    }
  }
</style>
