---
/**
 * Branchen Detail - Visuell aufgewertet mit mehr Bildern
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { localePath, type Locale } from '../../i18n/translations';

const { slug } = Astro.params;
const branchen = await getCollection('branchen');
const branche = branchen.find(b => b.id === slug);
const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

if (!branche) {
  return Astro.redirect('/404');
}

const data = branche.data;
const heroImage = data.heroImage || `/images/branchen/${slug}.jpg`;
const getBranchenImage = (id: string, image?: string) => image || `/images/branchen/${id}.jpg`;

const ui = {
  de: {
    kicker: 'Branchenlösung',
    contactBtn: 'Beratung anfragen',
    labBtn: 'Labor-Services',
    expressBtn: 'Express buchen',
    back: 'Alle Branchen',
    challengesTitle: 'Diese Herausforderungen kennen wir',
    solutionsTitle: `Unsere CT-Lösungen für ${data.name}`,
    useCasesTitle: 'Anwendungsfälle',
    statsTitle: 'Key Facts',
    servicesTitle: 'Unsere Service-Optionen',
    ctaTitle: 'Bereit für die nächste Prüfaufgabe?',
    ctaSubtitle: 'Kontaktieren Sie uns für eine unverbindliche Beratung zu Ihren spezifischen Anforderungen.',
    trustBadges: ['ISO 9001', 'ISO 17025', 'NADCAP', 'FDA Ready'],
    services: {
      labor: { title: 'CT-Labor', desc: 'Hochauflösende Prüfung im akkreditierten Labor', when: 'Für Einzelprüfungen, Erstmuster und komplexe Analysen' },
      scanexpress: { title: 'ScanExpress', desc: 'Mobiles CT direkt bei Ihnen vor Ort', when: 'Für Großbauteile, Serienprüfung und Express-Service' },
      cloud: { title: 'Cloud-Auswertung', desc: 'Flexible Auswertung Ihrer CT-Daten', when: 'Für eigene Auswertung, Rohdaten-Export und Kollaboration' }
    }
  }
}[locale] || ui.de;

const t = ui;

const industryColors: Record<string, string> = {
  'automotive': '#32285b', 'luftfahrt': '#8b5cf6', 'elektronik': '#00a0d2', 'medizintechnik': '#10b981',
  'kunststofftechnik': '#f59e0b', 'windenergie': '#06b6d4', 'maschinenbau': '#6366f1', 'forschung-entwicklung': '#ec4899',
  'additive-fertigung': '#06b6d4', 'e-mobilitaet': '#10b981', 'eisenguss': '#64748b', 'leichtmetallguss': '#00a0d2',
  'werkstoffpruefung': '#f59e0b', 'archaeologie': '#8b5cf6'
};

const accentColor = industryColors[slug as string] || '#32285b';

// Get related industries for gallery
const relatedBranchen = branchen.filter(b => b.id !== slug).slice(0, 3);
---

<BaseLayout title={data.seo?.title || `${data.name} | Microvista`} description={data.seo?.description || data.description}>
  <Header slot="header" />

  <article class="branche-page">
    <!-- HERO with Background Image -->
    <section class="branche-hero" style={`--accent: ${accentColor};`}>
      <div class="hero-image-bg">
        <img src={heroImage} alt={data.name} />
        <div class="hero-gradient"></div>
      </div>
      
      <div class="container">
        <nav class="hero-breadcrumb">
          <a href={lp('/branchen')} class="breadcrumb-link">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15.833 10H4.167m0 0L10 15.833M4.167 10L10 4.167" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {t.back}
          </a>
        </nav>
        
        <div class="hero-content">
          <div class="hero-kicker">
            <span class="kicker-label">{t.kicker}</span>
            <div class="trust-badges-small">
              {t.trustBadges.map(badge => <span class="badge">{badge}</span>)}
            </div>
          </div>
          <h1 class="hero-title">{data.name}</h1>
          <p class="hero-description">{data.description}</p>
          
          <div class="hero-actions">
            <a href={lp('/kontakt-beratung')} class="btn-primary">
              {t.contactBtn}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href={lp('/labor-ct-pruefung')} class="btn-secondary">
              {t.labBtn}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- PAIN POINTS with Icons -->
    {data.challenges && data.challenges.length > 0 && (
      <section class="pain-section">
        <div class="container">
          <div class="section-header">
            <span class="section-eyebrow" style={`color: ${accentColor}`}>Herausforderungen</span>
            <h2 class="section-title">{t.challengesTitle}</h2>
          </div>
          <div class="pain-grid">
            {data.challenges.map((challenge: any, idx: number) => (
              <div class="pain-card" style={`--index: ${idx}`}>
                <div class="pain-number">0{idx + 1}</div>
                <div class="pain-content">
                  <p class="pain-text">{challenge.title}</p>
                  {challenge.description && challenge.description.length > 20 && (
                    <p class="pain-description">{challenge.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- SOLUTIONS with Image -->
    {data.solutions && data.solutions.length > 0 && (
      <section class="solutions-section" style={`--accent: ${accentColor};`}>
        <div class="container">
          <div class="solutions-layout">
            <div class="solutions-content">
              <div class="section-header">
                <span class="section-eyebrow">Lösungen</span>
                <h2 class="section-title">{t.solutionsTitle}</h2>
              </div>
              <div class="solutions-list">
                {data.solutions.map((solution: any, idx: number) => (
                  <div class="solution-item">
                    <div class="solution-marker"></div>
                    <div class="solution-text">
                      <h3>{solution.title}</h3>
                      <p>{solution.description}</p>
                    </div>
                  </div>
                ))}
              </div>
              <a href={lp('/express-ct-inspektion')} class="btn-accent">
                {t.expressBtn}
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
            <div class="solutions-visual">
              <div class="solutions-image-wrapper">
                <img src={heroImage} alt={data.name} class="solutions-image" />
                <div class="solutions-overlay"></div>
                <div class="solutions-badge">
                  <span>Individuelle Lösung</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- USE CASES Gallery -->
    {data.useCases && data.useCases.length > 0 && (
      <section class="usecases-section">
        <div class="container">
          <div class="section-header centered">
            <span class="section-eyebrow" style={`color: ${accentColor}`}>Praxisbeispiele</span>
            <h2 class="section-title">{t.useCasesTitle}</h2>
          </div>
          <div class="usecases-grid">
            {data.useCases.map((useCase: string, idx: number) => (
              <div class="usecase-card" style={`--accent: ${accentColor}; --index: ${idx}`}>
                <div class="usecase-image">
                  <img src={heroImage} alt={useCase} />
                  <div class="usecase-overlay"></div>
                </div>
                <div class="usecase-content">
                  <span class="usecase-number">{String(idx + 1).padStart(2, '0')}</span>
                  <p>{useCase}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- TESTIMONIAL -->
    {data.quote && (
      <section class="testimonial-section" style={`--accent: ${accentColor};`}>
        <div class="container">
          <div class="testimonial-card">
            <div class="quote-icon">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
            </div>
            <blockquote>{data.quote.text}</blockquote>
            <cite>— {data.quote.author}</cite>
          </div>
        </div>
      </section>
    )}

    <!-- STATS Bento Grid -->
    {data.stats && data.stats.length > 0 && (
      <section class="stats-section" style={`--accent: ${accentColor};`}>
        <div class="container">
          <div class="section-header centered">
            <span class="section-eyebrow light">Überzeugende Zahlen</span>
            <h2 class="section-title light">{t.statsTitle}</h2>
          </div>
          <div class="stats-bento">
            {data.stats.map((stat: any, idx: number) => (
              <div class={`stat-box stat-box-${idx}`}>
                <span class="stat-value">{stat.value}</span>
                <span class="stat-label">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- SERVICES -->
    <section class="services-section" style={`--accent: ${accentColor};`}>
      <div class="container">
        <div class="section-header centered">
          <span class="section-eyebrow">Services</span>
          <h2 class="section-title">{t.servicesTitle}</h2>
        </div>
        <div class="services-grid">
          <a href={lp('/labor-ct-pruefung')} class="service-card">
            <div class="service-icon labor-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M10 2v7.31"/><path d="M14 2v7.31"/><path d="M8.5 2h7"/><path d="M14 12.5a2.5 2.5 0 0 0-5 0v4a2.5 2.5 0 0 0 5 0z"/>
                <path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z"/>
              </svg>
            </div>
            <h3>{t.services.labor.title}</h3>
            <p class="service-desc">{t.services.labor.desc}</p>
            <p class="service-when">{t.services.labor.when}</p>
            <span class="service-link">Mehr erfahren →</span>
          </a>
          
          <a href={lp('/serie/scanexpress')} class="service-card featured">
            <div class="service-badge">⚡ Express</div>
            <div class="service-icon scanexpress-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/>
              </svg>
            </div>
            <h3>{t.services.scanexpress.title}</h3>
            <p class="service-desc">{t.services.scanexpress.desc}</p>
            <p class="service-when">{t.services.scanexpress.when}</p>
            <span class="service-link">Mehr erfahren →</span>
          </a>
          
          <a href={lp('/cloud')} class="service-card">
            <div class="service-icon cloud-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17.5 19c0-1.7-1.3-3-3-3h-3.5"/><path d="M17.5 19c1.7 0 3-1.3 3-3s-1.3-3-3-3h-1"/>
                <path d="M6.5 13c-1.7 0-3 1.3-3 3s1.3 3 3 3h1"/><path d="M6.5 13h1c1.7 0 3-1.3 3-3s-1.3-3-3-3"/>
                <path d="M12 13v3"/><circle cx="12" cy="7" r="5"/>
              </svg>
            </div>
            <h3>{t.services.cloud.title}</h3>
            <p class="service-desc">{t.services.cloud.desc}</p>
            <p class="service-when">{t.services.cloud.when}</p>
            <span class="service-link">Mehr erfahren →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- RELATED INDUSTRIES Gallery -->
    <section class="related-section">
      <div class="container">
        <div class="section-header centered">
          <span class="section-eyebrow" style={`color: ${accentColor}`}>Entdecken Sie mehr</span>
          <h2 class="section-title">Weitere Branchen</h2>
        </div>
        <div class="related-grid">
          {relatedBranchen.map((related) => (
            <a href={lp(`/branchen/${related.id}`)} class="related-card">
              <div class="related-image">
                <img src={getBranchenImage(related.id, related.data.heroImage)} alt={related.data.name} />
                <div class="related-overlay"></div>
              </div>
              <div class="related-content">
                <h3>{related.data.name}</h3>
                <span>Mehr erfahren →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section" style={`--accent: ${accentColor};`}>
      <div class="container">
        <div class="cta-box">
          <h2>{t.ctaTitle}</h2>
          <p>{t.ctaSubtitle}</p>
          <div class="cta-actions">
            <a href={lp('/kontakt-beratung')} class="cta-btn primary">
              {t.contactBtn}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.167 10h11.666m0 0L10 4.167M15.833 10L10 15.833" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href={lp('/express-ct-inspektion')} class="cta-btn secondary">
              {t.expressBtn}
            </a>
          </div>
          <p class="usp-reminder">
            <span class="usp-highlight">GET YOUR INSPECTION DONE</span><br/>
            Anywhere. Anytime. Fast.
          </p>
        </div>
      </div>
    </section>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .branche-page {
    --accent: var(--mv-violet);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  /* HERO with Image Background */
  .branche-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: flex-end;
    color: var(--mv-white);
    overflow: hidden;
  }

  .hero-image-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 22, 64, 0.98) 0%,
      rgba(26, 22, 64, 0.8) 40%,
      rgba(50, 40, 91, 0.4) 70%,
      rgba(50, 40, 91, 0.2) 100%
    );
  }

  .hero-breadcrumb {
    position: relative;
    margin-bottom: var(--space-6);
    padding-top: calc(var(--space-16) + 60px);
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .breadcrumb-link:hover {
    color: var(--mv-white);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    padding-bottom: var(--space-16);
  }

  .hero-kicker {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .kicker-label {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mv-orange);
  }

  .trust-badges-small {
    display: flex;
    gap: var(--space-2);
  }

  .badge {
    padding: var(--space-1) var(--space-2);
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 700;
    margin-bottom: var(--space-4);
    line-height: 1.1;
    color: var(--mv-white);
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  .hero-description {
    font-size: clamp(var(--text-base), 2vw, var(--text-xl));
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--mv-orange);
    color: var(--mv-white);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: var(--mv-orange-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(238, 119, 17, 0.4);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: rgba(255, 255, 255, 0.1);
    color: var(--mv-white);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Section Headers */
  .section-header {
    margin-bottom: var(--space-10);
  }

  .section-header.centered {
    text-align: center;
  }

  .section-eyebrow {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .section-eyebrow.light {
    color: rgba(255, 255, 255, 0.7);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 700;
    color: var(--mv-violet);
  }

  .section-title.light {
    color: var(--mv-white);
  }

  /* PAIN POINTS */
  .pain-section {
    padding: var(--space-20) 0;
    background: var(--mv-gray-50);
  }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .pain-card {
    background: var(--mv-white);
    border: 1px solid var(--mv-gray-100);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    gap: var(--space-4);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .pain-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: #ef4444;
  }

  .pain-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .pain-number {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: #ef4444;
    opacity: 0.5;
    line-height: 1;
  }

  .pain-text {
    font-size: var(--text-base);
    color: var(--mv-gray-700);
    line-height: 1.5;
    margin: 0;
  }

  .pain-description {
    font-size: var(--text-sm);
    color: var(--mv-gray-500);
    line-height: 1.6;
    margin: var(--space-2) 0 0;
  }

  /* SOLUTIONS with Image */
  .solutions-section {
    padding: var(--space-20) 0;
    background: var(--mv-white);
  }

  .solutions-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .solutions-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .solution-item {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--mv-gray-50);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--accent);
  }

  .solution-marker {
    width: 12px;
    height: 12px;
    background: var(--accent);
    border-radius: 50%;
    margin-top: 6px;
    flex-shrink: 0;
  }

  .solution-text h3 {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--mv-gray-900);
    margin-bottom: var(--space-1);
  }

  .solution-text p {
    font-size: var(--text-sm);
    color: var(--mv-gray-600);
    margin: 0;
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--mv-orange);
    color: var(--mv-white);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-accent:hover {
    background: var(--mv-orange-hover);
