---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { localePath, type Locale } from '../../i18n/translations';
import { serviceSchema, breadcrumbSchema } from '../../components/seo/schemas';
import { getPruefaufgabenForBranche } from '../../lib/cross-links';

const { slug } = Astro.params;
const branchen = await getCollection('branchen');
const branche = branchen.find(b => b.id === slug);
const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

if (!branche) {
  return Astro.redirect('/404');
}

const data = branche.data;
const accentColor = '#32285b';
const related = branchen.filter(b => b.id !== slug).slice(0, 3);
const heroImage = data.heroImage || `/images/branchen/${slug}.jpg`;

// Cross-Links zu relevanten Prüfaufgaben
const pruefaufgaben = await getCollection('pruefaufgaben');
const relatedPruefaufgabenSlugs = getPruefaufgabenForBranche(slug ?? '');
const relatedPruefaufgaben = relatedPruefaufgabenSlugs
  .map(s => pruefaufgaben.find(p => p.data.slug === s))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

// Schema.org: Service + Breadcrumb
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://microvista.de';
const brancheUrl = `${siteUrl}${lp(`/branchen/${slug}`)}`;
const pageSchemas = [
  serviceSchema({
    name: data.name,
    description: data.description,
    url: brancheUrl,
    image: `${siteUrl}${heroImage}`,
    serviceType: 'Industrielle Computertomographie',
  }),
  breadcrumbSchema([
    { name: 'Home', url: `${siteUrl}${lp('/')}` },
    { name: 'Branchen', url: `${siteUrl}${lp('/branchen')}` },
    { name: data.name, url: brancheUrl },
  ]),
];
---

<BaseLayout
  title={data.seo?.title || `${data.name} | Microvista`}
  description={data.seo?.description || data.description}
  schema={pageSchemas}
>
  <Header slot="header" />

  <main class="branche-page">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg">
        <img src={heroImage} alt={`Industrielle CT-Prüfung für ${data.name}`} loading="eager" fetchpriority="high" />
        <div class="hero-overlay"></div>
      </div>
      <div class="container">
        <a href={lp('/branchen')} class="back-link">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15.833 10H4.167m0 0L10 15.833M4.167 10L10 4.167" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Alle Branchen
        </a>
        <div class="hero-content">
          <span class="hero-eyebrow">Branchenlösung</span>
          <h1 class="hero-title">{data.name}</h1>
          <p class="hero-desc">{data.description}</p>
          <div class="hero-badges">
            <span class="badge">ISO 9001</span>
            <span class="badge">ISO 17025</span>
            <span class="badge">NADCAP</span>
            <span class="badge">FDA Ready</span>
          </div>
          <div class="hero-actions">
            <a href={lp('/kontakt')} class="btn btn-primary">Beratung anfragen</a>
            <a href={lp('/express-ct-inspektion')} class="btn btn-secondary">Express buchen</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Challenges -->
    {data.challenges && (
      <section class="section section-gray">
        <div class="container">
          <div class="section-header">
            <span class="eyebrow">Die Herausforderungen</span>
            <h2 class="section-title">Diese Probleme kennen wir</h2>
          </div>
          <div class="challenges-grid">
            {data.challenges.map((c, i) => (
              <div class="challenge-card">
                <div class="challenge-num">{String(i + 1).padStart(2, '0')}</div>
                <h3>{c.title}</h3>
                <p>{c.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Solutions -->
    {data.solutions && (
      <section class="section">
        <div class="container">
          <div class="section-header">
            <span class="eyebrow">Unsere Antwort</span>
            <h2 class="section-title">CT-Lösungen für {data.name}</h2>
          </div>
          <div class="solutions-list">
            {data.solutions.map((s, i) => (
              <div class="solution-item">
                <div class="solution-marker">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <div class="solution-content">
                  <h3>{s.title}</h3>
                  <p>{s.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Use Cases -->
    {data.useCases && (
      <section class="section section-dark">
        <div class="container">
          <div class="section-header light">
            <span class="eyebrow light">Praxisbeispiele</span>
            <h2 class="section-title light">Anwendungsfälle</h2>
          </div>
          <div class="usecases-list">
            {data.useCases.map((u, i) => (
              <div class="usecase-item">
                <span class="usecase-num">{String(i + 1).padStart(2, '0')}</span>
                <p>{u}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Quote -->
    {data.quote && (
      <section class="section section-accent">
        <div class="container narrow">
          <blockquote class="quote">
            <svg class="quote-icon" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <p>{data.quote.text}</p>
            <cite>— {data.quote.author}</cite>
          </blockquote>
        </div>
      </section>
    )}

    <!-- Stats -->
    {data.stats && (
      <section class="section">
        <div class="container">
          <div class="section-header centered">
            <span class="eyebrow">Fakten</span>
            <h2 class="section-title">Überzeugende Zahlen</h2>
          </div>
          <div class="stats-grid">
            {data.stats.map((s) => (
              <div class="stat-card">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Services -->
    <section class="section section-gray">
      <div class="container">
        <div class="section-header centered">
          <span class="eyebrow">Services</span>
          <h2 class="section-title">So arbeiten wir</h2>
        </div>
        <div class="services-grid">
          <a href={lp('/labor-ct-pruefung')} class="service-card">
            <div class="service-icon purple">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 2v7.31"/><path d="M14 2v7.31"/><path d="M8.5 2h7"/><path d="M14 12.5a2.5 2.5 0 0 0-5 0v4a2.5 2.5 0 0 0 5 0z"/>
                <path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z"/>
              </svg>
            </div>
            <h3>CT-Labor</h3>
            <p>Hochauflösende Prüfung im akkreditierten Labor für Einzelprüfungen und Erstmuster.</p>
            <span class="link-arrow">Mehr erfahren →</span>
          </a>
          <a href={lp('/dienstleistungen/scanexpress')} class="service-card featured">
            <span class="featured-badge">Express verfügbar</span>
            <div class="service-icon orange">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/>
              </svg>
            </div>
            <h3>ScanExpress</h3>
            <p>Mobiles CT direkt bei Ihnen vor Ort für Großbauteile und schnelle Serienprüfung.</p>
            <span class="link-arrow">Mehr erfahren →</span>
          </a>
          <a href={lp('/software')} class="service-card">
            <div class="service-icon blue">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.5 19c0-1.7-1.3-3-3-3h-3.5"/><path d="M17.5 19c1.7 0 3-1.3 3-3s-1.3-3-3-3h-1"/>
              </svg>
            </div>
            <h3>Cloud-Auswertung</h3>
            <p>Flexible Auswertung Ihrer CT-Daten mit unserer sicheren Cloud-Plattform.</p>
            <span class="link-arrow">Mehr erfahren →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Passende Prüfaufgaben -->
    {relatedPruefaufgaben.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section-header centered">
            <span class="eyebrow">Prüfaufgaben</span>
            <h2 class="section-title">Passende Prüfaufgaben für {data.name}</h2>
          </div>
          <div class="pruefaufgaben-grid">
            {relatedPruefaufgaben.map((p) => (
              <a href={lp(`/pruefaufgaben/${p.data.slug}`)} class="pruefaufgabe-card">
                <h3>{p.data.name}</h3>
                <p>{p.data.description}</p>
                <span class="link-arrow">Prüfaufgabe öffnen →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Related Branchen -->
    <section class="section">
      <div class="container">
        <div class="section-header centered">
          <span class="eyebrow">Entdecken</span>
          <h2 class="section-title">Weitere Branchen</h2>
        </div>
        <div class="related-grid">
          {related.map((r) => (
            <a href={lp(`/branchen/${r.id}`)} class="related-card">
              <img src={r.data.heroImage || `/images/branchen/${r.id}.jpg`} alt={r.data.name} />
              <div class="related-overlay"></div>
              <span class="related-name">{r.data.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section-cta">
      <div class="container narrow centered">
        <h2 class="cta-title">Bereit für die nächste Prüfaufgabe?</h2>
        <p class="cta-text">Kontaktieren Sie uns für eine unverbindliche Beratung zu Ihren spezifischen Anforderungen.</p>
        <div class="cta-actions">
          <a href={lp('/kontakt')} class="btn btn-primary btn-large">Beratung anfragen</a>
          <a href={lp('/express-ct-inspektion')} class="btn btn-outline btn-large">Express buchen</a>
        </div>
        <p class="usp">GET YOUR INSPECTION DONE<br/><span>Anywhere. Anytime. Fast.</span></p>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Base */
  .branche-page {
    --accent: #32285b;
    --accent-light: #f3f0ff;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .container.narrow {
    max-width: 800px;
  }

  .container.centered {
    text-align: center;
  }

  /* Hero */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: flex-end;
    color: white;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,22,64,0.95) 0%, rgba(26,22,64,0.7) 50%, rgba(50,40,91,0.4) 100%);
  }

  .hero .container {
    position: relative;
    z-index: 1;
    padding-bottom: 80px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: white;
  }

  .hero-eyebrow {
    display: block;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ee7711;
    margin-bottom: 12px;
  }

  .hero-title {
    font-family: var(--font-heading, system-ui);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 20px;
    color: white;
    text-shadow: 0 2px 30px rgba(0,0,0,0.5);
  }

  .hero-desc {
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.6;
    color: rgba(255,255,255,0.9);
    max-width: 700px;
    margin-bottom: 24px;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
  }

  .badge {
    padding: 6px 12px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 24px;
    border-radius: 8px;
    font-family: var(--font-heading, system-ui);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: #ee7711;
    color: white;
  }

  .btn-primary:hover {
    background: #d66a0d;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: rgba(255,255,255,0.15);
    color: white;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.25);
  }

  .btn-outline {
    background: transparent;
    color: white;
    border: 2px solid rgba(255,255,255,0.5);
  }

  .btn-outline:hover {
    background: rgba(255,255,255,0.1);
    border-color: white;
  }

  .btn-large {
    padding: 16px 32px;
    font-size: 16px;
  }

  /* Sections */
  .section {
    padding: 80px 0;
  }

  .section-gray {
    background: #f8f9fa;
  }

  .section-dark {
    background: #1a1640;
    color: white;
  }

  .section-accent {
    background: var(--accent);
    color: white;
  }

  .section-cta {
    background: linear-gradient(135deg, #1a1640 0%, #32285b 100%);
    color: white;
    text-align: center;
  }

  /* Section Header */
  .section-header {
    margin-bottom: 48px;
  }

  .section-header.centered,
  .section-header.light {
    text-align: center;
  }

  .eyebrow {
    display: block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ee7711;
    margin-bottom: 8px;
  }

  .eyebrow.light {
    color: rgba(255,255,255,0.7);
  }

  .section-title {
    font-family: var(--font-heading, system-ui);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 700;
    color: #1a1640;
    line-height: 1.2;
  }

  .section-title.light {
    color: white;
  }

  /* Challenges */
  .challenges-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }

  .challenge-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 28px;
    transition: all 0.2s;
  }

  .challenge-card:hover {
    border-color: #ee7711;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  .challenge-num {
    font-family: var(--font-heading, system-ui);
    font-size: 32px;
    font-weight: 700;
    color: #ee7711;
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 12px;
  }

  .challenge-card h3 {
    font-size: 17px;
    font-weight: 600;
    color: #1a1640;
    margin-bottom: 12px;
    line-height: 1.4;
  }

  .challenge-card p {
    font-size: 14px;
    line-height: 1.6;
    color: #4b5563;
    margin: 0;
  }

  /* Solutions */
  .solutions-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 900px;
  }

  .solution-item {
    display: flex;
    gap: 20px;
    padding: 24px;
    background: #f8f9fa;
    border-radius: 12px;
    border-left: 4px solid #32285b;
  }

  .solution-marker {
    width: 28px;
    height: 28px;
    background: #10b981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
  }

  .solution-content h3 {
    font-size: 18px;
    font-weight: 600;
    color: #1a1640;
    margin-bottom: 8px;
  }

  .solution-content p {
    font-size: 15px;
    line-height: 1.6;
    color: #4b5563;
    margin: 0;
  }

  /* Use Cases */
  .usecases-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .usecase-item {
    display: flex;
    gap: 20px;
    padding: 24px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
  }

  .usecase-num {
    font-family: var(--font-heading, system-ui);
    font-size: 24px;
    font-weight: 700;
    color: #ee7711;
    line-height: 1;
  }

  .usecase-item p {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255,255,255,0.85);
    margin: 0;
  }

  /* Quote */
  .quote {
    text-align: center;
  }

  .quote-icon {
    color: #ee7711;
    opacity: 0.5;
    margin-bottom: 24px;
  }

  .quote p {
    font-family: var(--font-heading, system-ui);
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 24px;
    color: white;
  }

  .quote cite {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    font-style: normal;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .stat-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    transition: all 0.2s;
  }

  .stat-card:hover {
    border-color: #32285b;
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  }

  .stat-value {
    display: block;
    font-family: var(--font-heading, system-ui);
    font-size: 40px;
    font-weight: 700;
    color: #32285b;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 14px;
    color: #6b7280;
  }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .service-card {
    position: relative;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 32px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .service-card:hover {
    border-color: #32285b;
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  }

  .service-card.featured {
    border-color: #ee7711;
    box-shadow: 0 0 0 1px #ee7711;
  }

  .featured-badge {
    position: absolute;
    top: -10px;
    right: 20px;
    background: #ee7711;
    color: white;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .service-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .service-icon.purple {
    background: #f3f0ff;
    color: #32285b;
  }

  .service-icon.orange {
    background: #fff4eb;
    color: #ee7711;
  }

  .service-icon.blue {
    background: #e6f7ff;
    color: #00a0d2;
  }

  .service-card h3 {
    font-size: 20px;
    font-weight: 700;
    color: #1a1640;
    margin-bottom: 12px;
  }

  .service-card p {
    font-size: 14px;
    line-height: 1.6;
    color: #4b5563;
    margin-bottom: 20px;
  }

  .link-arrow {
    font-size: 14px;
    font-weight: 600;
    color: #32285b;
  }

  .service-card:hover .link-arrow {
    color: #ee7711;
  }

  /* Passende Prüfaufgaben */
  .pruefaufgaben-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .pruefaufgabe-card {
    display: flex;
    flex-direction: column;
