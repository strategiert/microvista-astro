---
/**
 * Wiki Artikel - Detailseite Redesign
 * Modernes Glossar-Layout mit Sidebar-Navigation
 */
import { render } from 'astro:content';
import { localePath, type Locale } from '../../i18n/translations';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import WikiSidebar from '../../components/sections/WikiSidebar.astro';
import { findLocalizedWikiEntry, getLocalizedWiki, getSlugBase } from '../../lib/wiki';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

const { slug } = Astro.params;
if (!slug) return Astro.redirect(lp('/wiki'));
const entry = await findLocalizedWikiEntry(slug, locale);
if (!entry) return Astro.redirect(lp('/wiki'));
const { Content } = await render(entry);
const currentSlug = getSlugBase(entry.id);

const uiByLocale = {
  de: {
    wiki: 'Lexikon',
    definition: 'Definition',
    synonyms: 'Synonyme',
    related: 'Verwandte Begriffe',
    category: 'Kategorie',
    back: 'Zurück zum Lexikon',
    tags: 'Tags'
  },
  en: {
    wiki: 'Glossary',
    definition: 'Definition',
    synonyms: 'Synonyms',
    related: 'Related Terms',
    category: 'Category',
    back: 'Back to Glossary',
    tags: 'Tags'
  },
  fr: {
    wiki: 'Glossaire',
    definition: 'Définition',
    synonyms: 'Synonymes',
    related: 'Termes associés',
    category: 'Catégorie',
    back: 'Retour au glossaire',
    tags: 'Tags'
  },
  es: {
    wiki: 'Glosario',
    definition: 'Definición',
    synonyms: 'Sinónimos',
    related: 'Términos relacionados',
    category: 'Categoría',
    back: 'Volver al glosario',
    tags: 'Etiquetas'
  },
  it: {
    wiki: 'Glossario',
    definition: 'Definizione',
    synonyms: 'Sinonimi',
    related: 'Termini correlati',
    category: 'Categoria',
    back: 'Torna al glossario',
    tags: 'Tag'
  }
};

const ui = uiByLocale[locale as keyof typeof uiByLocale] || uiByLocale.en;

const categoryLabels: Record<string, string> = {
  'grundlagen': { de: 'CT-Grundlagen', en: 'CT Basics', fr: 'Bases CT', es: 'Fundamentos CT', it: 'Fondamenti CT' }[locale] || 'CT Basics',
  'verfahren': { de: 'Verfahren', en: 'Methods', fr: 'Méthodes', es: 'Métodos', it: 'Metodi' }[locale] || 'Methods',
  'qm': { de: 'Qualitätsmanagement', en: 'Quality Management', fr: 'Management qualité', es: 'Gestión de calidad', it: 'Gestione qualità' }[locale] || 'Quality Management',
  'materialien': { de: 'Materialien', en: 'Materials', fr: 'Matériaux', es: 'Materiales', it: 'Materiali' }[locale] || 'Materials',
  'normen': { de: 'Normen & Standards', en: 'Standards', fr: 'Normes', es: 'Normas', it: 'Norme' }[locale] || 'Standards',
  'software': 'Software',
  'hardware': 'Hardware',
  'allgemein': { de: 'Allgemein', en: 'General', fr: 'Général', es: 'General', it: 'Generale' }[locale] || 'General'
};

const categoryColors: Record<string, { bg: string; text: string; border: string }> = {
  'grundlagen': { bg: 'rgba(50, 40, 91, 0.08)', text: '#32285b', border: '#32285b' },
  'verfahren': { bg: 'rgba(0, 160, 210, 0.08)', text: '#00a0d2', border: '#00a0d2' },
  'qm': { bg: 'rgba(238, 119, 17, 0.08)', text: '#ee7711', border: '#ee7711' },
  'materialien': { bg: 'rgba(16, 185, 129, 0.08)', text: '#10b981', border: '#10b981' },
  'normen': { bg: 'rgba(139, 92, 246, 0.08)', text: '#8b5cf6', border: '#8b5cf6' },
  'software': { bg: 'rgba(6, 182, 212, 0.08)', text: '#06b6d4', border: '#06b6d4' },
  'hardware': { bg: 'rgba(245, 158, 11, 0.08)', text: '#f59e0b', border: '#f59e0b' },
  'allgemein': { bg: 'rgba(100, 116, 139, 0.08)', text: '#64748b', border: '#64748b' },
};

const catColors = categoryColors[entry.data.category] || categoryColors['allgemein'];

// Schema.org
const definitionSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": entry.data.term,
  "description": entry.data.definition,
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": "Microvista CT-Lexikon"
  }
};

// Sidebar entries
const entries = await getLocalizedWiki(locale);
const sidebarEntries = entries
  .sort((a, b) => a.data.term.localeCompare(b.data.term, locale))
  .map(e => ({
    slug: getSlugBase(e.id),
    term: e.data.term,
    category: e.data.category
  }));
---

<BaseLayout
  title={`${entry.data.term} | ${ui.wiki}`}
  description={entry.data.definition}
  schema={definitionSchema}
>
  <Header slot="header" />

  <div class="wiki-layout">
    <!-- Sidebar Navigation -->
    <WikiSidebar
      entries={sidebarEntries}
      currentSlug={currentSlug}
      categories={categoryLabels}
      locale={locale}
      title={ui.wiki}
    />

    <!-- Main Content -->
    <main class="wiki-main">
      <article class="wiki-article">
        <!-- Article Header -->
        <header class="article-header" style={`--cat-color: ${catColors.text}; --cat-bg: ${catColors.bg}; --cat-border: ${catColors.border};`}>
          <nav class="article-breadcrumb">
            <a href={lp('/wiki')} class="breadcrumb-link">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15.833 10H4.167m0 0L10 15.833M4.167 10L10 4.167" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {ui.wiki}
            </a>
          </nav>

          <div class="article-meta">
            <span class="category-badge" style={`background: ${catColors.bg}; color: ${catColors.text};`}>
              {categoryLabels[entry.data.category] || entry.data.category}
            </span>
          </div>

          <h1 class="article-title">{entry.data.term}</h1>

          <!-- Definition Box -->
          <div class="definition-box">
            <span class="definition-label">{ui.definition}</span>
            <p class="definition-text">{entry.data.definition}</p>
          </div>

          <!-- Synonyms -->
          {entry.data.synonyms && entry.data.synonyms.length > 0 && (
            <div class="synonyms-box">
              <span class="synonyms-label">{ui.synonyms}:</span>
              <div class="synonyms-list">
                {entry.data.synonyms.map(synonym => (
                  <span class="synonym-tag">{synonym}</span>
                ))}
              </div>
            </div>
          )}
        </header>

        <!-- Article Content -->
        <div class="article-content prose">
          <Content />
        </div>

        <!-- Related Terms -->
        {entry.data.relatedTerms && entry.data.relatedTerms.length > 0 && (
          <footer class="article-footer">
            <h2 class="related-title">{ui.related}</h2>
            <div class="related-grid">
              {entry.data.relatedTerms.map(term => {
                const relatedEntry = entries.find(e => e.data.term.toLowerCase() === term.toLowerCase());
                if (!relatedEntry) return null;
                const relatedColor = categoryColors[relatedEntry.data.category] || categoryColors['allgemein'];
                return (
                  <a 
                    href={lp(`/wiki/${getSlugBase(relatedEntry.id)}`)}
                    class="related-card"
                    style={`--rel-color: ${relatedColor.text}; --rel-bg: ${relatedColor.bg};`}
                  >
                    <span class="related-term">{relatedEntry.data.term}</span>
                    <span class="related-category">{categoryLabels[relatedEntry.data.category]}</span>
                  </a>
                );
              })}
            </div>
          </footer>
        )}

        <!-- Back to Glossary -->
        <nav class="back-nav">
          <a href={lp('/wiki')} class="back-link">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15.833 10H4.167m0 0L10 15.833M4.167 10L10 4.167" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {ui.back}
          </a>
        </nav>
      </article>
    </main>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .wiki-layout {
    display: flex;
    min-height: calc(100vh - 80px);
  }

  .wiki-main {
    flex: 1;
    margin-left: 280px;
    min-height: calc(100vh - 80px);
  }

  @media (max-width: 1024px) {
    .wiki-main {
      margin-left: 0;
    }
  }

  .wiki-article {
    max-width: 800px;
    padding: var(--space-8) var(--space-8) var(--space-20);
  }

  @media (max-width: 640px) {
    .wiki-article {
      padding: var(--space-6) var(--space-4) var(--space-16);
    }
  }

  /* Article Header */
  .article-header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--mv-gray-200);
  }

  .article-breadcrumb {
    margin-bottom: var(--space-4);
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--mv-gray-500);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumb-link:hover {
    color: var(--mv-violet);
  }

  .article-meta {
    margin-bottom: var(--space-4);
  }

  .category-badge {
    display: inline-flex;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    font-weight: 700;
    color: var(--mv-violet);
    line-height: 1.2;
    margin-bottom: var(--space-6);
  }

  /* Definition Box */
  .definition-box {
    background: linear-gradient(135deg, var(--cat-bg) 0%, var(--mv-white) 100%);
    border-left: 4px solid var(--cat-border);
    border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
    padding: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .definition-label {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cat-color);
    margin-bottom: var(--space-2);
  }

  .definition-text {
    font-size: var(--text-lg);
    color: var(--mv-gray-700);
    line-height: 1.7;
    margin: 0;
  }

  /* Synonyms */
  .synonyms-box {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .synonyms-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--mv-gray-500);
  }

  .synonyms-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .synonym-tag {
    padding: var(--space-1) var(--space-3);
    background: var(--mv-gray-100);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--mv-gray-600);
  }

  /* Article Content */
  .article-content {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--mv-gray-700);
  }

  .article-content :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--mv-violet);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--mv-gray-100);
  }

  .article-content :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--mv-violet);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .article-content :global(p) {
    margin-bottom: var(--space-4);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .article-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .article-content :global(blockquote) {
    background: var(--mv-gray-50);
    border-left: 4px solid var(--mv-orange);
    padding: var(--space-4) var(--space-6);
    margin: var(--space-6) 0;
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    font-style: italic;
    color: var(--mv-gray-600);
  }

  .article-content :global(a) {
    color: var(--mv-violet);
    text-decoration: underline;
    text-decoration-color: var(--mv-blue);
    text-underline-offset: 3px;
  }

  .article-content :global(a:hover) {
    color: var(--mv-orange);
  }

  .article-content :global(code) {
    background: var(--mv-gray-100);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.9em;
    color: var(--mv-violet);
  }

  .article-content :global(pre) {
    background: var(--mv-violet);
    color: var(--mv-white);
    padding: var(--space-5);
    border-radius: var(--radius-xl);
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .article-content :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
  }

  /* Footer */
  .article-footer {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--mv-gray-200);
  }

  .related-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--mv-violet);
    margin-bottom: var(--space-4);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-3);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--rel-bg);
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .related-card:hover {
    border-color: var(--rel-color);
    transform: translateY(-2px);
  }

  .related-term {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--rel-color);
  }

  .related-category {
    font-size: var(--text-xs);
    color: var(--mv-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Back Nav */
  .back-nav {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--mv-gray-200);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--mv-violet);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--mv-orange);
  }
</style>
