---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import WikiEntryCard from '../../../components/sections/WikiEntryCard.astro';
import { localePath, type Locale } from '../../../i18n/translations';
import { getLocalizedWiki, getSlugBase } from '../../../lib/wiki';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);
const { category } = Astro.params;

const labels = {
  de: {
    wiki: 'CT-Lexikon',
    back: 'Alle Wiki-Einträge',
    eyebrow: 'Wiki-Kategorie',
    empty: 'In dieser Kategorie wurden keine Einträge gefunden.',
    entries: 'Einträge',
    categories: {
      grundlagen: 'Grundlagen',
      verfahren: 'Verfahren',
      qm: 'Qualitätsmanagement',
      materialien: 'Materialien',
      normen: 'Normen & Standards',
      software: 'Software',
      hardware: 'Hardware',
      allgemein: 'Allgemein'
    }
  },
  en: {
    wiki: 'CT Glossary',
    back: 'All wiki entries',
    eyebrow: 'Wiki Category',
    empty: 'No entries were found in this category.',
    entries: 'entries',
    categories: {
      grundlagen: 'Basics',
      verfahren: 'Methods',
      qm: 'Quality Management',
      materialien: 'Materials',
      normen: 'Standards',
      software: 'Software',
      hardware: 'Hardware',
      allgemein: 'General'
    }
  }
};

const t = labels[locale as keyof typeof labels] || labels.de;
const categoryLabel = category ? t.categories[category as keyof typeof t.categories] : undefined;

if (!category || !categoryLabel) {
  return Astro.redirect(lp('/wiki'));
}

const allEntries = await getLocalizedWiki(locale);
const entries = allEntries
  .filter((entry) => entry.data.category === category)
  .sort((a, b) => a.data.term.localeCompare(b.data.term, locale));
---

<BaseLayout
  title={`${categoryLabel} | ${t.wiki}`}
  description={`${categoryLabel}: Fachbegriffe und Definitionen im Microvista CT-Lexikon.`}
>
  <Header slot="header" />

  <main class="wiki-category-page">
    <section class="category-hero">
      <div class="container">
        <a href={lp('/wiki')} class="back-link">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15.833 10H4.167m0 0L10 15.833M4.167 10L10 4.167" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {t.back}
        </a>
        <span class="eyebrow">{t.eyebrow}</span>
        <h1>{categoryLabel}</h1>
        <p>{entries.length} {t.entries}</p>
      </div>
    </section>

    <section class="category-results">
      <div class="container">
        {entries.length === 0 ? (
          <p class="empty">{t.empty}</p>
        ) : (
          <div class="entries-grid">
            {entries.map((entry) => (
              <WikiEntryCard
                term={entry.data.term}
                definition={entry.data.definition}
                category={entry.data.category}
                categoryLabel={categoryLabel}
                slug={getSlugBase(entry.id)}
                locale={locale}
                synonyms={entry.data.synonyms}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .wiki-category-page {
    background: #fff;
  }

  .category-hero {
    background: linear-gradient(135deg, #1a1638 0%, #32285b 72%, #453276 100%);
    color: #fff;
    padding: var(--space-16) 0 var(--space-12);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255,255,255,0.72);
    font-weight: 700;
    margin-bottom: var(--space-8);
    text-decoration: none;
  }

  .back-link:hover {
    color: #fff;
  }

  .eyebrow {
    display: block;
    color: var(--mv-orange);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .category-hero h1 {
    color: #fff;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .category-hero p {
    color: rgba(255,255,255,0.75);
    font-size: var(--text-xl);
  }

  .category-results {
    padding: var(--space-12) 0 var(--space-20);
  }

  .entries-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 920px;
  }

  .empty {
    max-width: 720px;
    padding: var(--space-8);
    background: var(--mv-gray-50);
    border: 1px solid var(--mv-gray-200);
    border-radius: var(--radius-lg);
    color: var(--mv-gray-600);
  }
</style>
