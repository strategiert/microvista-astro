---
/**
 * Wiki Index - Redesign
 * Modernes Lexikon-Layout mit Bento Grid und alphabetischer Navigation
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import WikiHero from '../../components/sections/WikiHero.astro';
import WikiCategoryGrid from '../../components/sections/WikiCategoryGrid.astro';
import WikiEntryCard from '../../components/sections/WikiEntryCard.astro';
import { localePath, type Locale } from '../../i18n/translations';
import { getLocalizedWiki } from '../../lib/wiki';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

// Wiki-Einträge mit Sprach-Fallback (FR/ES/IT → EN → DE)
const localizedEntries = await getLocalizedWiki(locale);

// Nach Alphabet sortieren
const entries = localizedEntries.sort((a, b) =>
  a.data.term.localeCompare(b.data.term, locale)
);

// Nach Buchstaben gruppieren
const groupedEntries = entries.reduce((acc, entry) => {
  const letter = entry.data.term[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(entry);
  return acc;
}, {} as Record<string, typeof entries>);

// Alle Buchstaben A-Z
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const availableLetters = Object.keys(groupedEntries).sort();

// Kategorien mit Count
const categoryCounts = entries.reduce((acc, entry) => {
  acc[entry.data.category] = (acc[entry.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categories = Object.keys(categoryCounts).map(cat => ({
  id: cat,
  label: cat,
  count: categoryCounts[cat]
}));

const content = {
  de: {
    title: 'CT-Lexikon',
    subtitle: 'Fachbegriffe der industriellen Computertomographie verständlich erklärt',
    searchPlaceholder: 'Begriff suchen...',
    categories: 'Kategorien',
    allEntries: 'Alle Einträge',
    noEntries: 'Keine Einträge gefunden.',
    entries: 'Einträge',
    categoryLabels: {
      'grundlagen': 'Grundlagen',
      'verfahren': 'Verfahren',
      'qm': 'QM',
      'materialien': 'Materialien',
      'normen': 'Normen',
      'software': 'Software',
      'hardware': 'Hardware',
      'allgemein': 'Allgemein'
    },
    stats: {
      entries: 'Einträge',
      categories: 'Kategorien'
    }
  },
  en: {
    title: 'CT Glossary',
    subtitle: 'Industrial CT terms explained clearly',
    searchPlaceholder: 'Search term...',
    categories: 'Categories',
    allEntries: 'All Entries',
    noEntries: 'No entries found.',
    entries: 'entries',
    categoryLabels: {
      'grundlagen': 'Basics',
      'verfahren': 'Methods',
      'qm': 'QM',
      'materialien': 'Materials',
      'normen': 'Standards',
      'software': 'Software',
      'hardware': 'Hardware',
      'allgemein': 'General'
    },
    stats: {
      entries: 'Entries',
      categories: 'Categories'
    }
  },
  fr: {
    title: 'Glossaire CT',
    subtitle: 'Termes de la tomographie industrielle expliqués',
    searchPlaceholder: 'Rechercher...',
    categories: 'Catégories',
    allEntries: 'Tous les entrées',
    noEntries: 'Aucune entrée trouvée.',
    entries: 'entrées',
    categoryLabels: {
      'grundlagen': 'Bases',
      'verfahren': 'Méthodes',
      'qm': 'MQ',
      'materialien': 'Matériaux',
      'normen': 'Normes',
      'software': 'Logiciel',
      'hardware': 'Matériel',
      'allgemein': 'Général'
    },
    stats: {
      entries: 'Entrées',
      categories: 'Catégories'
    }
  },
  es: {
    title: 'Glosario CT',
    subtitle: 'Términos de tomografía industrial explicados',
    searchPlaceholder: 'Buscar...',
    categories: 'Categorías',
    allEntries: 'Todas las entradas',
    noEntries: 'No se encontraron entradas.',
    entries: 'entradas',
    categoryLabels: {
      'grundlagen': 'Fundamentos',
      'verfahren': 'Métodos',
      'qm': 'GC',
      'materialien': 'Materiales',
      'normen': 'Normas',
      'software': 'Software',
      'hardware': 'Hardware',
      'allgemein': 'General'
    },
    stats: {
      entries: 'Entradas',
      categories: 'Categorías'
    }
  },
  it: {
    title: 'Glossario CT',
    subtitle: 'Termini della tomografia industriale spiegati',
    searchPlaceholder: 'Cerca...',
    categories: 'Categorie',
    allEntries: 'Tutte le voci',
    noEntries: 'Nessuna voce trovata.',
    entries: 'voci',
    categoryLabels: {
      'grundlagen': 'Fondamenti',
      'verfahren': 'Metodi',
      'qm': 'GQ',
      'materialien': 'Materiali',
      'normen': 'Norme',
      'software': 'Software',
      'hardware': 'Hardware',
      'allgemein': 'Generale'
    },
    stats: {
      entries: 'Voci',
      categories: 'Categorie'
    }
  }
};

const t = content[locale as keyof typeof content] || content.de;

const categoryData = categories.map(cat => ({
  id: cat.id,
  label: t.categoryLabels[cat.id as keyof typeof t.categoryLabels] || cat.id,
  count: cat.count
}));

const stats = [
  { value: entries.length.toString(), label: t.stats.entries },
  { value: categories.length.toString(), label: t.stats.categories }
];
---

<BaseLayout
  title={t.title}
  description={t.subtitle}
>
  <Header slot="header" />

  <main class="wiki-page">
    <!-- Hero Section -->
    <WikiHero
      title={t.title}
      subtitle={t.subtitle}
      searchPlaceholder={t.searchPlaceholder}
      locale={locale}
      stats={stats}
    />

    <!-- Category Grid -->
    <WikiCategoryGrid
      categories={categoryData}
      locale={locale}
      title={t.categories}
    />

    <!-- Alphabet Navigation -->
    <nav class="alphabet-nav" aria-label="Alphabetische Navigation">
      <div class="container">
        <div class="alphabet-scroll">
          {alphabet.map(letter => {
            const hasEntries = availableLetters.includes(letter);
            return (
              <a
                href={hasEntries ? `#letter-${letter}` : undefined}
                class:list={['alphabet-letter', { 'disabled': !hasEntries, 'active': hasEntries }]}
                aria-disabled={!hasEntries}
              >
                {letter}
              </a>
            );
          })}
        </div>
      </div>
    </nav>

    <!-- Entries List -->
    <section class="entries-section">
      <div class="container">
        <h2 class="section-title">{t.allEntries}</h2>
        
        {entries.length === 0 ? (
          <div class="empty-state">
            <p>{t.noEntries}</p>
          </div>
        ) : (
          <div class="entries-content">
            {availableLetters.map(letter => (
              <div class="letter-group" id={`letter-${letter}`}>
                <h3 class="letter-heading">
                  <span class="letter-marker">{letter}</span>
                </h3>
                <div class="entries-grid">
                  {groupedEntries[letter].map(entry => (
                    <WikiEntryCard
                      term={entry.data.term}
                      definition={entry.data.definition}
                      category={entry.data.category}
                      categoryLabel={t.categoryLabels[entry.data.category as keyof typeof t.categoryLabels] || entry.data.category}
                      slug={entry.slug}
                      locale={locale}
                      synonyms={entry.data.synonyms}
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .wiki-page {
    background: var(--mv-white);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  /* Alphabet Navigation */
  .alphabet-nav {
    position: sticky;
    top: 80px;
    z-index: 10;
    background: linear-gradient(180deg, var(--mv-white) 0%, rgba(255,255,255,0.95) 100%);
    backdrop-filter: blur(8px);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--mv-gray-200);
  }

  .alphabet-scroll {
    display: flex;
    gap: var(--space-1);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    justify-content: center;
    flex-wrap: wrap;
  }

  .alphabet-scroll::-webkit-scrollbar {
    display: none;
  }

  .alphabet-letter {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--mv-violet);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .alphabet-letter.active:hover {
    background: var(--mv-violet);
    color: var(--mv-white);
  }

  .alphabet-letter.disabled {
    color: var(--mv-gray-300);
    cursor: default;
  }

  /* Entries Section */
  .entries-section {
    padding: var(--space-12) 0 var(--space-20);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--mv-violet);
    margin-bottom: var(--space-8);
  }

  .letter-group {
    margin-bottom: var(--space-12);
    scroll-margin-top: 140px;
  }

  .letter-heading {
    display: flex;
    align-items: center;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--mv-gray-100);
  }

  .letter-marker {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--mv-violet);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--mv-gray-50);
    border-radius: var(--radius-lg);
  }

  .entries-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
    color: var(--mv-gray-500);
  }

  @media (max-width: 640px) {
    .alphabet-nav {
      top: 60px;
    }

    .alphabet-letter {
      width: 32px;
      height: 32px;
      font-size: var(--text-xs);
    }

    .letter-group {
      scroll-margin-top: 120px;
    }
  }
</style>

<script>
  // Client-side search
  const searchInput = document.getElementById('wiki-search') as HTMLInputElement;
  const entryCards = document.querySelectorAll('.wiki-card');
  const letterGroups = document.querySelectorAll('.letter-group');

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();

    entryCards.forEach(card => {
      const term = card.querySelector('.term')?.textContent?.toLowerCase() || '';
      const definition = card.querySelector('.definition')?.textContent?.toLowerCase() || '';
      const matches = term.includes(query) || definition.includes(query);
      (card as HTMLElement).style.display = matches ? 'flex' : 'none';
    });

    // Hide empty letter groups
    letterGroups.forEach(group => {
      const visibleCards = group.querySelectorAll('.wiki-card[style="display: flex;"], .wiki-card:not([style])');
      const hasVisible = visibleCards.length > 0;
      (group as HTMLElement).style.display = hasVisible ? 'block' : 'none';
    });
  });
</script>
