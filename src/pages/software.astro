    updateTitle: 'Das steckt im VistaXPro-Update',
    updateText: 'Microvista hat seine Yxlon FF85-CT-Anlage auf die VistaXPro-Variante upgedatet. Das Ergebnis: Scans bis zu 5-mal schneller, eine bis zu 10-mal höhere Auflösung – und das neue Prüfverfahren Laminografie (LayerScan) steht zur Verfügung.',
    updateItems: [
      { stat: '5×', label: 'schnellere Scan-Zyklen', detail: 'Weniger Prüfzeit, höherer Durchsatz' },
      { stat: '10×', label: 'höhere Auflösung', detail: 'Kleinste Defekte sichtbar, weniger Datenmenge' },
      { stat: 'Neu', label: 'Laminografie', detail: 'LayerScan für flache Bauteile ohne 360°-Drehung' },
    ],

    ctaTitle: 'Bereit für automatisierte CT-Auswertung?',
    ctaSubline: 'Software-Beratung oder Cloud-Auswertung – wir melden uns innerhalb von 24 Stunden.',
    cta1: 'Software anfragen',
    cta2: 'Cloud-Auswertung testen',

    moreTitle: 'Mehr zur InspectVista CT-Software',
    moreSubline: 'Details zu Funktionsweise, Einsatzgebieten, Vorteilen, Einführung und Lizenzmodell.',
    more: [
      { title: 'Funktionsweise', text: 'Die vier Module — Registrierung, ROI, Prüfaufgaben-Ausführung, Ergebnisausgabe.', href: '/software/funktionsweise' },
      { title: 'Anwendungen', text: 'Acht Praxisbeispiele: Batterie, Stator, Kühlplatte, Pumpe, Schweißnähte u. v. m.', href: '/software/anwendungen' },
