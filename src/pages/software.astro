        accent: '#ee7711',
      },
    ],

    featuresTitle: 'What InspectVista can do',
    featuresSubline: 'From automatic defect detection to laminography – all inspection methods in one software.',
    features: [
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
        title: 'Fully Automatic Evaluation',
