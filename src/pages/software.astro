    ],

    fuerWenTitle: 'Two paths to automated CT evaluation',
    fuerWenSubline: 'InspectVista adapts to your infrastructure – whether you need new software or evaluation capacity.',
    wege: [
      {
        nr: 'A',
        tag: 'Software',
        title: 'InspectVista on your CT system',
        text: 'Do you own an industrial CT system and need better, more powerful evaluation software? InspectVista (VistaXPro) runs directly on your system and delivers 5× faster scans, 10× higher resolution, and new inspection methods like laminography.',
        bullets: [
          '5× faster scan cycles',
          '10× higher image resolution',
          'Laminography (LayerScan) for flat parts',
          'Fully automatic pass/fail classification',
        ],
        cta: 'Request Software',
        href: '/kontakt',
        accent: '#00a0d2',
      },
      {
        nr: 'B',
        tag: 'Cloud',
        title: 'You scan – Microvista evaluates',
        text: 'Manual evaluation consuming too much time? You own a CT but lack evaluation capacity, trained staff, or specialized software? Upload your reconstructed scan data securely to the Microvista Cloud – we deliver the finished inspection report.',
