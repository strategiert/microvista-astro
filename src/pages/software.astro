      { title: 'Einführung', text: 'Vier Schritte: Bedarfsanalyse, Validierung, Integration, Reifeprozess.', href: '/software/einfuehrung' },
      { title: 'Preise & Lizenz', text: 'Transparente Jahreslizenz — alle Module, Updates und Support inklusive.', href: '/software/preise' },
    ],
  },

  en: {
    seoTitle: 'InspectVista – Industrial CT Software for Automation',
    seoDesc: 'InspectVista automates your CT data evaluation: 5× faster, 10× higher resolution, laminography – as software or cloud service. ISO 9001 & 17025 certified.',

    badge: 'InspectVista · CT Software & Cloud Evaluation',
