const t = content[locale as keyof typeof content] || content.en || content.de;
---

<BaseLayout
  title={t.seoTitle}
  description={t.seoDesc}
  theme="neutral"
>
  <Header slot="header" />

  <!-- ─── 1. HERO ─────────────────────────────────────── -->
  <section class="sw-hero">
    <div class="sw-hero-inner">
      <div class="sw-container sw-hero-container">
        <div class="sw-hero-content">
          <div class="sw-badge-row">
            <img
              src="/images/logos/Microvista-InspectVista-Logo-2025-colored-02.png"
              alt="InspectVista Logo"
              class="sw-product-logo"
              loading="eager"
            />
          </div>
          <p class="sw-tagline">{t.tagline}</p>
          <h1>
            {t.headline}
            <span class="sw-accent">{t.headlineAccent}</span>
          </h1>
          <p class="sw-subline">{t.subline}</p>
          <div class="sw-hero-cta">
            <a href={lp('/kontakt')} class="sw-btn sw-btn-cyan sw-btn-lg">{t.cta1}</a>
            <a href={lp('/kontakt')} class="sw-btn sw-btn-ghost sw-btn-lg">{t.cta2}</a>
          </div>
        </div>
      </div>
      <div class="sw-hero-img-col">
        <img
          src="/images/ct/Beispiel-Bedienoberflaeche-der-CT-Software-am-Laptop.png"
          alt="InspectVista CT-Software Benutzeroberfläche auf Laptop"
          class="sw-hero-img"
          loading="eager"
        />
        <div class="sw-hero-img-fade"></div>
      </div>
    </div>
  </section>

  <!-- ─── 2. STATS BAR ────────────────────────────────── -->
  <section class="sw-stats">
    <div class="sw-container">
      <div class="sw-stats-grid">
        {t.stats.map((s: any) => (
          <div class="sw-stat">
            <span class="sw-stat-value">{s.value}</span>
            <span class="sw-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 3. FÜR WEN? (Zwei Wege) ────────────────────── -->
  <section class="sw-section sw-fuerwen">
    <div class="sw-container">
      <div class="sw-section-head sw-center">
        <h2>{t.fuerWenTitle}</h2>
        <p class="sw-muted">{t.fuerWenSubline}</p>
      </div>
      <div class="sw-wege-grid">
        {t.wege.map((w: any) => (
          <div class="sw-weg-card">
            <div class="sw-weg-header" style={`border-color: ${w.accent}`}>
              <span class="sw-weg-nr" style={`background: ${w.accent}`}>{w.nr}</span>
              <span class="sw-weg-tag">{w.tag}</span>
            </div>
            <h3>{w.title}</h3>
            <p>{w.text}</p>
            <ul class="sw-weg-bullets">
              {w.bullets.map((b: string) => (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style={`color: ${w.accent}`}><path d="M20 6L9 17l-5-5"/></svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <a href={lp(w.href)} class="sw-weg-cta" style={`color: ${w.accent}; border-color: ${w.accent}`}>
              {w.cta}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 4. FEATURES GRID ─────────────────────────────── -->
  <section class="sw-section sw-features">
    <div class="sw-container">
      <div class="sw-section-head sw-center">
        <h2>{t.featuresTitle}</h2>
        <p class="sw-muted">{t.featuresSubline}</p>
      </div>
      <div class="sw-features-grid">
        {t.features.map((f: any) => (
          <div class="sw-feature-card">
            <div class="sw-feature-icon" set:html={f.icon}></div>
            <h3>{f.title}</h3>
            <p>{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 5. CLOUD-WORKFLOW ────────────────────────────── -->
  <section class="sw-section sw-workflow">
    <div class="sw-container">
      <div class="sw-section-head sw-center">
        <h2>{t.workflowTitle}</h2>
        <p class="sw-muted">{t.workflowSubline}</p>
      </div>
      <div class="sw-workflow-grid">
        {t.workflow.map((w: any, i: number) => (
          <div class="sw-workflow-step">
            <div class="sw-workflow-nr">{w.nr}</div>
            {i < t.workflow.length - 1 && (
              <div class="sw-workflow-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            )}
            <h3>{w.title}</h3>
            <p>{w.text}</p>
          </div>
        ))}
      </div>
      <div class="sw-workflow-image">
        <img
          src="/images/ct/Auswertung-CT-Scan-vom-CT-Techniker-Dustin-Klein-e1761286147918.jpg"
          alt="CT-Techniker Dustin Klein bei der Auswertung eines industriellen CT-Scans"
          loading="lazy"
        />
        <div class="sw-workflow-label">
