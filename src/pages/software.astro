      { icon: '⚙', title: 'Montage & Fügekontrolle', text: 'Schweißnähte, Presspassungen, Kleber' },
      { icon: '⚡', title: 'Hairpin-Statoren', text: 'E-Motor-Wicklungen vollständig prüfen' },
