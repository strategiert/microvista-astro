    workflow: [
      { nr: '1', title: 'Anfrage & Absprache', text: 'Sie definieren Prüfaufgabe, Stückzahl und Anforderungen. Express-Option (< 24h) auf Anfrage.' },
      { nr: '2', title: 'Scan & Upload', text: 'Sie führen den CT-Scan durch und laden die rekonstruierten Daten + Anforderungen in die sichere Microvista Cloud.' },
