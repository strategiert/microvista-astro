    badge: 'InspectVista · CT-Software & Cloud-Auswertung',
    tagline: 'GET YOUR INSPECTION DONE – Anywhere. Anytime. Fast.',
    headline: 'Industrielle CT-Software',
    headlineAccent: 'zur Automatisierung',
    subline: 'Mit InspectVista erfolgt Ihre CT-Datenauswertung vollautomatisch – schnell, präzise, wirtschaftlich. Nutzen Sie die Software direkt auf Ihrer CT-Anlage oder übergeben Sie die Auswertung an Microvista via Cloud.',
    cta1: 'Software anfragen',
    cta2: 'Cloud-Auswertung testen',

    stats: [
      { value: '5×', label: 'schnellere Scans' },
      { value: '10×', label: 'höhere Auflösung' },
      { value: '100%', label: 'automatisiert' },
      { value: 'ISO', label: '9001 & 17025' },
    ],

    fuerWenTitle: 'Zwei Wege zur automatisierten CT-Auswertung',
    fuerWenSubline: 'InspectVista passt sich Ihrer Infrastruktur an – egal ob Sie eine neue Software suchen oder Auswertungskapazität benötigen.',
