---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import { localePath, type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

const services = [
  {
    slug: 'ct-labor',
    name: 'CT-Labor',
    eyebrow: 'Bauteil einsenden',
    desc: 'Hochauflösende Scans, Auswertung und Prüfbericht im Microvista CT-Labor.',
    image: '/images/wp/2025/10/CT-Techniker-am-industriellen-CT-Dustin-Klein-scaled-e1761285791426-1024x683.jpg',
    stats: ['Erstmuster', 'Einzelteile', 'Chargen']
  },
  {
    slug: 'ct-datenauswertung',
    name: 'CT-Datenauswertung',
    eyebrow: 'Daten hochladen',
    desc: 'Automatisierte und geprüfte Auswertung vorhandener CT-Daten über die Microvista Cloud.',
    image: '/images/software/Auswertung-CT-einer-Pumpe.webp',
    stats: ['Q-Gate', 'Cloud', 'Report']
  },
  {
    slug: 'scanexpress',
    name: 'SCANEXPRESS',
    eyebrow: 'CT vor Ort',
    desc: 'Mobiles industrielles CT zur Miete für akute Qualitätsvorfälle und temporäre Prüfbedarfe.',
    image: '/images/wp/2026/01/Industrielles-mobiles-CT-ScanExpress.webp',
    stats: ['Vor Ort', 'OPEX', 'Serie']
  }
];

const t = {
  title: 'Dienstleistungen',
  subtitle: 'Drei Wege zur belastbaren CT-Entscheidung',
  description: 'CT-Labor, mobile CT-Lösungen und Datenauswertung - alles aus einer Hand.',
  lead: 'Ob Bauteil im Labor, vorhandene CT-Daten oder ein mobiler Einsatz direkt in der Produktion: Microvista wählt den Prüfweg nach Zeitdruck, Bauteilgeometrie und Entscheidungsbedarf.',
  learnMore: 'Mehr erfahren',
  questionnaire: 'Fragebogen starten',
  contact: 'Beratung anfragen'
};
---

<BaseLayout title={t.title} description={t.description}>
  <Header slot="header" />

  <main class="services-page">
    <section class="services-hero">
      <div class="container">
        <Breadcrumbs items={[{ label: t.title }]} />
        <span class="eyebrow">Microvista CT-Services</span>
        <h1>{t.subtitle}</h1>
        <p>{t.lead}</p>
        <div class="hero-actions">
          <a href={lp('/fragebogen')} class="btn primary">{t.questionnaire}</a>
          <a href={lp('/kontakt')} class="btn secondary">{t.contact}</a>
        </div>
      </div>
    </section>

    <section class="services-section">
      <div class="container services-grid">
        {services.map((service) => (
          <a href={lp(`/dienstleistungen/${service.slug}`)} class="service-card">
            <img src={service.image} alt={service.name} loading="lazy" />
            <div class="service-body">
              <span>{service.eyebrow}</span>
              <h2>{service.name}</h2>
              <p>{service.desc}</p>
              <div class="service-tags">
                {service.stats.map((item) => <em>{item}</em>)}
              </div>
              <strong>{t.learnMore}</strong>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .services-page {
    background: #fff;
  }

  .services-hero {
    background: linear-gradient(135deg, #171335 0%, #32285b 72%, #493875 100%);
    color: #fff;
    padding: var(--space-16) 0 var(--space-14, 3.5rem);
  }

  .services-hero :global(.breadcrumbs),
  .services-hero :global(.breadcrumbs a),
  .services-hero :global(.breadcrumbs span) {
    color: rgba(255,255,255,0.72);
  }

  .eyebrow {
    display: block;
    color: var(--mv-orange);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .services-hero h1 {
    max-width: 900px;
    color: #fff;
    font-size: clamp(3rem, 7vw, 5.6rem);
    text-transform: uppercase;
    margin-bottom: var(--space-5);
  }

  .services-hero p {
    max-width: 780px;
    color: rgba(255,255,255,0.78);
    font-size: var(--text-xl);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 var(--space-6);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
  }

  .btn.primary {
    background: var(--mv-orange);
    color: #fff;
  }

  .btn.secondary {
    border: 1px solid rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  .services-section {
    padding: var(--space-16) 0 var(--space-20);
    background: #f6f7fb;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--mv-gray-200);
    border-radius: var(--radius-md);
    color: inherit;
    text-decoration: none;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .service-card:hover {
    border-color: var(--mv-orange);
    box-shadow: 0 18px 45px rgba(50,40,91,0.14);
    transform: translateY(-4px);
  }

  .service-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .service-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: var(--space-6);
  }

  .service-body > span {
    color: var(--mv-orange);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    margin-bottom: var(--space-3);
  }

  .service-body h2 {
    color: var(--mv-violet);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-3);
  }

  .service-body p {
    color: var(--mv-gray-600);
    line-height: 1.65;
  }

  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-6) 0;
  }

  .service-tags em {
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: #f3f0ff;
    color: var(--mv-violet);
    font-style: normal;
    font-weight: 700;
    font-size: var(--text-xs);
  }

  .service-body strong {
    margin-top: auto;
    color: var(--mv-orange);
    font-family: var(--font-heading);
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }
  }
</style>
