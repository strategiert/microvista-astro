---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-laminographie', locale);
---

<PruefaufgabenLayout
  title="Laminographie: Zerstörungsfrei flache Bauteile prüfen"
  description="Laminographie für flache Bauteile: Leiterplatten, Elektronikbaugruppen und Verbundwerkstoffe hochauflösend analysieren."
  content={content}
  locale={locale}
/>
