---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-form-und-lagetoleranzen', locale);
---

<PruefaufgabenLayout
  title="Form- und Lagetoleranzen messen | Methoden & ISO 1101"
  description="Form- und Lagetoleranzen nach ISO 1101 einfach erklärt: Bedeutung, Messmethoden und Vorteile der industriellen CT für präzise Qualitätskontrolle."
  content={content}
  locale={locale}
/>
