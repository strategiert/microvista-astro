---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-messung-wandstaerken', locale);
---

<PruefaufgabenLayout
  title="Messung von Wandstärken mit industrieller CT"
  description="Automatisierte Messung von Wandstärken mit industrieller CT, welche kritische Abweichungen vom Soll-Zustand schnell sichtbar macht."
  content={content}
  locale={locale}
/>
