---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-erstmusterpruefbericht', locale);
---

<PruefaufgabenLayout
  title="Erstmusterprüfbericht (EMPB) nach VDA | Erstbemusterung Microvista"
  description="Erstmusterprüfbericht (EMPB) für PPAP & VDA Band 2: Zerstörungsfreie CT-Prüfung für Erstbemusterung. Express-Service verfügbar. Jetzt Beratung sichern!"
  content={content}
  locale={locale}
/>
