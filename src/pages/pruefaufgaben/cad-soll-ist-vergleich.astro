---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-cad-soll-ist-vergleich', locale);
---

<PruefaufgabenLayout
  title="Highspeed CAD Soll-Ist-Vergleich mit industrieller CT"
  description="Express-Inspektion für einen CAD Soll-Ist-Vergleich buchbar - priorisierte Prüfung durch die CT-Experten von Microvista."
  content={content}
  locale={locale}
/>
