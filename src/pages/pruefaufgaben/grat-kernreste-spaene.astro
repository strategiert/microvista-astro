---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-grat-kernreste-spaene', locale);
---

<PruefaufgabenLayout
  title="Schnelle CT-Prüfung auf Grat, Kernreste & Späne"
  description="Grat, Kernreste & Späne automatisiert & schnell finden mit industrieller CT. Eine Prüfung ist bei Ihnen oder im Microvista CT-Labor möglich."
  content={content}
  locale={locale}
/>
