---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { getCollection } from 'astro:content';
import { faqSchema, serviceSchema } from '../../components/seo/schemas';
import { localePath, type Locale } from '../../i18n/translations';

const { slug } = Astro.params;
const pruefaufgaben = await getCollection('pruefaufgaben');
const entry = pruefaufgaben.find(p => p.data.slug === slug);
if (!entry) return Astro.redirect('/pruefaufgaben/');
const task = entry.data;
const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

const t = {
  de: {
    whatIs: 'Was ist das?',
    howItWorks: 'Wie funktioniert es?',
    benefits: 'Vorteile',
    applications: 'Anwendungsgebiete',
  },
  en: {
    whatIs: 'What is it?',
    howItWorks: 'How does it work?',
    benefits: 'Benefits',
    applications: 'Applications',
  },
  fr: {
    whatIs: 'De quoi s\'agit-il ?',
    howItWorks: 'Comment ça fonctionne ?',
    benefits: 'Avantages',
    applications: 'Applications',
  },
  es: {
    whatIs: '¿Qué es?',
    howItWorks: '¿Cómo funciona?',
    benefits: 'Ventajas',
    applications: 'Aplicaciones',
  },
  it: {
    whatIs: 'Di cosa si tratta?',
    howItWorks: 'Come funziona?',
    benefits: 'Vantaggi',
    applications: 'Applicazioni',
  },
}[locale] ?? {
  whatIs: 'What is it?',
  howItWorks: 'How does it work?',
  benefits: 'Benefits',
  applications: 'Applications',
};

const schemas = [];
if (task.faq?.length) schemas.push(faqSchema(task.faq));
schemas.push(serviceSchema({
  name: task.name,
  description: task.description,
  url: `https://microvista.de/pruefaufgaben/${task.slug}/`,
}));
---

<PruefaufgabenLayout
  title={task.seo.title}
  description={task.seo.description}
  pageTitle={task.name}
  pageLead={task.description}
  locale={locale}
>
  <section class="slug-section">
    <h2>{t.whatIs}</h2>
    <div set:html={task.whatIs} />
  </section>

  <section class="slug-section">
    <h2>{t.howItWorks}</h2>
    <div set:html={task.howItWorks} />
  </section>

  <section class="slug-section">
    <h2>{t.benefits}</h2>
    <ul class="slug-benefits">
      {task.benefits.map((b: string) => <li>{b}</li>)}
    </ul>
  </section>

  <section class="slug-section">
    <h2>{t.applications}</h2>
    <ul class="slug-apps">
      {task.applications.map((a: string) => <li>{a}</li>)}
    </ul>
  </section>

  {task.faq?.length > 0 && (
    <section class="slug-section">
      <h2>FAQ</h2>
      {task.faq.map((item: { question: string; answer: string }) => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <div class="faq-answer" set:html={item.answer} />
        </details>
      ))}
    </section>
  )}
</PruefaufgabenLayout>

<style>
  .slug-section {
    margin-bottom: var(--space-12);
  }

  .slug-benefits li::marker,
  .slug-apps li::marker {
    color: #ee7711;
  }

  .faq-item {
    border: 1px solid #e5e7eb;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-3);
    overflow: hidden;
  }

  .faq-item summary {
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    font-weight: 600;
    color: #32285b;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary:hover {
    background: #f5f3ff;
  }

  .faq-answer {
    padding: 0 var(--space-5) var(--space-4);
    line-height: 1.8;
    color: #374151;
    border-top: 1px solid #e5e7eb;
  }
</style>
