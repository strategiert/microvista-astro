---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-porositatsanalyse', locale);
---

<PruefaufgabenLayout
  title="Automatische Porositätsanalyse mit industrieller CT"
  description="Porositätsanalyse in verschiedensten Materialen wie z.B. Schwer- & Leichtmetall mit industrieller CT. Jetzt klicken & mehr erfahren!"
  content={content}
  locale={locale}
/>
