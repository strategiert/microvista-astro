---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-montage-fugekontrolle', locale);
---

<PruefaufgabenLayout
  title="Schnelle Montage- & Fügekontrolle mit industrieller CT"
  description="Montage & Fügekontrolle kinderleicht: Industrielle CT prüft das Verhalten einer montierten Baugruppe automatisch in verschiedenen Zuständen."
  content={content}
  locale={locale}
/>
