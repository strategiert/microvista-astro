---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-reverse-engineering', locale);
---

<PruefaufgabenLayout
  title="Reverse Engineering von komplexen Bauteilen mit CT"
  description="Brauchen Sie Unterstützung beim Reverse Engineering? Microvista digitalisiert große & komplexe Bauteile mit industrieller CT."
  content={content}
  locale={locale}
/>
