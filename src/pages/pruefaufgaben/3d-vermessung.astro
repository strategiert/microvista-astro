---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-3d-vermessung', locale);
---

<PruefaufgabenLayout
  title="Moderne 3D Vermessung von Bauteilen | Optisch, taktil & CT"
  description="3D Vermessung von Bauteilen mit optischen Scans, taktiler Messtechnik & industrieller CT. Präzise Soll-Ist-Vergleiche, Reverse Engineering & QS."
  content={content}
  locale={locale}
/>
