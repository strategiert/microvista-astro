---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-schweissnahtpruefung', locale);
---

<PruefaufgabenLayout
  title="Zerstörungsfreie Schweißnahtprüfung Überblick über Verfahren"
  description="Zerstörungsfreie Prüfung von Schweißnähten: Verfahren, Einsatzgebiete und typische Fehlerbilder bei Schweißverbindungen verständlich erklärt."
  content={content}
  locale={locale}
/>
