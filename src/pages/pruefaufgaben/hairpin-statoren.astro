---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('pruefaufgabe-hairpin-statoren', locale);
---

<PruefaufgabenLayout
  title="Qualitätssicherung bei Hairpin Statoren"
  description="Hairpin Statoren sind das Herzstück von Elektromotoren. Informieren Sie sich darum wie eine Inspektion aller Pins automatisch möglich ist."
  content={content}
  locale={locale}
/>
