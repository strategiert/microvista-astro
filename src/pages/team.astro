---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { localePath, type Locale } from '../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const lp = (path: string) => localePath(path, locale);

const people = [
  {
    name: 'Dr. Robin Höhne',
    role: 'CEO',
    image: '/images/wp/2024/08/Dr.-Robin-Hoehne-Microvista-GmbH-Team.webp',
    focus: 'Strategie, Kundenprojekte und mobile CT-Technologie'
  },
  {
    name: 'Jonas Wengerodt',
    role: 'Sales Manager',
    image: '/images/wp/2024/08/Jonas-Wengerodt-Microvista-GmbH-Team.webp',
    focus: 'Erstberatung, Angebot und Projektklärung'
  },
  {
    name: 'Dustin Klein',
    role: 'CT Technician',
    image: '/images/wp/2024/08/Dustin-Klein-Microvista-GmbH-Team.webp',
    focus: 'Scanplanung, Bedienung und technische Umsetzung'
  },
  {
    name: 'Yevhen Petrenko',
    role: 'CT Technician',
    image: '/images/wp/2024/08/Yvhen-Petrenko-Microvista-GmbH-Team.webp',
    focus: 'CT-Prüfung, Datenerfassung und Prozesssicherheit'
  },
  {
    name: 'Erik Wünsche',
    role: 'Application Engineer',
    image: '/images/wp/2024/08/Erik-Wuensche-Microvista-GmbH-Team.webp',
    focus: 'Anwendungen, Auswertung und kundenspezifische Prüfprozesse'
  }
];

const t = {
  de: {
    title: 'Unser Team',
    description: 'Lernen Sie das Microvista-Team kennen - CT-Experten, Ingenieure und Qualitätsspezialisten.',
    eyebrow: 'Microvista Team',
    h1: 'Menschen, die CT-Ergebnisse belastbar machen',
    lead: 'Von der ersten Prüfidee bis zum Report: Unser Team verbindet industrielle CT-Erfahrung, Automatisierung und pragmatische Projektbegleitung.',
    contact: 'Kontakt aufnehmen',
    express: 'Express-Inspektion buchen',
    contacts: 'Ansprechpartner & Prozessbegleiter',
    focus: 'Schwerpunkt',
    leadership: 'Geschäftsführung',
    leadershipTitle: 'Prof. Dr. Lutz Hagner',
    leadershipRole: 'Geschäftsführer Microvista GmbH',
    leadershipText: 'Prof. Dr. Lutz Hagner begleitet Microvista seit der Gründung. Sein Fokus liegt auf zerstörungsfreier Prüfung mit industrieller Computertomographie, höherer Ortsauflösung, schnelleren Prüfprozessen und mobilen Systemen wie dem ScanExpress.',
    motto: '... nicht ohne Liebe!',
    family: 'We love Technology Familie',
    familyText: 'Microvista ist Teil der NetCo-Familie. Mehr als 50 Mitarbeitende an den Standorten Blankenburg (Harz) und Magdeburg schaffen ein technisches Umfeld, in dem komplexe Produkte und Lösungen entstehen.',
    ctaTitle: 'Direkt mit dem passenden Ansprechpartner sprechen?',
    ctaText: 'Beschreiben Sie kurz Bauteil, Material und Prüfziel. Wir ordnen intern den richtigen Kontakt und den passenden CT-Weg zu.'
  },
  en: {
    title: 'Our Team',
    description: 'Meet the Microvista team - CT experts, engineers and quality specialists.',
    eyebrow: 'Microvista Team',
    h1: 'People who make CT results reliable',
    lead: 'From inspection idea to report: our team combines industrial CT experience, automation and practical project guidance.',
    contact: 'Get in touch',
    express: 'Book express inspection',
    contacts: 'Contacts & process guides',
    focus: 'Focus',
    leadership: 'Management',
    leadershipTitle: 'Prof. Dr. Lutz Hagner',
    leadershipRole: 'Managing Director Microvista GmbH',
    leadershipText: 'Prof. Dr. Lutz Hagner has supported Microvista since its foundation. His focus is non-destructive testing with industrial CT, higher resolution, faster inspection processes and mobile systems such as ScanExpress.',
    motto: '... not without love!',
    family: 'We love Technology Family',
    familyText: 'Microvista is part of the NetCo family. More than 50 employees in Blankenburg (Harz) and Magdeburg create a technical environment for complex products and solutions.',
    ctaTitle: 'Talk to the right contact directly?',
    ctaText: 'Briefly describe component, material and inspection goal. We will route you to the right contact and CT path.'
  }
}[locale as 'de' | 'en'] || {
  title: 'Our Team',
  description: 'Meet the Microvista team.',
  eyebrow: 'Microvista Team',
  h1: 'People who make CT results reliable',
  lead: 'CT experts, engineers and quality specialists.',
  contact: 'Get in touch',
  express: 'Book express inspection',
  contacts: 'Contacts & process guides',
  focus: 'Focus',
  leadership: 'Management',
  leadershipTitle: 'Prof. Dr. Lutz Hagner',
  leadershipRole: 'Managing Director Microvista GmbH',
  leadershipText: 'Prof. Dr. Lutz Hagner has supported Microvista since its foundation.',
  motto: '... not without love!',
  family: 'We love Technology Family',
  familyText: 'Microvista is part of the NetCo family.',
  ctaTitle: 'Talk to the right contact directly?',
  ctaText: 'Briefly describe component, material and inspection goal.'
};
---

<BaseLayout title={t.title} description={t.description}>
  <Header slot="header" />

  <main class="team-page">
    <section class="team-hero">
      <div class="container hero-grid">
        <div>
          <span class="eyebrow">{t.eyebrow}</span>
          <h1>{t.h1}</h1>
          <p>{t.lead}</p>
          <div class="hero-actions">
            <a href={lp('/kontakt')} class="btn primary">{t.contact}</a>
            <a href={lp('/express-ct-inspektion')} class="btn secondary">{t.express}</a>
          </div>
        </div>
        <div class="hero-image">
          <img src="/images/wp/2024/08/2023_08-FO-Mitarbeiter_alle.webp" alt="Microvista und NetCo Team" loading="eager" />
        </div>
      </div>
    </section>

    <section class="section contacts-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow dark">{t.contacts}</span>
          <h2>CT-Projekte brauchen klare Verantwortliche</h2>
        </div>
        <div class="people-grid">
          {people.map((person) => (
            <article class="person-card">
              <img src={person.image} alt={`${person.name} - ${person.role}`} loading="lazy" />
              <div class="person-content">
                <span>{person.role}</span>
                <h3>{person.name}</h3>
                <p><strong>{t.focus}:</strong> {person.focus}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section leadership-section">
      <div class="container leadership-grid">
        <div class="leadership-copy">
          <span class="eyebrow dark">{t.leadership}</span>
          <h2>{t.leadershipTitle}</h2>
          <p class="role">{t.leadershipRole}</p>
          <p>{t.leadershipText}</p>
          <blockquote>{t.motto}</blockquote>
        </div>
        <img src="/images/wp/2024/08/Prof.-Dr.-Lutz-Hagner-Geschaeftsfphrer-Microvista.webp" alt="Prof. Dr. Lutz Hagner - Geschäftsführer Microvista" loading="lazy" />
      </div>
    </section>

    <section class="family-section">
      <div class="container family-grid">
        <div>
          <span class="eyebrow">{t.family}</span>
          <h2>Technologiekompetenz aus der NetCo-Familie</h2>
          <p>{t.familyText}</p>
        </div>
        <div class="family-facts">
          <div><strong>50+</strong><span>Mitarbeitende</span></div>
          <div><strong>2</strong><span>Standorte</span></div>
          <div><strong>15+</strong><span>Jahre CT-Erfahrung</span></div>
        </div>
      </div>
    </section>

    <section class="team-cta">
      <div class="container cta-inner">
        <div>
          <h2>{t.ctaTitle}</h2>
          <p>{t.ctaText}</p>
        </div>
        <a href={lp('/kontakt')} class="btn primary">{t.contact}</a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .team-page {
    background: #fff;
  }

  .team-hero {
    background: linear-gradient(135deg, #171335 0%, #32285b 62%, #4a397c 100%);
    color: #fff;
    padding: var(--space-20) 0 var(--space-16);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(380px, 1.05fr);
    gap: var(--space-12);
    align-items: center;
  }

  .eyebrow {
    display: block;
    color: var(--mv-orange);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .eyebrow.dark {
    color: var(--mv-orange);
  }

  .team-hero h1 {
    color: #fff;
    font-size: clamp(3rem, 7vw, 5.8rem);
    text-transform: uppercase;
    margin-bottom: var(--space-5);
  }

  .team-hero p {
    max-width: 680px;
    color: rgba(255,255,255,0.78);
    font-size: var(--text-xl);
    line-height: 1.65;
  }

  .hero-actions,
  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .hero-image {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.16);
    box-shadow: 0 30px 90px rgba(0,0,0,0.35);
  }

  .hero-image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 var(--space-6);
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
  }

  .btn.primary {
    background: var(--mv-orange);
    color: #fff;
  }

  .btn.secondary {
    border: 1px solid rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  .section {
    padding: var(--space-20) 0;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }

  .section-heading h2,
  .leadership-copy h2,
  .family-section h2,
  .team-cta h2 {
    color: var(--mv-violet);
    font-size: clamp(2rem, 4vw, 3.2rem);
    text-transform: uppercase;
  }

  .people-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .person-card {
    background: #fff;
    border: 1px solid var(--mv-gray-200);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .person-card img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: var(--mv-gray-100);
  }

  .person-content {
    padding: var(--space-5);
  }

  .person-content span {
    color: var(--mv-orange);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
  }

  .person-content h3 {
    color: var(--mv-violet);
    font-size: var(--text-xl);
    margin: var(--space-2) 0 var(--space-3);
  }

  .person-content p {
    color: var(--mv-gray-600);
    line-height: 1.55;
    font-size: var(--text-sm);
  }

  .leadership-section {
    background: #f6f7fb;
  }

  .leadership-grid,
  .family-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.72fr);
    gap: var(--space-12);
    align-items: center;
  }

  .leadership-copy .role {
    color: var(--mv-orange);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    margin: var(--space-3) 0 var(--space-5);
  }

  .leadership-copy p {
    color: var(--mv-gray-700);
    font-size: var(--text-lg);
    line-height: 1.75;
  }

  .leadership-copy blockquote {
    margin-top: var(--space-8);
    color: var(--mv-violet);
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
  }

  .leadership-grid > img {
    width: 100%;
    border-radius: var(--radius-md);
    box-shadow: 0 20px 55px rgba(50,40,91,0.18);
  }

  .family-section {
    background: #171335;
    color: #fff;
    padding: var(--space-20) 0;
  }

  .family-section h2 {
    color: #fff;
    margin-bottom: var(--space-5);
  }

  .family-section p {
    color: rgba(255,255,255,0.76);
    font-size: var(--text-lg);
    line-height: 1.75;
  }

  .family-facts {
    display: grid;
    gap: var(--space-3);
  }

  .family-facts div {
    padding: var(--space-6);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: var(--radius-md);
    background: rgba(255,255,255,0.06);
  }

  .family-facts strong {
    display: block;
    color: #fff;
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    line-height: 1;
  }

  .family-facts span {
    color: rgba(255,255,255,0.62);
  }

  .team-cta {
    padding: var(--space-16) 0;
    background: #fff;
  }

  .cta-inner {
    align-items: center;
    justify-content: space-between;
    margin-top: 0;
  }

  .team-cta p {
    max-width: 720px;
    color: var(--mv-gray-600);
    font-size: var(--text-lg);
    line-height: 1.65;
    margin-top: var(--space-3);
  }

  @media (max-width: 1100px) {
    .people-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .hero-grid,
    .leadership-grid,
    .family-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .people-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions,
    .cta-inner {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      width: 100%;
    }
  }
</style>
