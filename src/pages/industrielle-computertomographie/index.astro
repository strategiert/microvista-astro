---
import PruefaufgabenLayout from '../../layouts/PruefaufgabenLayout.astro';
import { loadStaticPage } from '../../lib/load-static-page';
import { type Locale } from '../../i18n/translations';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('industrielle-computertomographie', locale);
---

<PruefaufgabenLayout
  title="Industrielle Computertomographie Dienstleister für Exzellenz"
  description="Defektanalyse, Dimensionsmessung, Montage- & Fügekontrolle durch industrielle Computertomographie: Anywhere. Anytime. Fast."
  content={content}
  locale={locale}
/>
