---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { loadStaticPage, loadStaticPageRaw } from '../lib/load-static-page';
import { localePath, type Locale } from '../i18n/translations';
import { faqSchema, breadcrumbSchema } from '../components/seo/schemas';

const locale = (Astro.locals.locale || 'de') as Locale;
const content = await loadStaticPage('faq', locale);
const raw = await loadStaticPageRaw('faq', locale);

// FAQ-Markdown parsen: Q&A sind als aufeinanderfolgende Absätze nach "## Was Kunden häufig fragen:".
// Frage = Absatz der auf "?" endet. Antwort = alle folgenden Absätze bis zur nächsten Frage.
function extractFaqs(md: string): { question: string; answer: string }[] {
  const start = md.search(/^##\s/m);
  const body = start >= 0 ? md.slice(start) : md;
  const lines = body.split(/\n{2,}/).map(l => l.trim()).filter(Boolean);
  const faqs: { question: string; answer: string }[] = [];
  let current: { question: string; answer: string } | null = null;
  for (const line of lines) {
    if (line.startsWith('#')) continue;
    if (/\?\s*$/.test(line) && !line.startsWith('-') && !line.startsWith('*') && line.length < 200) {
      if (current) faqs.push(current);
      current = { question: line.replace(/\s+/g, ' '), answer: '' };
    } else if (current) {
      current.answer += (current.answer ? ' ' : '') + line.replace(/\n/g, ' ').replace(/\s+/g, ' ');
    }
  }
  if (current && current.answer) faqs.push(current);
  return faqs.slice(0, 20);
}

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://microvista.de';
const faqs = extractFaqs(raw);
const pageSchemas: object[] = [
  breadcrumbSchema([
    { name: 'Home', url: `${siteUrl}${localePath('/', locale)}` },
    { name: 'FAQ', url: `${siteUrl}${localePath('/faq', locale)}` },
  ]),
];
if (faqs.length) pageSchemas.push(faqSchema(faqs));

const labels = {
  de: {
    title: 'Häufig gestellte Fragen',
    description: 'Häufig gestellte Fragen zur industriellen Computertomographie bei Microvista.',
    breadcrumb: 'FAQ'
  },
  en: {
    title: 'FAQ',
    description: 'Frequently asked questions about industrial computed tomography at Microvista.',
    breadcrumb: 'FAQ'
  },
  fr: {
    title: 'FAQ',
    description: 'Questions fréquentes sur la tomographie industrielle chez Microvista.',
    breadcrumb: 'FAQ'
  },
  es: {
    title: 'Preguntas frecuentes',
    description: 'Preguntas frecuentes sobre tomografía industrial en Microvista.',
    breadcrumb: 'FAQ'
  },
  it: {
    title: 'Domande frequenti',
    description: 'Domande frequenti sulla tomografia industriale in Microvista.',
    breadcrumb: 'FAQ'
  }
}[locale] || {
  title: 'Häufig gestellte Fragen',
  description: 'Häufig gestellte Fragen zur industriellen Computertomographie bei Microvista.',
  breadcrumb: 'FAQ'
};
---

<BaseLayout title={labels.title} description={labels.description} schema={pageSchemas}>
  <Header slot="header" />

  <div class="faq-page">
    <div class="container">
      <Breadcrumbs items={[{ label: labels.breadcrumb }]} />
      <article class="faq-content" set:html={content} />
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .faq-page { padding-bottom: var(--space-16); }
  .faq-content { max-width: 800px; margin: 0 auto; padding: var(--space-8) 0; }
  .faq-content :global(h1) { font-size: var(--text-4xl); margin-bottom: var(--space-8); }
  .faq-content :global(h2) { margin-top: var(--space-8); margin-bottom: var(--space-4); }
  .faq-content :global(h3) { margin-top: var(--space-6); margin-bottom: var(--space-3); }
  .faq-content :global(p) { line-height: 1.8; margin-bottom: var(--space-4); }
</style>
